---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-2/Nav.astro';
import Hero from '../components/direction-2/Hero.astro';
import Stats from '../components/direction-2/Stats.astro';
import Services from '../components/direction-2/Services.astro';
import LocalContext from '../components/direction-2/LocalContext.astro';
import WhyChoose from '../components/direction-2/WhyChoose.astro';
import Process from '../components/direction-2/Process.astro';
import Comparison from '../components/direction-2/Comparison.astro';
import Testimonials from '../components/direction-2/Testimonials.astro';
import ServiceAreas from '../components/direction-2/ServiceAreas.astro';
import FinalCTA from '../components/direction-2/FinalCTA.astro';
import Footer from '../components/direction-2/Footer.astro';
---
<Layout title="Neighbourhood Pro — Plumber Happy Valley">
  <style is:global>
    :root {
      --color-brand-primary:   #1D3461;
      --color-brand-secondary: #2D4A8A;
      --color-brand-accent:    #F59E0B;
      --color-brand-bg:        #FAFAF7;
      --color-brand-surface:   #F0EFE9;
      --color-brand-text:      #1A2040;
      --color-brand-muted:     #64748B;
      --font-heading: 'Lexend Variable', system-ui, sans-serif;
      --font-body:    'Source Sans 3 Variable', system-ui, sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); background: var(--color-brand-bg); color: var(--color-brand-text); -webkit-font-smoothing: antialiased; }

    /* ── Section reveal (fade + slide up, staggered via --d) ── */
    .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); transition-delay: var(--d, 0ms); }
    .reveal.is-in { opacity: 1; transform: none; }

    /* ── Hero load sequence ── */
    .d2-hero-left  { opacity: 0; transform: translateY(20px); animation: d2FadeUp .9s cubic-bezier(.22,1,.36,1) .15s forwards; }
    .d2-hero-right { opacity: 0; transform: translateX(48px); animation: d2SlideIn 1s cubic-bezier(.22,1,.36,1) .4s forwards; }
    @keyframes d2FadeUp { to { opacity: 1; transform: none; } }
    @keyframes d2SlideIn { to { opacity: 1; transform: none; } }

    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .reveal, .d2-hero-left, .d2-hero-right { opacity: 1 !important; transform: none !important; animation: none !important; }
    }
    :focus-visible { outline: 3px solid var(--color-brand-accent); outline-offset: 2px; border-radius: 4px; }
  </style>

  <Nav />
  <main>
    <Hero />
    <Stats />
    <Services />
    <LocalContext />
    <WhyChoose />
    <Process />
    <Comparison />
    <Testimonials />
    <ServiceAreas />
    <FinalCTA />
  </main>
  <Footer />

  <script is:inline>
    (() => {
      const els = document.querySelectorAll('.reveal');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((e) => e.classList.add('is-in')); return;
      }
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); } });
      }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
      els.forEach((e) => obs.observe(e));
    })();
  </script>
</Layout>

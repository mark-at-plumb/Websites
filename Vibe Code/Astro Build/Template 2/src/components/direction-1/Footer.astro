---
import Chevron from './Chevron.astro';
const services = [
  ['General Plumbing', '/general-plumbing/'], ['Emergency Plumbing', '/emergency-plumbing/'],
  ['Blocked Drains', '/blocked-drains/'], ['Hot Water', '/hot-water/'],
  ['Gas Fitting', '/gas-fitting/'], ['Pipe Relining', '/pipe-relining/'],
  ['Leak Detection', '/leak-detection/'], ['Taps & Toilets', '/taps-toilets/'],
  ['Burst Pipes', '/burst-pipes/'],
];
const suburbs = ['Aberfoyle Park', 'Reynella', 'Flagstaff Hill', 'Chandlers Hill', 'Trott Park', 'Morphett Vale', 'Old Reynella'];
---
<footer class="bg-brand-primary text-white pt-[clamp(3.5rem,7vw,6rem)] pb-10">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <a href="#top" class="flex items-center gap-2.5">
          <span class="grid place-items-center w-9 h-9 bg-brand-accent text-brand-primary">
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M14 5a3 3 0 0 0-3 3v2H8a2 2 0 0 0-2 2 2 2 0 0 0 2 2h3v2a3 3 0 1 0 6 0" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span class="font-heading font-extrabold tracking-[-0.02em] text-[18px]">Plumber <span class="text-brand-accent">Happy Valley</span></span>
        </a>
        <p class="mt-5 text-[14px] leading-relaxed text-white/60 max-w-sm">
          Local, family-owned plumbing for Happy Valley and the southern suburbs. Show up on time. Do the job properly. Treat the home with respect.
        </p>
        <a href="tel:1300000000" class="group mt-6 inline-flex items-center gap-2.5 bg-brand-accent text-brand-primary font-heading font-extrabold text-[15px] px-5 py-3 hover:bg-white transition-colors">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M3 5c0 8.837 7.163 16 16 16l1.5-3.5-4.5-2-1.8 1.8a12.5 12.5 0 0 1-5.3-5.3L6.5 10 4.5 5.5 3 5Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          1300 XXX XXX <Chevron class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" />
        </a>
      </div>

      <div>
        <h3 class="font-heading font-extrabold uppercase text-[12px] tracking-[0.16em] text-brand-accent">Services</h3>
        <ul class="mt-5 space-y-2.5">
          {services.map(([label, href]) => (
            <li><a href={href} class="group inline-flex items-center gap-1.5 text-[14px] text-white/65 hover:text-white transition-colors"><Chevron class="w-3 h-3 text-brand-accent/60 group-hover:text-brand-accent transition-colors" />{label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading font-extrabold uppercase text-[12px] tracking-[0.16em] text-brand-accent">Service Areas</h3>
        <ul class="mt-5 space-y-2.5">
          {suburbs.map((s) => (
            <li><a href="#contact" class="group inline-flex items-center gap-1.5 text-[14px] text-white/65 hover:text-white transition-colors"><Chevron class="w-3 h-3 text-brand-accent/60 group-hover:text-brand-accent transition-colors" />{s}</a></li>
          ))}
        </ul>
        <h3 class="mt-7 font-heading font-extrabold uppercase text-[12px] tracking-[0.16em] text-brand-accent">Contact</h3>
        <p class="mt-4 text-[14px] text-white/65 leading-relaxed">Happy Valley, SA<br/>Open 24/7 for emergencies</p>
      </div>
    </div>

    <div class="mt-12 relative overflow-hidden h-28 sm:h-32">
      <img src="/ab-images/electrician-van-skyline.webp" alt="Our service fleet" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-primary via-brand-primary/40 to-transparent"></div>
    </div>

    <div class="mt-10 pt-7 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-[12.5px] text-white/45">
        Lic. #333997 &middot; ABN 52 668 135 886 &middot; Master Plumber South Australia
      </p>
      <p class="text-[12.5px] text-white/45 flex items-center gap-2">
        <span class="text-brand-accent">&#9733;</span> Proudly supporting Make-A-Wish Australia
      </p>
    </div>
    <p class="mt-4 text-[12px] text-white/30">&copy; {new Date().getFullYear()} Plumber Happy Valley. All rights reserved.</p>
  </div>
</footer>

---
// Global scroll-reveal: any element with [data-reveal] fades + rises in.
---
<style is:global>
  [data-reveal] { opacity: 0; transform: translateY(26px); transition: opacity .65s cubic-bezier(.2,.7,.2,1), transform .65s cubic-bezier(.2,.7,.2,1); transition-delay: var(--rd, 0s); }
  [data-reveal].is-in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { opacity:1; transform:none; transition:none; } }
</style>
<script is:inline>
  (() => {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); } });
    }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
    const attach = () => document.querySelectorAll('[data-reveal]:not(.is-in)').forEach((el) => io.observe(el));
    if (document.readyState !== 'loading') attach(); else document.addEventListener('DOMContentLoaded', attach);
  })();
</script>

---
import Chevron from './Chevron.astro';
const creds = [
  'Fully Licensed & Insured — Lic. #333997',
  'Master Plumber, South Australia',
  '500+ verified 5-star reviews',
  'Lifetime Labour Warranty on every job',
  '24/7 emergency service, 365 days',
  '10% pensioner discount',
  'Humm interest-free finance available',
  'ABN 52 668 135 886',
];
---
<section class="bg-brand-primary text-white py-[clamp(2.5rem,5vw,4rem)] border-y-2 border-brand-accent/30">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="flex flex-col lg:flex-row lg:items-center gap-8">
      <p class="font-heading font-black text-[clamp(1.3rem,3vw,1.9rem)] tracking-[-0.02em] leading-[1.05] lg:w-1/4 shrink-0">
        Licensed,<br/>insured &amp;<br/><span class="text-brand-accent">accountable.</span>
      </p>
      <ul data-reveal class="grid sm:grid-cols-2 gap-x-8 gap-y-3 flex-1">
        {creds.map((c) => (
          <li class="flex items-center gap-3 text-[14.5px] text-white/80">
            <Chevron class="w-4 h-4 text-brand-accent shrink-0" /> {c}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

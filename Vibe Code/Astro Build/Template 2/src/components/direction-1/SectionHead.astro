---
import Chevron from './Chevron.astro';
interface Props { eyebrow: string; title: string; align?: 'left' | 'center'; dark?: boolean; }
const { eyebrow, title, align = 'left', dark = false } = Astro.props;
const center = align === 'center';
---
<div data-reveal class={`max-w-2xl ${center ? 'mx-auto text-center' : ''}`}>
  <p class={`flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.34em] text-brand-accent ${center ? 'justify-center' : ''}`}>
    <Chevron class="w-3.5 h-3.5" /> {eyebrow}
  </p>
  <h2 class={`mt-4 font-heading font-black tracking-[-0.03em] leading-[1.02] text-[clamp(1.85rem,4.2vw,3rem)] ${dark ? 'text-white' : 'text-brand-primary'}`}>{title}</h2>
  <p class={`mt-4 text-[1.02rem] leading-relaxed ${dark ? 'text-white/65' : 'text-brand-muted'}`}><slot /></p>
</div>

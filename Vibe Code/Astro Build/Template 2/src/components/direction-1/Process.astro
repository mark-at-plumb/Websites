---
import SectionHead from './SectionHead.astro';
const steps = [
  { n: '1', title: 'Call or Book Online', desc: 'Speak to a real local team member who books a time that suits you. Emergency? We aim to be there within the hour.' },
  { n: '2', title: 'On-Site Assessment', desc: 'We inspect the problem properly, explain what is going on in plain English, and give you a fixed price before any work begins.' },
  { n: '3', title: 'Work Completed', desc: 'Once you approve the price, we get it done with quality parts, tidy up after ourselves, and leave your home as we found it.' },
  { n: '4', title: 'Signed Off & Guaranteed', desc: 'We walk you through the finished work and back our labour for life. If anything is not right, we come back and make it right.' },
];
---
<section class="relative bg-brand-bg py-[clamp(4rem,8vw,7rem)] overflow-hidden">
  <img src="/ab-images/electrician-loading-tools.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-brand-primary/85"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <SectionHead eyebrow="Our Process" title="Four simple steps, no surprises" align="center" dark={true}>
      We keep it straightforward so you always know what is happening and what it costs.
    </SectionHead>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 relative">
      {steps.map((s, i) => (
        <div data-reveal style={`--rd:${i * 90}ms`} class="relative">
          <div class="flex items-center gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-brand-accent text-brand-primary font-heading font-black text-[1.25rem] shrink-0">{s.n}</span>
            <span class="h-px flex-1 bg-gradient-to-r from-brand-accent/50 to-transparent hidden lg:block"></span>
          </div>
          <h3 class="mt-5 font-heading font-extrabold text-[1.2rem] tracking-[-0.02em] text-white leading-tight">{s.title}</h3>
          <p class="mt-2.5 text-[14px] leading-relaxed text-white/75">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

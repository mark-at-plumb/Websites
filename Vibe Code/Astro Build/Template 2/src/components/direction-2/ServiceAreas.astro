---
import Shield from './Shield.astro';
const areas = ['Happy Valley','Aberfoyle Park','Flagstaff Hill','Chandlers Hill','Reynella','Old Reynella','Woodcroft','Morphett Vale','O\'Halloran Hill','Trott Park','Hallett Cove','Coromandel Valley','Cherry Gardens','Clarendon'];
---
<section id="areas" class="bg-brand-bg">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 md:py-32">
    <div class="reveal max-w-2xl">
      <p class="flex items-center gap-2 font-heading font-medium text-[11px] tracking-[0.18em] uppercase text-brand-accent mb-4">
        <Shield class="w-3.5 h-4" /> Where We Work
      </p>
      <h2 class="font-heading font-extrabold text-brand-text tracking-[-0.025em] leading-[1.05] text-[clamp(2rem,4.5vw,3rem)]">Serving Happy Valley and surrounds</h2>
      <p class="mt-4 text-[1.05rem] text-brand-text/70 font-light">Based in the southern suburbs, we cover Happy Valley and the surrounding foothills daily. If your suburb is nearby and not listed, give us a call — chances are we\'re already in your street.</p>
    </div>
    <ul class="reveal mt-10 flex flex-wrap gap-3">
      {areas.map((a) => (
        <li>
          <a href="#" class="inline-flex items-center gap-2 rounded-full bg-white border border-brand-primary/12 px-4 py-2 text-[14px] font-medium text-brand-text hover:border-brand-accent hover:text-brand-primary hover:shadow-[0_8px_20px_-12px_rgba(29,52,97,0.5)] transition-all duration-300">
            <Shield class="w-3 h-3.5 text-brand-accent" /> {a}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

---
// Recurring "verified, trusted local" motif — a shield with an inner check.
interface Props { class?: string; }
const { class: className = 'w-6 h-6' } = Astro.props;
---
<svg viewBox="0 0 24 28" class={className} fill="none" aria-hidden="true">
  <path d="M12 1.2 1.6 5.2v8.1c0 6.6 4.4 11 10.4 13.3 6-2.3 10.4-6.7 10.4-13.3V5.2L12 1.2Z"
    stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/>
  <path d="M7.4 13.6l3.1 3.1 6.1-6.5" stroke="currentColor" stroke-width="1.8"
    stroke-linecap="round" stroke-linejoin="round"/>
</svg>

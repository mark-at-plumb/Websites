---
import Shield from './Shield.astro';
const features = [
  { title: '24/7 Emergency Response', icon: 'clock', desc: 'Burst pipe at midnight or a blocked drain on a public holiday — we answer around the clock and aim to be at your door within the hour, every day of the year.' },
  { title: 'Lifetime Labour Warranty', icon: 'shield', desc: 'Every job we complete is backed by a Lifetime Labour Warranty. If our workmanship ever fails, we come back and put it right at no cost to you. Simple as that.' },
  { title: 'Fixed Upfront Pricing', icon: 'tag', desc: 'No hourly rates, no bill shock. You get the full price in writing before we lift a tool, so the figure we quote is the figure you pay — even if the job runs long.' },
  { title: 'Family-Owned & Local', icon: 'home', desc: 'We\'re a family-run Adelaide business, not a franchise call centre. You deal with the same licensed team start to finish, people who live and work in your area.' },
];
const icons = {
  clock: 'M12 7v5l3 2M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z',
  tag: 'M3 12V5a2 2 0 0 1 2-2h7l9 9-9 9-9-9Zm5-4.5a1.2 1.2 0 1 0 0-2.4 1.2 1.2 0 0 0 0 2.4Z',
  home: 'M3 11l9-7 9 7M5 10v9h5v-5h4v5h5v-9',
};
---
<section id="why" class="bg-brand-bg">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 md:py-32 grid lg:grid-cols-[420px_1fr] gap-12 lg:gap-16 items-start">
   <div class="reveal lg:sticky lg:top-28">
     <img src="/images/team.jpg" alt="Our family-owned plumbing team" loading="lazy" class="w-full h-full object-cover rounded-xl shadow-[0_24px_50px_-20px_rgba(29,52,97,0.4)]" />
   </div>
   <div>
    <div class="reveal max-w-2xl">
      <p class="flex items-center gap-2 font-heading font-medium text-[11px] tracking-[0.18em] uppercase text-brand-accent mb-4">
        <Shield class="w-3.5 h-4" /> Why Choose Us
      </p>
      <h2 class="font-heading font-extrabold text-brand-text tracking-[-0.025em] leading-[1.05] text-[clamp(2rem,4.5vw,3rem)]">A professional outfit, not just a sole trader</h2>
    </div>
    <div class="mt-14 grid sm:grid-cols-2 gap-6">
      {features.map((f, i) => (
        <div class="d2-why reveal rounded-xl bg-white border-2 border-brand-primary/10 p-7 hover:border-brand-primary/25 transition-colors duration-300" style={`--d:${i * 90}ms`}>
          <span class="grid place-items-center w-12 h-12 rounded-xl bg-brand-accent/15 text-brand-accent mb-5">
            {f.icon === 'shield'
              ? <Shield class="w-6 h-7" />
              : <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d={icons[f.icon]} stroke-linecap="round" stroke-linejoin="round"/></svg>}
          </span>
          <h3 class="font-heading font-bold text-[1.15rem] text-brand-text">{f.title}</h3>
          <p class="mt-3 text-[14.5px] leading-relaxed text-brand-muted">{f.desc}</p>
        </div>
      ))}
    </div>
   </div>
  </div>
</section>

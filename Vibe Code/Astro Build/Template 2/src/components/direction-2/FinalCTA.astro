---
import Shield from './Shield.astro';
---
<section id="contact" class="relative bg-brand-accent overflow-hidden">
  <div class="pointer-events-none absolute -right-16 -top-12 text-brand-primary/10" aria-hidden="true"><Shield class="w-[380px] h-[460px]" /></div>
  <div class="relative mx-auto max-w-4xl px-5 sm:px-8 py-24 md:py-28 text-center">
    <p class="reveal flex items-center justify-center gap-2 font-heading font-semibold text-[11px] tracking-[0.18em] uppercase text-brand-primary/70 mb-5">
      <Shield class="w-3.5 h-4" /> Within-the-Hour Response
    </p>
    <h2 class="reveal font-heading font-extrabold text-brand-primary tracking-[-0.025em] leading-[1.05] text-[clamp(2.1rem,5vw,3.4rem)]">Need a plumber in Happy Valley today?</h2>
    <p class="reveal mt-5 max-w-2xl mx-auto text-[1.0625rem] text-brand-primary/80 font-medium">Call now for a fixed upfront price and 24/7 emergency service, or request a free quote online. Your first service is $50 off — and every job is backed by our Lifetime Labour Warranty.</p>
    <div class="reveal mt-9 flex flex-wrap items-center justify-center gap-4">
      <a href="tel:1300000000" class="inline-flex items-center gap-2.5 bg-brand-primary text-white font-heading font-bold text-[17px] px-8 py-4 rounded-xl shadow-[0_14px_36px_-10px_rgba(15,23,42,0.6)] hover:-translate-y-0.5 transition-all duration-300">
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true"><path d="M3 5c0 8.837 7.163 16 16 16l1.5-3.5-4.5-2-1.8 1.8a12.5 12.5 0 0 1-5.3-5.3L6.5 10 4.5 5.5 3 5Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Call 1300 XXX XXX
      </a>
      <a href="#" class="inline-flex items-center gap-2 font-heading font-bold text-[16px] text-brand-primary px-7 py-4 rounded-xl border-2 border-brand-primary/30 hover:border-brand-primary/60 hover:bg-brand-primary/5 transition-all duration-300">
        Get a Free Quote
      </a>
    </div>
  </div>
</section>

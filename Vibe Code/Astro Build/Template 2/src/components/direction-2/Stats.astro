---
const stats = [
  { kind: 'count', value: 500, suffix: '+', label: 'Five-Star Reviews', sub: 'from Adelaide homeowners' },
  { kind: 'count', value: 10, suffix: ' Years', label: 'In Adelaide Homes', sub: 'a decade of local experience' },
  { kind: 'type', text: '24/7', label: 'Emergency Response', sub: 'weekends + public holidays' },
];
---
<section class="relative isolate overflow-hidden border-y border-white/10">
  <img src="/images/hero-plumber.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-20 h-full w-full object-cover" />
  <div class="absolute inset-0 -z-10 bg-brand-primary/85"></div>
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-16 md:py-20 grid sm:grid-cols-3 gap-10 sm:gap-6 text-center sm:text-left">
    {stats.map((s, i) => (
      <div class="d2-stat reveal" style={`--d:${i * 120}ms`}>
        <div class="font-heading font-black tracking-[-0.03em] text-white leading-none text-[clamp(3.4rem,7vw,5rem)]">
          {s.kind === 'count'
            ? <span class="d2-counter" data-target={s.value} data-suffix={s.suffix}>0{s.suffix}</span>
            : <span class="d2-typer" data-text={s.text}></span>}
        </div>
        <div class="mt-3 h-1 w-14 mx-auto sm:mx-0 rounded-full bg-brand-accent"></div>
        <p class="mt-4 font-heading font-bold text-[1.05rem] text-white">{s.label}</p>
        <p class="text-[14px] text-white/65 mt-0.5">{s.sub}</p>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const counters = document.querySelectorAll('.d2-counter');
    const typers = document.querySelectorAll('.d2-typer');

    const runCount = (el) => {
      const target = +el.dataset.target;
      const suffix = el.dataset.suffix || '';
      if (reduce) { el.textContent = target + suffix; return; }
      const dur = 1400; const start = performance.now();
      const tick = (now) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(target * eased) + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    const runType = (el) => {
      const text = el.dataset.text;
      if (reduce) { el.textContent = text; return; }
      let i = 0;
      const id = setInterval(() => {
        el.textContent = text.slice(0, ++i);
        if (i >= text.length) clearInterval(id);
      }, 160);
    };

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting || e.target.dataset.done) return;
        e.target.dataset.done = '1';
        if (e.target.classList.contains('d2-counter')) runCount(e.target);
        else runType(e.target);
      });
    }, { threshold: 0.6 });
    counters.forEach((c) => obs.observe(c));
    typers.forEach((t) => obs.observe(t));
  })();
</script>

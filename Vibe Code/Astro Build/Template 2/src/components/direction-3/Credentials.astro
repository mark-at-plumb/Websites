---
import Droplet from './Droplet.astro';
const creds = [
  '$50 Off First Service', 'Within-the-Hour Response', 'Fixed Upfront Pricing', 'Lifetime Labour Warranty',
  'Lic. #333997 — Master Plumber SA', '500+ 5-Star Reviews', '24/7 Emergency Service', '10% Pensioner Discount',
  'Humm Interest-Free Finance', 'Family-Owned, Locally Led', 'A Decade of Adelaide Experience', 'ABN 52 668 135 886',
];
---
<section class="bg-brand-surface py-[clamp(4rem,8vw,6rem)]">
  <div class="mx-auto max-w-5xl px-5 sm:px-8 text-center">
    <p class="d3-reveal font-body font-semibold text-[10px] uppercase tracking-[0.2em] text-brand-accent mb-8 flex items-center justify-center gap-2"><Droplet class="w-2.5 h-3" /> Licensed, insured and properly backed</p>
    <div class="d3-reveal flex flex-wrap justify-center gap-2.5">
      {creds.map((c) => (
        <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/25 text-brand-accent font-body font-medium text-[13px] px-4 py-2">
          <Droplet class="w-2 h-2.5" />{c}
        </span>
      ))}
    </div>
  </div>
</section>

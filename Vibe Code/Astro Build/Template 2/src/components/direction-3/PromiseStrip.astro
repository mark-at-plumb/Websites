---
import Droplet from './Droplet.astro';
---
<section class="d3-reveal bg-brand-surface py-[clamp(4rem,8vw,6.5rem)]">
  <div class="mx-auto max-w-4xl px-5 sm:px-8 text-center">
    <Droplet class="mx-auto mb-7 w-7 h-9 text-brand-accent d3-float" />
    <p class="font-heading italic font-medium text-brand-primary leading-[1.25] text-[clamp(1.6rem,4.5vw,2.85rem)]" style="font-variation-settings:'opsz' 72;">
      Show up on time. Do the job properly. Treat the home with respect.
    </p>
    <p class="mt-7 font-body text-[13px] uppercase tracking-[0.18em] text-brand-muted">The promise behind every visit</p>
  </div>
</section>

---
import Droplet from './Droplet.astro';
---
<section id="contact" class="relative overflow-hidden bg-brand-accent py-[clamp(5rem,10vw,8rem)] text-white">
  <Droplet class="d3-float pointer-events-none absolute -left-8 top-10 w-32 h-40 text-white/[0.07]" />
  <Droplet class="d3-float-slow pointer-events-none absolute right-6 bottom-6 w-20 h-24 text-white/10" />
  <div class="relative mx-auto max-w-3xl px-5 sm:px-8 text-center">
    <Droplet class="mx-auto mb-7 w-7 h-9 text-white/80" />
    <h2 class="font-heading font-black leading-[1.05] tracking-[-0.02em] text-[clamp(2.25rem,6vw,4rem)]" style="font-variation-settings:'opsz' 144;">
      Let's get it sorted, <span class="italic">properly</span>.
    </h2>
    <p class="mt-6 mx-auto max-w-[48ch] font-body text-[18px] leading-[1.7] text-white/85">
      One call and a real local picks up. Fixed price before we start, lifetime labour warranty after — and your first service is $50 off.
    </p>
    <a href="tel:1300000000" class="mt-9 inline-flex items-center gap-3 rounded-full bg-white text-brand-accent font-heading font-bold text-[clamp(1.25rem,3vw,1.75rem)] px-9 py-5 hover:bg-brand-primary hover:text-white transition-colors" style="font-variation-settings:'opsz' 48;">
      <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 5c0 8.837 7.163 16 16 16l1.5-3.5-4.5-2-1.8 1.8a12.5 12.5 0 0 1-5.3-5.3L6.5 10 4.5 5.5 3 5Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      1300 XXX XXX
    </a>
    <p class="mt-5 font-body text-[14px] text-white/70">24/7 emergency service · weekends &amp; public holidays</p>
  </div>
</section>

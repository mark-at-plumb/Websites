---
import Droplet from './Droplet.astro';
const services = [
  { name: 'General Plumbing', href: '/general-plumbing/', img: '/images/kitchen.jpg', desc: 'Everyday repairs and installs done right the first time — leaking taps, running toilets, new fixtures and the small jobs other plumbers never call back about.' },
  { name: 'Emergency Plumbing', href: '/emergency-plumbing/', img: '/images/service-emergency.jpg', desc: 'A real local on the line, day or night. Within-the-hour response where availability allows, so a midnight disaster does not become a morning catastrophe.' },
  { name: 'Blocked Drains', href: '/blocked-drains/', img: '/images/service-drains.jpg', desc: 'We clear the blockage and find why it happened — CCTV camera inspection, high-pressure jetting and a fixed price before any work begins.' },
  { name: 'Hot Water', href: '/hot-water/', img: '/images/service-hotwater.jpg', desc: 'Repairs, replacements and upgrades across gas, electric and heat-pump systems. Cold shower today, hot water back on the same day wherever we can.' },
  { name: 'Gas Fitting', href: '/gas-fitting/', img: '/images/kitchen.jpg', desc: 'Licensed gas work done safely and to code — appliance installs, leak repairs and compliance certificates. No shortcuts where gas is involved.' },
  { name: 'Pipe Relining', href: '/pipe-relining/', img: '/images/service-drains.jpg', desc: 'Fix damaged pipes without digging up your yard. A trenchless reline restores the pipe from the inside and lasts for decades.' },
  { name: 'Leak Detection', href: '/leak-detection/', img: '/images/service-emergency.jpg', desc: 'Acoustic and thermal tools pinpoint hidden leaks before they wreck floors and walls — and before they balloon your next water bill.' },
  { name: 'Taps & Toilets', href: '/taps-toilets/', img: '/images/bathroom.jpg', desc: 'Dripping taps and wobbly toilets handled fast and tidy. Quality parts, clean workmanship and the mess cleaned up before we leave.' },
  { name: 'Burst Pipes', href: '/burst-pipes/', img: '/images/service-emergency.jpg', desc: 'Water everywhere? We isolate the supply, repair the burst and dry the situation out — fast, calm and fixed properly so it holds.' },
];
---
<section id="services" class="bg-brand-bg py-[clamp(4.5rem,9vw,7rem)]">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="d3-reveal max-w-2xl">
      <p class="font-body font-semibold text-[10px] uppercase tracking-[0.2em] text-brand-accent mb-4 flex items-center gap-2"><Droplet class="w-2.5 h-3" /> What we do</p>
      <h2 class="font-heading font-black text-brand-primary leading-[1.05] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]" style="font-variation-settings:'opsz' 96;">
        What we do in <span class="italic text-brand-accent">Happy Valley</span>
      </h2>
      <p class="mt-5 font-body text-[17px] leading-[1.7] text-brand-secondary">Nine things we do every day for local homes — each with the same fixed upfront pricing and lifetime labour warranty.</p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2">
      {services.map((s, i) => (
        <a href={s.href} class="d3-reveal d3-card group relative block overflow-hidden rounded-[20px] bg-white" style={`--rd:${(i % 2) * 90}ms`}>
          <div class="relative overflow-hidden rounded-t-[20px]">
            <img src={s.img} alt={`${s.name} in Happy Valley`} class="w-full h-52 object-cover rounded-t-[20px] transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-brand-accent/15"></div>
            <Droplet class="absolute right-5 bottom-4 w-5 h-6 text-white/40 transition-colors group-hover:text-white/70" />
          </div>
          <div class="relative p-8 pl-9">
            <span class="absolute left-0 top-0 h-full w-1.5 bg-brand-accent/40 transition-all duration-300 group-hover:bg-brand-accent"></span>
            <h3 class="font-heading font-bold text-[22px] text-brand-primary tracking-[-0.01em]" style="font-variation-settings:'opsz' 40;">{s.name}</h3>
            <p class="mt-3 font-body text-[15px] leading-[1.65] text-brand-secondary max-w-[44ch]">{s.desc}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 font-body font-semibold text-[14px] text-brand-accent">
              Learn more
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .d3-card { box-shadow: 0 2px 4px rgba(122,79,40,0.04), 0 12px 28px -16px rgba(122,79,40,0.18); transition: box-shadow .35s ease, transform .35s ease; }
  .d3-card:hover { transform: translateY(-4px); box-shadow: 0 10px 24px -6px rgba(13,115,119,0.28), 0 28px 60px -24px rgba(13,115,119,0.35); }
</style>

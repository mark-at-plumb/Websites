---
import Droplet from './Droplet.astro';
const steps = [
  { t: 'You call, we answer', d: 'A real local — not a call centre — picks up, listens to the problem and books a time that suits you, including same-day for emergencies.' },
  { t: 'We arrive on time', d: 'We turn up in the window we promised, take a proper look, and explain plainly what is going on and what your options are.' },
  { t: 'Fixed price, agreed first', d: 'You get the full price upfront and in writing before any work starts. You decide. No surprises, no hourly meter ticking over.' },
  { t: 'Done properly, cleaned up', d: 'We do the job to code, test it, tidy the site and back it with our Lifetime Labour Warranty before we leave.' },
];
---
<section class="bg-brand-surface py-[clamp(4.5rem,9vw,7rem)]">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="d3-reveal max-w-2xl mb-14">
      <p class="font-body font-semibold text-[10px] uppercase tracking-[0.2em] text-brand-accent mb-4 flex items-center gap-2"><Droplet class="w-2.5 h-3" /> How it works</p>
      <h2 class="font-heading font-black text-brand-primary leading-[1.05] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]" style="font-variation-settings:'opsz' 96;">
        Four steps, no surprises
      </h2>
    </div>
    <div class="relative grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="hidden lg:block absolute top-[18px] left-[12%] right-[12%] h-px bg-brand-accent/30" aria-hidden="true"></div>
      {steps.map((s, i) => (
        <div class="d3-reveal relative" style={`--rd:${i*80}ms`}>
          <div class="relative z-10 flex items-center gap-3 mb-5">
            <span class="grid place-items-center w-9 h-9 rounded-full bg-brand-accent text-white font-heading font-bold text-[15px]">{i+1}</span>
            <Droplet class="w-3 h-4 text-brand-accent/40" />
          </div>
          <h3 class="font-heading font-bold text-[19px] text-brand-primary" style="font-variation-settings:'opsz' 36;">{s.t}</h3>
          <p class="mt-2.5 font-body text-[15px] leading-[1.65] text-brand-secondary">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

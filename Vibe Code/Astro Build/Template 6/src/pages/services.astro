---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BookingForm from '../components/BookingForm.astro';
import BrandPartners from '../components/BrandPartners.astro';
import ServiceTiles from '../components/ServiceTiles.astro';
import Ratings from '../components/Ratings.astro';
---

<Layout title="Plumbing Services Adelaide | Hilton Plumbing">

<Nav />

<!-- HERO -->
<section style="background:#0E151B; overflow:hidden;">
  <div class="hero-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:480px;">
    <div style="display:flex; flex-direction:column; justify-content:center; padding:80px 40px 80px 20px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; margin:0 0 16px;">What We Do</p>
      <h1 style="font-family:var(--font-heading); font-size:clamp(2rem,4vw,3.2rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 16px;">Plumbing Services<br/>Adelaide</h1>
      <p style="font-size:16px; color:rgba(255,255,255,0.75); line-height:1.7; margin:0 0 32px; max-width:480px;">Having plumbing issues? We've got it covered. Upfront quoting, licensed plumbers, and 2,500+ five-star reviews across Adelaide.</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/contact/" style="display:inline-block; background:#E86000; color:#fff; text-decoration:none; padding:14px 32px; border-radius:5px; font-family:var(--font-heading); font-size:16px; font-weight:700;">Book Now</a>
        <a href="tel:1300872343" style="display:inline-flex; align-items:center; gap:8px; border:2px solid rgba(255,255,255,0.35); color:#fff; text-decoration:none; padding:12px 24px; border-radius:5px; font-family:var(--font-heading); font-size:15px; font-weight:600;">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          1300 872 343
        </a>
      </div>
    </div>
    <div class="hero-img-col" style="position:relative; overflow:hidden;">
      <img
        src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/05/img-hero-banner01.png.webp"
        alt="Adelaide plumbing services"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;"
      />
    </div>
  </div>
</section>

<ServiceTiles />

<!-- SERVICE CARDS -->
<section style="background:#0E151B; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:52px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">Our Services</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0;">Our Plumbing Services in Adelaide</h2>
    </div>
    <div class="svc-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:2px; background:rgba(255,255,255,0.06); border-radius:10px; overflow:hidden;">
      {[
        { img:'/images/hello-plumbing-hot-water-system-electrician.webp', title:'Hot Water Systems',   tag:'Install & Repair',        desc:'Gas, electric, solar and heat pump. Same-day service available. Backed by warranty.',              href:'/hot-water/' },
        { img:'/images/Gas-fitter-and-plumber-baulkham-hills.webp',       title:'Gas Fitting',         tag:'Install & Leak Detection', desc:'Licensed gas fitting, appliance installations, and leak detection across Adelaide.',              href:'#' },
        { img:'/images/blocked-drain-plumber-baulkham-hills.webp',        title:'Blocked Drains',      tag:'CCTV · Hydrojet · Reline', desc:'CCTV drain inspection and high-pressure hydrojetting. Fixed upfront. Backed by warranty.',       href:'#' },
        { img:'/images/Plumbing-Leak-Detection-Service.webp',             title:'Leak Detection',      tag:'Non-Invasive',             desc:'We locate hidden leaks before opening walls or floors. Fast, accurate, and mess-free.',          href:'#' },
        { img:'/images/Plumbing-Emergency-Near-Me.webp',                  title:'Emergency Plumber',   tag:'24/7 Response',            desc:'We answer around the clock. No call-out fee. Aiming to arrive within the hour.',                href:'#' },
        { img:'/images/commercial-plumbing.webp',                         title:'Commercial Plumbing', tag:'Maintenance & Fit-Out',    desc:'Shops, offices, restaurants and strata. Scheduled servicing and emergency callouts.',           href:'#' },
      ].map(c => (
        <div class="svc-card" style="background:#111d26; overflow:hidden; display:flex; flex-direction:column;">
          <div style="position:relative; overflow:hidden;">
            <img src={c.img} alt={c.title} style="width:100%; height:200px; object-fit:cover; display:block;" />
            <div style="position:absolute; top:12px; left:12px; background:#E86000; color:#fff; font-family:var(--font-heading); font-size:11px; font-weight:700; letter-spacing:0.06em; padding:4px 10px; border-radius:3px;">{c.tag}</div>
          </div>
          <div style="padding:24px; flex:1; display:flex; flex-direction:column; gap:10px;">
            <h3 style="font-family:var(--font-heading); font-size:1rem; font-weight:800; color:#fff; margin:0;">{c.title}</h3>
            <p style="font-size:14px; color:rgba(255,255,255,0.6); line-height:1.7; margin:0; flex:1;">{c.desc}</p>
            <a href={c.href} style="display:inline-flex; align-items:center; gap:6px; color:#E86000; font-family:var(--font-heading); font-weight:700; font-size:13px; text-decoration:none; margin-top:4px;">
              Find out more
              <svg width="13" height="13" fill="none" stroke="#E86000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT WE STAND FOR -->
<section style="background:#012D5E; padding:56px 20px;">
  <div style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 2fr; gap:60px; align-items:start;">
    <div>
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 12px;">Our Promise</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0 0 16px; line-height:1.2;">What We Stand For</h2>
      <p style="font-size:15px; color:rgba(255,255,255,0.65); line-height:1.7; margin:0;">Five reasons Adelaide homeowners trust us with every job.</p>
    </div>
    <div style="display:flex; flex-direction:column; gap:0; border-top:1px solid rgba(255,255,255,0.12);">
      {[
        { title:'Upfront Pricing',                           body:'Fixed quote before we start. No hourly rates, no call-out fees, no bill shock.',                                          icon:'M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z' },
        { title:'No Call Out Fees',                          body:'We come to your Adelaide home at no extra charge. Our pricing covers the job, not the travel.',                           icon:'M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z' },
        { title:'All Workmanship Guaranteed',                body:'Lifetime Labour Warranty on every job. If a fault occurs due to our workmanship, we return and fix it for free.',          icon:'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z' },
        { title:'Reasonable Pricing and Top Quality Service', body:'Fair pricing doesn\'t mean corners cut. Licensed team, quality parts, proven methods on every Adelaide job.',              icon:'M21 6.5C21 8.43 19.43 10 17.5 10S14 8.43 14 6.5 15.57 3 17.5 3 21 4.57 21 6.5zM5 6h7v2H5V6zM3 13h18v2H3v-2zm0 5h18v2H3v-2z' },
        { title:'Genuine Cost Effective Solutions',           body:'We fix the real problem, not just the symptom. Honest advice, no upselling.',                                             icon:'M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7zm2.85 11.1l-.85.6V16h-4v-2.3l-.85-.6A4.997 4.997 0 0 1 7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.63-.8 3.16-2.15 4.1z' },
      ].map(item => (
        <details class="accord" style="border-bottom:1px solid rgba(255,255,255,0.12);">
          <summary style="display:flex; align-items:center; justify-content:space-between; padding:20px 4px; gap:16px; user-select:none;">
            <span style="display:flex; align-items:center; gap:14px;">
              <span style="flex-shrink:0; width:34px; height:34px; border-radius:8px; background:rgba(232,96,0,0.15); border:1px solid rgba(232,96,0,0.25); display:flex; align-items:center; justify-content:center;">
                <svg width="18" height="18" fill="#E86000" viewBox="0 0 24 24"><path d={item.icon}/></svg>
              </span>
              <span class="accord-title" style="font-family:var(--font-heading); font-size:16px; font-weight:700; color:#fff; transition:color 0.2s;">{item.title}</span>
            </span>
            <span class="accord-icon" style="flex-shrink:0; width:28px; height:28px; border:1.5px solid rgba(255,255,255,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:300; color:#E86000; line-height:1;"></span>
          </summary>
          <p style="padding:0 4px 20px 62px; margin:0; font-size:15px; color:rgba(255,255,255,0.72); line-height:1.75;">{item.body}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<Ratings />

<BrandPartners />
<BookingForm />
<Footer />

</Layout>

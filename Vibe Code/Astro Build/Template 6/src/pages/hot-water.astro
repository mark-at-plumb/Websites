---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BookingForm from '../components/BookingForm.astro';
import BrandPartners from '../components/BrandPartners.astro';
import ServiceTiles from '../components/ServiceTiles.astro';
import Ratings from '../components/Ratings.astro';
---

<Layout title="Hot Water Systems Adelaide | Hilton Plumbing">

<Nav />

<!-- HERO -->
<section style="background:#0E151B; overflow:hidden;">
  <div class="hero-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:480px;">
    <div style="display:flex; flex-direction:column; justify-content:center; padding:80px 40px 80px 20px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; margin:0 0 16px;">Hot Water Specialists</p>
      <h1 style="font-family:var(--font-heading); font-size:clamp(2rem,4vw,3.2rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 16px;">Hot Water System<br/>Install &amp; Repair</h1>
      <p style="font-size:16px; color:rgba(255,255,255,0.75); line-height:1.7; margin:0 0 32px; max-width:480px;">Gas, electric, solar and heat pump systems. Same-day service available across Adelaide. Fixed upfront pricing, no call-out fees, Lifetime Labour Warranty.</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/contact/" style="display:inline-block; background:#E86000; color:#fff; text-decoration:none; padding:14px 32px; border-radius:5px; font-family:var(--font-heading); font-size:16px; font-weight:700;">Book Now</a>
        <a href="tel:1300872343" style="display:inline-flex; align-items:center; gap:8px; border:2px solid rgba(255,255,255,0.35); color:#fff; text-decoration:none; padding:12px 24px; border-radius:5px; font-family:var(--font-heading); font-size:15px; font-weight:600;">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          1300 872 343
        </a>
      </div>
    </div>
    <div class="hero-img-col" style="position:relative; overflow:hidden;">
      <img
        src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/05/img-hero-banner01.png.webp"
        alt="Hot water system Adelaide"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;"
      />
    </div>
  </div>
</section>

<ServiceTiles />

<!-- SYSTEM TYPES -->
<section style="background:#fff; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:52px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">What We Supply &amp; Install</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#0E151B; margin:0 0 12px;">Hot Water System Types</h2>
      <p style="font-size:15px; color:#6d6d6d; max-width:580px; margin:0 auto; line-height:1.7;">Every Adelaide home is different. We'll recommend the right system for your household size, energy preference, and budget.</p>
    </div>
    <div class="four-col" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px;">
      {[
        { icon:'M12 2a5 5 0 0 1 5 5c0 2.7-1.6 5-4 6.3V20a1 1 0 0 1-2 0v-6.7C8.6 12 7 9.7 7 7a5 5 0 0 1 5-5z', title:'Gas Storage',      desc:'Reliable and cost-effective. Stores and reheats water in an insulated tank using gas burners.' },
        { icon:'M17 8C8 10 5.9 16.2 9.7 20.6c.5-1.3.7-2.7.5-4 .2 0 .5.1.7.2.4.1.8.3 1.1.6.9.7 1.4 1.9 1.4 3.1 2.3-1.6 3.4-4.5 2.8-7.3-.8.4-1.7.6-2.7.8 1.8-1.4 3-3.5 3.5-6z', title:'Instant Gas',      desc:'Continuous flow — only heats water when you need it. Great for larger households.' },
        { icon:'M7 2v11h3v9l7-12h-4l4-8z',                                                                             title:'Electric Storage',  desc:'Simple and affordable to install. Connects to off-peak tariffs to reduce running costs.' },
        { icon:'M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z',                                                         title:'Solar Hot Water',   desc:'Harness Adelaide\'s sun to heat your water. Excellent long-term savings with a gas backup.' },
        { icon:'M9 11.24V7.5C9 6.12 10.12 5 11.5 5S14 6.12 14 7.5v3.74c1.21-.81 2-2.18 2-3.74C16 5.01 13.99 3 11.5 3S7 5.01 7 7.5c0 1.56.79 2.93 2 3.74zm9.84 4.63l-4.54-2.26c-.17-.07-.35-.11-.54-.11H13v-6c0-.83-.67-1.5-1.5-1.5S10 6.67 10 7.5v10.74l-3.43-.72c-.08-.01-.15-.03-.24-.03-.31 0-.59.13-.79.33l-.79.8 4.94 4.94c.27.27.65.44 1.06.44h6.79c.75 0 1.33-.55 1.44-1.28l.75-5.27c.01-.07.02-.14.02-.2 0-.62-.38-1.16-.91-1.38z', title:'Heat Pump',        desc:'3x more energy efficient than standard electric. Ideal for Adelaide\'s climate.' },
        { icon:'M21 6.5C21 8.43 19.43 10 17.5 10S14 8.43 14 6.5 15.57 3 17.5 3 21 4.57 21 6.5zM5 6h7v2H5V6zM3 13h18v2H3v-2zm0 5h18v2H3v-2z', title:'Instant Electric', desc:'Compact and space-saving. Heats water on demand with no tank required.' },
        { icon:'M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z', title:'Commercial',        desc:'High-capacity systems for offices, restaurants, and strata buildings.' },
        { icon:'M12 2l-5.5 9h11L12 2zm0 3.84L14.93 10H9.07L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5S15.01 22 17.5 22s4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z', title:'Water Filtration',  desc:'Clean, filtered water throughout your home. We supply and install whole-house systems.' },
      ].map(s => (
        <div style="background:#F9F9F9; border-radius:10px; padding:28px 24px; border-top:3px solid #E86000;">
          <div style="width:44px; height:44px; background:#fff; border-radius:8px; border:1px solid #e8e8e8; display:flex; align-items:center; justify-content:center; margin-bottom:16px; box-shadow:0 2px 6px rgba(0,0,0,0.06);">
            <svg width="22" height="22" fill="#E86000" viewBox="0 0 24 24"><path d={s.icon}/></svg>
          </div>
          <h3 style="font-family:var(--font-heading); font-size:1rem; font-weight:800; color:#0E151B; margin:0 0 8px;">{s.title}</h3>
          <p style="font-size:14px; color:#6d6d6d; line-height:1.7; margin:0 0 16px;">{s.desc}</p>
          <a href="/contact/" style="font-family:var(--font-heading); font-size:13px; font-weight:700; color:#E86000; text-decoration:none;">Get a quote &rarr;</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section style="background:#0E151B; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:52px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">The Process</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0;">Getting a New Hot Water System is Easy</h2>
    </div>
    <div class="four-col" style="display:grid; grid-template-columns:repeat(4,1fr); gap:24px;">
      {[
        { n:'01', title:'Choose Your System', desc:'Tell us your home size, energy preference and budget. We\'ll recommend the best option.' },
        { n:'02', title:'Get a Fixed Quote',  desc:'We provide a written upfront price — no hidden extras, no call-out fees.' },
        { n:'03', title:'Same-Day Install',   desc:'Our licensed team arrives on time and completes the installation with minimal disruption.' },
        { n:'04', title:'Final Inspection',   desc:'We test everything, walk you through operation, and clean up before we leave.' },
      ].map(s => (
        <div style="text-align:center; padding:32px 20px;">
          <div style="width:56px; height:56px; border-radius:50%; background:#E86000; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-family:var(--font-heading); font-size:18px; font-weight:900; color:#fff;">{s.n}</div>
          <h3 style="font-family:var(--font-heading); font-size:1rem; font-weight:800; color:#fff; margin:0 0 10px;">{s.title}</h3>
          <p style="font-size:14px; color:rgba(255,255,255,0.6); line-height:1.7; margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- COMMON PROBLEMS — card grid -->
<section style="background:#012D5E; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:52px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">Repairs &amp; Troubleshooting</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0 0 12px;">Common Hot Water Problems We Fix</h2>
      <p style="font-size:15px; color:rgba(255,255,255,0.55); max-width:560px; margin:0 auto; line-height:1.7;">No hot water? System leaking? Running out too fast? Our licensed plumbers diagnose and fix on the same visit — parts on-truck, upfront pricing.</p>
    </div>
    <div class="three-col" style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:40px;">
      {[
        { icon:'M12 2a5 5 0 0 1 5 5c0 2.7-1.6 5-4 6.3V20a1 1 0 0 1-2 0v-6.7C8.6 12 7 9.7 7 7a5 5 0 0 1 5-5z',                                                                              title:'No Hot Water',               body:'Faulty pilot light, broken thermostat, or failed element. We diagnose and fix on the same visit with parts on-truck.' },
        { icon:'M17.66 11.2c-.23-.3-.51-.56-.77-.82-.67-.6-1.43-1.03-2.07-1.66C13.33 7.26 13 4.85 13.95 3c-.95.23-1.78.75-2.49 1.32-2.43 2.03-3.45 5.37-2.35 8.43-.06.07-.12.13-.18.21-.29.41-.52.86-.54 1.37-.02.53.18 1.06.51 1.46.65.81 1.66 1.22 2.69 1.32.34.03.69.04 1.04.02 1.72-.1 3.33-.9 4.29-2.29.58-.84.85-1.89.66-2.89l-.06-.25c.03.01.05.02.08.04zM11.5 15.38c-.29.23-.64.38-1 .44-.7.12-1.42-.05-1.99-.43-.29-.19-.52-.45-.66-.76-.14-.31-.19-.65-.15-.98.04-.35.17-.68.36-.97.28-.43.65-.78 1.05-1.09 1.14.59 2.07 1.39 2.76 2.37-.09.15-.21.29-.37.42z',                                      title:'Water Not Hot Enough',        body:'Thermostat or element issue. We test, recalibrate, or replace the faulty component on the spot.' },
        { icon:'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z',                                                                          title:'Runs Out Too Quickly',        body:'Tank may be undersized or element underperforming. We right-size your system during the same call.' },
        { icon:'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',           title:'Leaking Unit',               body:'Leaks near the relief valve or tank base often mean replacement is due. We assess and advise honestly.' },
        { icon:'M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z', title:'Noisy Pipes or Unit',         body:'Banging or rumbling means sediment buildup or a failing element. We flush and service the system.' },
        { icon:'M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z', title:'High Energy Bills',           body:'An ageing system often costs more to run than a new heat pump pays back in 2–3 years. We\'ll run the numbers.' },
      ].map(c => (
        <div class="problem-card" style="background:#fff; border-radius:10px; padding:28px 24px; border-left:3px solid #E86000; display:flex; flex-direction:column; gap:14px;">
          <div style="width:44px; height:44px; border-radius:8px; background:rgba(232,96,0,0.12); border:1px solid rgba(232,96,0,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="20" height="20" fill="#E86000" viewBox="0 0 24 24"><path d={c.icon}/></svg>
          </div>
          <h3 class="problem-card-title" style="font-family:var(--font-heading); font-size:1rem; font-weight:800; color:#0E151B; margin:0;">{c.title}</h3>
          <p class="problem-card-body" style="font-size:14px; color:#4a4a4a; line-height:1.75; margin:0; flex:1;">{c.body}</p>
        </div>
      ))}
    </div>
    <div style="text-align:center;">
      <a href="tel:1300872343" style="display:inline-flex; align-items:center; gap:10px; background:#E86000; color:#fff; text-decoration:none; padding:15px 36px; border-radius:5px; font-family:var(--font-heading); font-size:16px; font-weight:700;">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        Call 1300 872 343 — Same Day Service
      </a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section style="background:#fff; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:48px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">FAQs</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#0E151B; margin:0;">Frequently Asked Questions</h2>
    </div>
    <div style="max-width:800px; margin:0 auto; border-top:1px solid #e8e8e8;">
      {[
        { q:'How long does a hot water system last?',              a:'Most systems last 8–15 years depending on type, usage and maintenance. If yours is over 10 years old and losing efficiency, replacement is often more cost-effective than repair.' },
        { q:'What temperature should I set my hot water to?',      a:'Australian guidelines recommend 60°C for tank-based systems to prevent legionella, with tempering valves to deliver 50°C at the tap for safety.' },
        { q:'Which system is best for a family of 4?',             a:'A 250–315 litre gas storage or continuous flow unit suits most 4-person households. We\'ll calculate the right size based on your usage patterns.' },
        { q:'Can I switch from electric to gas hot water?',        a:'Yes. We handle the full conversion including gas line connection. Many Adelaide homes see significant savings after switching.' },
        { q:'Do you offer same-day installation?',                 a:'Yes — in most cases. If your current system has failed, call us and we\'ll aim to have hot water restored the same day.' },
        { q:'Is solar hot water worth it in Adelaide?',            a:'Absolutely. Adelaide averages over 2,500 hours of sunshine per year. A solar system typically pays for itself within 5–7 years.' },
      ].map(item => (
        <details class="accord" style="border-bottom:1px solid #e8e8e8;">
          <summary style="display:flex; align-items:center; justify-content:space-between; padding:20px 4px; gap:16px; user-select:none;">
            <span class="accord-title" style="font-family:var(--font-heading); font-size:16px; font-weight:700; color:#0E151B; transition:color 0.2s;">{item.q}</span>
            <span class="accord-icon" style="flex-shrink:0; width:28px; height:28px; border:1.5px solid #ccc; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:300; color:#E86000; line-height:1;"></span>
          </summary>
          <p style="padding:0 4px 20px; margin:0; font-size:15px; color:#4a4a4a; line-height:1.75;">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<Ratings />
<BrandPartners />
<BookingForm />
<Footer />

</Layout>

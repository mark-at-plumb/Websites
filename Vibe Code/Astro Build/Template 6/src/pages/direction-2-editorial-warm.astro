---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { usps, services, emergencyPoints, process, credentials, faqs, adjoiningSuburbs, phone, phoneHref, email } from '../data/content';
---

<Layout title="Direction 2 — Editorial Warm | Plumber [Suburb]">
  <style is:global>
    :root {
      --color-brand-primary:   #1B1B1B;
      --color-brand-secondary: #2A2420;
      --color-brand-accent:    #C1561F;
      --color-brand-bg:        #F7F2EA;
      --color-brand-surface:   #EFE7D8;
      --color-brand-text:      #2A2420;
      --color-brand-muted:     #6B6258;
      --font-heading: 'Fraunces Variable', Georgia, serif;
    }
  </style>

  <Header />

  <main>
    <!-- Full-bleed photographic hero -->
    <section class="relative h-[36rem] sm:h-[42rem] overflow-hidden">
      <img src="/images/stock/pexels-8486972.jpg" alt="Local plumber on the job in [Suburb]" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"></div>
      <div class="relative h-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col justify-end pb-16">
        <span class="text-brand-accent text-xs font-bold uppercase tracking-[0.2em] mb-4">[Suburb], South Australia</span>
        <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-[0.95] max-w-3xl mb-6">
          Properly done. <em class="not-italic text-brand-accent">On time</em>, every time.
        </h1>
        <p class="text-white/80 text-lg max-w-xl mb-8 leading-relaxed">
          Plumber [Suburb] is the local, family-owned plumber for [Suburb] homes — backed by a
          Lifetime Labour Warranty and a fixed price before we lift a tool.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center justify-center bg-brand-accent text-white px-8 py-4 text-sm font-bold tracking-wide hover:bg-orange-800 transition-colors">
            Book a Job
          </a>
          <a href={phoneHref} class="inline-flex items-center justify-center border border-white/40 text-white px-8 py-4 text-sm font-bold tracking-wide hover:bg-white/10 transition-colors">
            Call {phone}
          </a>
        </div>
      </div>
    </section>

    <!-- Stat band -->
    <section class="bg-brand-primary text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 grid grid-cols-2 sm:grid-cols-4 gap-8 text-center sm:text-left">
        {[
          ['10+', 'Years across Adelaide'],
          ['500+', '5-star reviews'],
          ['24/7', 'Emergency response'],
          ['$0', 'Surprises on the bill'],
        ].map(([num, label]) => (
          <div>
            <div class="font-heading text-4xl font-bold text-brand-accent">{num}</div>
            <div class="text-sm text-white/70 mt-1">{label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Welcome -->
    <section id="about" class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-brand-primary mb-6">[Suburb]'s Trusted Local Plumbers</h2>
      <p class="text-lg text-brand-text leading-relaxed">
        We're a family-owned plumbing business serving [Suburb] homes, backed by a decade of
        hands-on work across Adelaide and Lic. #333997 with Master Plumber South Australia. Every
        job is completed by our licensed local team, fully insured and quoted upfront.
      </p>
    </section>

    <!-- Services — alternating rows -->
    <section id="services" class="bg-brand-surface py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-brand-primary mb-14 text-center">What We Fix in [Suburb]</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-10">
          {services.map((s) => (
            <div class="flex gap-4">
              <Icon name={s.icon} class="w-7 h-7 text-brand-accent shrink-0 mt-1" />
              <div>
                <h3 class="font-heading text-base font-bold text-brand-primary mb-1">{s.name}</h3>
                <p class="text-sm text-brand-muted leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why choose — image/text split -->
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <img src="/images/stock/pexels-6422939.jpg" alt="A [Suburb] home we service" class="w-full h-80 lg:h-[28rem] object-cover" />
      <div>
        <h2 class="font-heading text-3xl font-bold text-brand-primary mb-6">Why [Suburb] Locals Choose Us</h2>
        <ul class="space-y-5">
          {usps.map((u) => (
            <li class="flex gap-4">
              <Icon name={u.icon} class="w-6 h-6 text-brand-accent shrink-0 mt-1" />
              <div>
                <h3 class="font-heading text-base font-bold text-brand-primary">{u.title}</h3>
                <p class="text-sm text-brand-muted leading-relaxed">{u.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Emergency band -->
    <section id="emergency" class="bg-brand-secondary text-white py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6">When It Can't Wait, We Don't Either</h2>
        <p class="text-white/75 leading-relaxed max-w-2xl mx-auto mb-10">
          Where availability allows, we aim to be at your door within the hour, 24/7. While you
          wait, turn off the mains and, if you smell gas, open windows and leave the house.
        </p>
        <div class="flex flex-wrap justify-center gap-3 mb-10">
          {emergencyPoints.map((p) => (
            <span class="text-xs sm:text-sm border border-white/20 rounded-full px-4 py-2 text-white/85">{p}</span>
          ))}
        </div>
        <a href={phoneHref} class="inline-flex items-center justify-center bg-brand-accent text-white px-8 py-4 text-sm font-bold tracking-wide hover:bg-orange-800 transition-colors">
          Call Now: {phone}
        </a>
      </div>
    </section>

    <!-- Vertical process timeline -->
    <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="font-heading text-3xl font-bold text-brand-primary mb-12 text-center">How We Work</h2>
      <div class="space-y-10 border-l-2 border-brand-surface pl-8">
        {process.map((p) => (
          <div class="relative">
            <span class="absolute -left-[39px] top-0 w-4 h-4 rounded-full bg-brand-accent"></span>
            <h3 class="font-heading text-lg font-bold text-brand-primary mb-1">{p.title}</h3>
            <p class="text-sm text-brand-muted leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Credentials -->
    <section class="bg-brand-surface py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-bold text-brand-primary mb-10 text-center">Our Credentials and Standards</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-4">
          {credentials.map((c) => (
            <li class="flex items-start gap-3">
              <Icon name="check" class="w-4 h-4 mt-1 text-brand-accent shrink-0" />
              <span class="text-sm text-brand-text">{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Service areas -->
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="font-heading text-3xl font-bold text-brand-primary mb-4">Servicing [Suburb] and Surrounding Areas</h2>
      <p class="text-brand-text leading-relaxed max-w-2xl mx-auto mb-8">
        We're based locally and service [Suburb] plus the neighbouring suburbs as part of our
        greater Adelaide coverage area.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {adjoiningSuburbs.map((s) => (
          <span class="border border-brand-muted/30 px-4 py-2 text-sm font-semibold text-brand-primary">{s}</span>
        ))}
      </div>
    </section>

    <!-- Final CTA -->
    <section id="contact" class="relative overflow-hidden bg-brand-primary text-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20 text-center">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6">Need a Plumber in [Suburb]?</h2>
        <p class="text-white/80 leading-relaxed max-w-xl mx-auto mb-10">
          Call {phone} any time, day or night. New customers get $50 off their first
          service, backed by our Lifetime Labour Warranty on every job.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={phoneHref} class="inline-flex items-center justify-center bg-brand-accent text-white px-8 py-4 text-sm font-bold tracking-wide hover:bg-orange-800 transition-colors">
            Call {phone}
          </a>
          <a href={`mailto:${email}`} class="inline-flex items-center justify-center border border-white/30 text-white px-8 py-4 text-sm font-bold tracking-wide hover:bg-white/10 transition-colors">
            Email Us
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ accordion -->
    <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="font-heading text-3xl font-bold text-brand-primary mb-10 text-center">Plumber FAQs</h2>
      <div class="divide-y divide-brand-surface">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex items-center justify-between cursor-pointer list-none font-heading font-bold text-brand-primary">
              {f.q}
              <span class="text-brand-accent text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-sm text-brand-muted leading-relaxed mt-3">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

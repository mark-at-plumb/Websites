---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BrandPartners from '../components/BrandPartners.astro';
---

<Layout title="Plumber Adelaide | Hilton Plumbing | Local Family-Owned">



<!-- NAVIGATION -->
<Nav />


<!-- ═══════════════════════════════════════════════
     HERO — split layout
════════════════════════════════════════════════ -->
<section style="background:#0E151B; overflow:hidden;">
  <div class="hero-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:580px;">

    <!-- Left: text -->
    <div style="display:flex; flex-direction:column; justify-content:center; padding:80px 40px 80px 20px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; margin:0 0 16px;">Your Mate in the Trade&reg;</p>
      <h1 style="font-family:var(--font-heading); font-size:clamp(2.2rem,4.5vw,3.6rem); font-weight:800; color:#fff; line-height:1.08; margin:0 0 10px;">
        Your mate in<br/>the trade
      </h1>
      <p style="font-family:var(--font-heading); font-size:clamp(1.1rem,2.2vw,1.6rem); font-weight:500; color:#E86000; margin:0 0 22px;">Plumbers Adelaide</p>
      <p style="font-size:16px; color:rgba(255,255,255,0.78); line-height:1.7; margin:0 0 36px; max-width:480px;">
        Your mate will fix your sink without breaking your bank. Trust us for reliable and budget-friendly solutions to all your plumbing needs.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:center;">
        <a href="/contact/" style="display:inline-block; background:#E86000; color:#fff; text-decoration:none; padding:14px 32px; border-radius:5px; font-family:var(--font-heading); font-size:16px; font-weight:700;">
          Book now
        </a>
        <a href="tel:1300872343" style="display:inline-flex; align-items:center; gap:8px; border:2px solid rgba(255,255,255,0.35); color:#fff; text-decoration:none; padding:12px 24px; border-radius:5px; font-family:var(--font-heading); font-size:15px; font-weight:600; transition:border-color 0.2s;">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          1300 872 343
        </a>
      </div>
    </div>

    <!-- Right: hero image -->
    <div class="hero-img-col" style="position:relative; overflow:hidden;">
      <img
        src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/05/img-hero-banner01.png.webp"
        alt="Adelaide plumber ready to help"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;"
      />
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     SERVICE TILES — professional version
════════════════════════════════════════════════ -->
<section style="background:#E86000; padding:0;">
  <div style="max-width:1260px; margin:0 auto;">
    <div class="eight-grid" style="display:grid; grid-template-columns:repeat(8,1fr);">
      {[
        {
          label: 'Hot Water\nSystems',
          href: '/hot-water/',
          svg: 'M12 2a5 5 0 0 1 5 5c0 2.7-1.6 5-4 6.3V20a1 1 0 0 1-2 0v-6.7C8.6 12 7 9.7 7 7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3c0 1.9 1.2 3.5 3 4.2 1.8-.7 3-2.3 3-4.2a3 3 0 0 0-3-3z',
        },
        {
          label: 'Blocked\nDrains',
          href: '/blocked-drains/',
          svg: 'M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zM7 11h10v2H7v-2zm3-4h4v2h-4V7zm1 8h2v2h-2v-2z',
        },
        {
          label: 'Gas\nFitting',
          href: '/gas-fitting/',
          svg: 'M17 8C8 10 5.9 16.2 9.7 20.6c.5-1.3.7-2.7.5-4 .2 0 .5.1.7.2.4.1.8.3 1.1.6.9.7 1.4 1.9 1.4 3.1 2.3-1.6 3.4-4.5 2.8-7.3-.8.4-1.7.6-2.7.8 1.8-1.4 3-3.5 3.5-6z',
        },
        {
          label: 'Leak\nDetection',
          href: '/leak-detection/',
          svg: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
        },
        {
          label: 'Emergency\nPlumbing',
          href: '/emergency/',
          svg: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
        },
        {
          label: 'Commercial\nPlumbing',
          href: '/commercial/',
          svg: 'M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z',
        },
        {
          label: 'General\nPlumbing',
          href: '/services/',
          svg: 'M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z',
        },
        {
          label: 'Water\nFiltration',
          href: '/water-filtration/',
          svg: 'M12 2l-5.5 9h11L12 2zm0 3.84L14.93 10H9.07L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5S15.01 22 17.5 22s4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z',
        },
      ].map(s => (
        <a href={s.href} class="svc-tile" style="display:flex; flex-direction:column; align-items:center; gap:10px; padding:22px 10px; border-left:1px solid rgba(255,255,255,0.2); border-right:1px solid rgba(255,255,255,0.2); text-decoration:none; background:#E86000;">
          <svg width="28" height="28" fill="#fff" viewBox="0 0 24 24"><path d={s.svg}/></svg>
          <span style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#fff; line-height:1.35; text-align:center; white-space:pre-line;">{s.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     WHAT WE STAND FOR — accordion
════════════════════════════════════════════════ -->
<section style="background:#012D5E; padding:56px 20px;">
  <div style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 2fr; gap:60px; align-items:start;">

    <!-- Left heading -->
    <div>
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 12px;">Our Promise</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0 0 16px; line-height:1.2;">What We Stand For</h2>
      <p style="font-size:15px; color:rgba(255,255,255,0.65); line-height:1.7; margin:0;">Five reasons Adelaide homeowners trust us with every job — big or small.</p>
    </div>

    <!-- Right: accordion items -->
    <div style="display:flex; flex-direction:column; gap:0; border-top:1px solid rgba(255,255,255,0.12);">
      {[
        {
          title: 'Upfront Pricing',
          body: 'You get a fixed quote before we lift a single tool. No hourly rates, no call-out fees, no bill shock. The price we quote is the price you pay — every time.',
          iconPath: 'M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z',
        },
        {
          title: 'No Call Out Fees',
          body: 'We come to your Adelaide home at no extra charge. Our pricing covers the job, not the travel. Simply call and we come.',
          iconPath: 'M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z',
        },
        {
          title: 'All Workmanship Guaranteed',
          body: 'Every job is backed by our Lifetime Labour Warranty. If a fault occurs because of our workmanship, we return and fix it at no cost to you.',
          iconPath: 'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z',
        },
        {
          title: 'Reasonable Pricing and Top Quality Service',
          body: 'Fair pricing does not mean cutting corners. Our licensed team uses quality parts and proven methods on every job, backed by over a decade of Adelaide plumbing experience.',
          iconPath: 'M21 6.5C21 8.43 19.43 10 17.5 10S14 8.43 14 6.5 15.57 3 17.5 3 21 4.57 21 6.5zM5 6h7v2H5V6zM3 13h18v2H3v-2zm0 5h18v2H3v-2z',
        },
        {
          title: 'Genuine Cost Effective Solutions',
          body: 'We fix the real problem, not just the symptom. We will never upsell you parts or work you do not need, and we always give honest advice on the best path forward.',
          iconPath: 'M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7zm2.85 11.1l-.85.6V16h-4v-2.3l-.85-.6A4.997 4.997 0 0 1 7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.63-.8 3.16-2.15 4.1z',
        },
      ].map((item, i) => (
        <details class="accord" style="border-bottom:1px solid rgba(255,255,255,0.12);">
          <summary style="display:flex; align-items:center; justify-content:space-between; padding:20px 4px; gap:16px; user-select:none;">
            <span style="display:flex; align-items:center; gap:14px;">
              <span style="flex-shrink:0; width:34px; height:34px; border-radius:8px; background:rgba(232,96,0,0.15); border:1px solid rgba(232,96,0,0.25); display:flex; align-items:center; justify-content:center;">
                <svg width="18" height="18" fill="#E86000" viewBox="0 0 24 24"><path d={item.iconPath}/></svg>
              </span>
              <span class="accord-title" style="font-family:var(--font-heading); font-size:16px; font-weight:700; color:#fff; transition:color 0.2s;">{item.title}</span>
            </span>
            <span class="accord-icon" style="flex-shrink:0; width:28px; height:28px; border:1.5px solid rgba(255,255,255,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:300; color:#E86000; line-height:1;"></span>
          </summary>
          <p style="padding:0 4px 20px 62px; margin:0; font-size:15px; color:rgba(255,255,255,0.72); line-height:1.75;">{item.body}</p>
        </details>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     AWARD / RATINGS — matching Hilton Plumbing
════════════════════════════════════════════════ -->
<section style="background:#fff; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">

    <div style="text-align:center; margin-bottom:48px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">Customer Reviews</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#0E151B; margin:0;">Award Winning Service</h2>
    </div>

    <div class="rating-row" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px;">
      {[
        { platform: 'Google',         stars: '4.9', count: '2,614', color: '#4285F4' },
        { platform: 'Facebook',       stars: '4.8', count: '259',   color: '#1877F2' },
        { platform: 'Product Review', stars: '4.8', count: '729',   color: '#E86000' },
        { platform: 'Word of Mouth',  stars: '4.8', count: '65',    color: '#0E151B' },
      ].map(r => (
        <div class="rating-card" style="border:1px solid #e8e8e8; border-radius:10px; padding:28px 20px; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
          <div style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#6d6d6d; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:14px;">{r.platform}</div>
          <div style="display:flex; justify-content:center; gap:3px; margin-bottom:14px;">
            {[1,2,3,4,5].map(() => <span style={`color:#F5A623; font-size:20px; line-height:1;`}>&#9733;</span>)}
          </div>
          <div class="rating-counter" data-target={r.stars} style="font-family:var(--font-heading); font-size:2.6rem; font-weight:900; color:#0E151B; line-height:1;">0.0</div>
          <div style="font-family:var(--font-heading); font-size:12px; font-weight:600; color:#6d6d6d; margin-top:8px; letter-spacing:0.03em;">BASED ON {r.count} REVIEWS</div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     TESTIMONIALS — professional version
════════════════════════════════════════════════ -->
<section style="background:#0E151B; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">

    <div style="text-align:center; margin-bottom:48px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">What Our Customers Say</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#fff; margin:0 0 8px;">Our Happy Customers</h2>
      <p style="color:rgba(255,255,255,0.55); font-size:15px; margin:0;">4.9 out of 5 &nbsp;&middot;&nbsp; 2,500+ verified reviews across Google, Facebook &amp; Product Review</p>
    </div>

    <div class="testi-row" style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px;">
      {[
        {
          name: 'Sarah M.',
          initials: 'SM',
          date: '2 weeks ago',
          platform: 'Google',
          text: 'Fantastic service. The plumber arrived exactly on time, gave us a fixed price upfront, and sorted the blocked drain within the hour. No mess, no fuss. Will definitely use again.',
        },
        {
          name: 'James T.',
          initials: 'JT',
          date: '1 month ago',
          platform: 'Google',
          text: 'Professional, friendly, and knew exactly what was wrong with our hot water system. Price was fair and the work was done properly. Best plumber we have used in Adelaide.',
        },
        {
          name: 'Karen L.',
          initials: 'KL',
          date: '3 weeks ago',
          platform: 'Google',
          text: 'Called at 7am about a burst pipe. The team was at our door within the hour. The whole job was quoted before they started and came in on budget. Outstanding service.',
        },
      ].map(t => (
        <div class="testi-card" style="background:#fff; border-radius:10px; padding:32px 28px; position:relative; box-shadow:0 4px 16px rgba(0,0,0,0.15);">
          <!-- Quote mark -->
          <div style="font-family:Georgia, serif; font-size:64px; color:#E86000; line-height:0.7; margin-bottom:16px; opacity:0.9;">&ldquo;</div>

          <!-- Stars -->
          <div style="display:flex; gap:2px; margin-bottom:14px;">
            {[1,2,3,4,5].map(() => <span style="color:#F5A623; font-size:14px;">&#9733;</span>)}
          </div>

          <!-- Text -->
          <p style="font-size:15px; color:#4a4a4a; line-height:1.75; margin:0 0 24px;">{t.text}</p>

          <!-- Reviewer -->
          <div style="display:flex; align-items:center; gap:12px; border-top:1px solid #f0f0f0; padding-top:20px;">
            <div style="width:40px; height:40px; border-radius:50%; background:#0E151B; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-family:var(--font-heading); font-size:13px; font-weight:700; color:#fff;">{t.initials}</span>
            </div>
            <div style="flex:1;">
              <div style="font-family:var(--font-heading); font-weight:700; font-size:14px; color:#0E151B;">{t.name}</div>
              <div style="font-size:12px; color:#6d6d6d;">{t.platform} &middot; {t.date}</div>
            </div>
            <!-- Google G icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" style="flex-shrink:0; opacity:0.5;"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════
     AWARD WINNING SERVICE — matching Hilton layout
     (text left · plumber image right, person centred)
════════════════════════════════════════════════ -->
<section style="background:#F3F3F3; padding:64px 20px;">
  <div class="about-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;">

    <!-- Left: text + badges -->
    <div>
      <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 12px;">Who We Are</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:#0E151B; margin:0 0 20px; line-height:1.2;">Award Winning Service</h2>
      <p style="font-size:16px; color:#4a4a4a; line-height:1.8; margin:0 0 16px;">
        At Hilton our whole business philosophy is built around being your mate in the trade&reg;. We won't rip you off, we don't upsell you things you don't need, and we always give honest advice.
      </p>
      <p style="font-size:16px; color:#4a4a4a; line-height:1.8; margin:0 0 32px;">
        Family-owned and locally operated, backed by Lic.&nbsp;#333997 (Master Plumber South Australia), a decade of experience, and 500+ 5-star reviews from Adelaide homeowners.
      </p>

      <a href="/about/" style="display:inline-block; background:#E86000; color:#fff; text-decoration:none; padding:13px 28px; border-radius:5px; font-family:var(--font-heading); font-size:15px; font-weight:700;">Learn more</a>
    </div>

    <!-- Right: plumber photo + award badges below -->
    <div style="display:flex; flex-direction:column; align-items:center; gap:20px;">
      <div style="width:380px; height:380px; border-radius:12px; overflow:hidden; box-shadow:0 8px 32px rgba(0,0,0,0.12); background:#e0e0e0;">
        <img
          src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/08/hilton-plumber-600x600.png.webp"
          alt="Hilton Plumbing Adelaide licensed plumber"
          style="width:100%; height:100%; object-fit:cover; object-position:center top;"
        />
      </div>
      <!-- Award badges below the image -->
      <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap; justify-content:center;">
        <img src="/images/MPA.png.webp" alt="Master Plumbers Australia" style="height:52px; width:auto; object-fit:contain;" />
        <img src="/images/best-plumber-award-20251-600x225.png.webp" alt="Best Plumber Award 2025" style="height:40px; width:auto; object-fit:contain;" />

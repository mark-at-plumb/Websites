---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { usps, services, emergencyPoints, process, comparison, credentials, faqs, adjoiningSuburbs, phone, phoneHref, email } from '../data/content';

const quickServices = [
  { name: 'Hot Water Systems', icon: 'flame' },
  { name: 'Blocked Drains', icon: 'drain' },
  { name: 'Gas Fitting', icon: 'gas' },
  { name: 'Leak Detection', icon: 'drop' },
  { name: 'Emergency Plumbing', icon: 'bolt' },
  { name: 'Pipe Relining', icon: 'pipe' },
  { name: 'General Plumbing', icon: 'wrench' },
  { name: 'Taps & Toilets', icon: 'tap' },
];

const valueProps = [
  { title: 'Upfront Pricing', body: 'Fixed quote before we start. No surprises on the bill.', icon: 'dollar' },
  { title: 'Lifetime Labour Warranty', body: 'If a fault is ours, we come back and fix it at no cost.', icon: 'shield' },
  { title: 'Workmanship Guaranteed', body: 'Every job is completed to the highest licensed standard.', icon: 'check' },
  { title: '24/7 Emergency Response', body: 'We respond within the hour where availability allows.', icon: 'clock' },
  { title: 'Local, Family-Owned', body: 'A decade of hands-on experience across Adelaide homes.', icon: 'home' },
];

const ratingPlatforms = [
  { platform: 'Google', rating: '4.9', reviews: '500+' },
  { platform: 'ProductReview', rating: '4.8', reviews: '200+' },
  { platform: 'Facebook', rating: '4.9', reviews: '150+' },
  { platform: 'Houzz', rating: '4.8', reviews: '80+' },
];

const milestones = [
  { stat: '10,000+', label: 'Homes served across Adelaide' },
  { stat: '2,500+', label: 'Hot water systems installed' },
  { stat: '1,800+', label: 'Blocked drains cleared' },
];

const serviceCards = services.slice(0, 6);

const hotWaterBrands = ['Rinnai', 'Rheem', 'Dux', 'Bosch', 'Rinnai', 'Vulcan', 'iStore', 'AquaMax'];

const formJobTypes = [
  'Blocked Drains', 'General Plumbing', 'Hot Water System Install',
  'Hot Water System Repair', 'Leak Detection', 'Burst Pipe',
  'Gas Detection / Repairs', 'Emergency',
];
---

<Layout title="Direction 3 — Minimal Modern | Plumber [Suburb]">
  <style is:global>
    :root {
      --color-brand-primary:   #0F4C4C;
      --color-brand-secondary: #0A3434;
      --color-brand-accent:    #FF6B4A;
      --color-brand-bg:        #FAFAF8;
      --color-brand-surface:   #F0F1ED;
      --color-brand-text:      #1C2422;
      --color-brand-muted:     #6B7572;
      --font-heading: 'Jost Variable', system-ui, sans-serif;
    }
  </style>

  <Header />

  <main>

    <!-- ── S2: HERO — full-width image with overlay text ────────────────── -->
    <section class="relative h-[28rem] sm:h-[36rem] overflow-hidden">
      <img
        src="/images/stock/pexels-8486972.jpg"
        alt="Local licensed plumber in [Suburb] ready for a job"
        class="absolute inset-0 w-full h-full object-cover object-top"
      />
      <div class="absolute inset-0 bg-brand-primary/80"></div>
      <div class="relative h-full flex flex-col items-center justify-center text-center px-4">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white max-w-3xl leading-tight mb-4">
          Your local [Suburb] plumber.
        </h1>
        <p class="text-white/85 text-lg max-w-xl mb-8 leading-relaxed">
          On time. Fixed upfront price. Done properly. Plumber [Suburb] backs every job with a
          Lifetime Labour Warranty and 24/7 emergency response.
        </p>
        <a
          href="#booking"
          class="inline-flex items-center justify-center rounded-full bg-brand-accent text-white px-8 py-4 text-sm font-bold hover:bg-orange-600 transition-colors"
        >
          Book Now
        </a>
      </div>
    </section>

    <!-- ── S3: QUICK SERVICE LINKS — 8-card horizontal row ──────────────── -->
    <section class="bg-white border-b border-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-brand-muted text-center mb-5">Book a plumber now</p>
        <div class="grid grid-cols-4 sm:grid-cols-8 gap-2">
          {quickServices.map((s) => (
            <a href="#services" class="flex flex-col items-center gap-2 rounded-2xl p-3 hover:bg-brand-surface transition-colors text-center group">
              <span class="w-10 h-10 rounded-full bg-brand-primary/10 flex items-center justify-center group-hover:bg-brand-primary/20 transition-colors">
                <Icon name={s.icon} class="w-5 h-5 text-brand-primary" />
              </span>
              <span class="text-xs font-semibold text-brand-text leading-tight">{s.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S4: WHAT WE STAND FOR — 5-column card grid ───────────────────── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary text-center mb-10">What We Stand For</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
          {valueProps.map((v) => (
            <div class="bg-white rounded-3xl p-6 flex flex-col gap-3">
              <span class="w-10 h-10 rounded-full bg-brand-accent/10 flex items-center justify-center shrink-0">
                <Icon name={v.icon} class="w-5 h-5 text-brand-accent" />
              </span>
              <h3 class="font-heading text-sm font-bold text-brand-primary">{v.title}</h3>
              <p class="text-xs text-brand-muted leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S5: AWARD-WINNING SERVICE — 4-column ratings cards ───────────── -->
    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary text-center mb-10">Award-Winning Service</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
          {ratingPlatforms.map((r) => (
            <div class="rounded-3xl border border-brand-surface p-6 flex flex-col items-center gap-3 text-center">
              <div class="flex gap-0.5">
                {Array.from({length: 5}).map(() => (
                  <svg viewBox="0 0 16 16" class="w-4 h-4 text-brand-accent" fill="currentColor">
                    <path d="M8 1l1.85 3.75L14 5.5l-3 2.93.71 4.14L8 10.4l-3.71 2.17.71-4.14L2 5.5l4.15-.75z"/>
                  </svg>
                ))}
              </div>
              <div class="font-heading text-2xl font-bold text-brand-primary">{r.rating}</div>
              <div class="text-xs text-brand-muted">{r.reviews} reviews</div>
              <div class="text-xs font-bold text-brand-text uppercase tracking-wide">{r.platform}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S6: OUR HAPPY CUSTOMERS — stats + testimonial cards ──────────── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary text-center mb-10">Our Happy Customers</h2>
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-5">
          <!-- Stats block -->
          <div class="bg-brand-primary text-white rounded-3xl p-8 flex flex-col justify-center items-center text-center lg:col-span-1">
            <div class="flex gap-0.5 mb-3">
              {Array.from({length: 5}).map(() => (
                <svg viewBox="0 0 16 16" class="w-4 h-4 text-brand-accent" fill="currentColor">
                  <path d="M8 1l1.85 3.75L14 5.5l-3 2.93.71 4.14L8 10.4l-3.71 2.17.71-4.14L2 5.5l4.15-.75z"/>
                </svg>
              ))}
            </div>
            <div class="font-heading text-4xl font-bold mb-1">4.9</div>
            <div class="text-white/75 text-sm">out of 5</div>
            <div class="mt-4 font-heading text-lg font-bold text-brand-accent">500+</div>
            <div class="text-white/75 text-xs">5-Star Reviews</div>
          </div>
          <!-- Testimonial cards — placeholder slots -->
          {[
            { name: 'S. M.', suburb: '[Suburb]', quote: 'Called for a burst pipe at 11pm. They were at the door within the hour, fixed it cleanly and the price was exactly what they quoted. Will use again.' },
            { name: 'T. G.', suburb: '[Suburb]', quote: 'Booked for a blocked drain that two others couldn\'t clear. They found the cause with a camera, sorted it in one visit. Highly recommend.' },
            { name: 'A. R.', suburb: '[Adjoining Suburb]', quote: 'Hot water system died on a Sunday. Replaced same day, no extra charges for the weekend. Fantastic service.' },
          ].map((t) => (
            <div class="bg-white rounded-3xl p-6 flex flex-col gap-4">
              <div class="flex gap-0.5">
                {Array.from({length: 5}).map(() => (
                  <svg viewBox="0 0 16 16" class="w-4 h-4 text-brand-accent" fill="currentColor">
                    <path d="M8 1l1.85 3.75L14 5.5l-3 2.93.71 4.14L8 10.4l-3.71 2.17.71-4.14L2 5.5l4.15-.75z"/>
                  </svg>
                ))}
              </div>
              <p class="text-sm text-brand-text leading-relaxed flex-1">"{t.quote}"</p>
              <div class="text-xs font-bold text-brand-primary">{t.name} &mdash; {t.suburb}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S7: PHILOSOPHY — full-width with image background ────────────── -->
    <section class="relative overflow-hidden">
      <img
        src="/images/stock/pexels-6419128.jpg"
        alt="Plumber [Suburb] — hands-on licensed trade work"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-brand-primary/85"></div>
      <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 text-center text-white">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6">Award-Winning Service</h2>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          We started this business after a decade of watching homeowners get let down by tradies
          who showed up late and rushed the job. So we built one that does the opposite. Fixed
          price before we start. Lifetime Labour Warranty on every job. Local team, real accountability.
        </p>
        <a href="#about" class="inline-flex items-center justify-center rounded-full border border-white/40 text-white px-8 py-3.5 text-sm font-bold hover:bg-white/10 transition-colors">
          Learn More
        </a>
      </div>
    </section>

    <!-- ── S8: CERTIFICATIONS ROW — horizontal trust badges ─────────────── -->
    <section class="bg-white border-b border-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-wrap justify-center gap-6 items-center">
          {[
            { label: 'Lic. #333997', sub: 'Master Plumber SA' },
            { label: 'ABN 52 668 135 886', sub: 'Registered Business' },
            { label: 'Fully Insured', sub: 'All Work Covered' },
            { label: 'AS/NZS 3500', sub: 'Compliant Standard' },
          ].map((b) => (
            <div class="flex flex-col items-center gap-1 text-center min-w-[110px]">
              <span class="text-xs font-bold text-brand-primary uppercase tracking-wide">{b.label}</span>
              <span class="text-xs text-brand-muted">{b.sub}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S9: BOOKING FORM #1 ────────────────────────────────────────────── -->
    <section id="booking" class="bg-brand-surface">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary text-center mb-2">Need a plumber now?</h2>
        <p class="text-brand-muted text-center mb-10">Make a booking</p>
        <div class="bg-white rounded-3xl p-8 shadow-sm">
          <form class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">First Name</label>
              <input type="text" placeholder="Jane" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Last Name</label>
              <input type="text" placeholder="Smith" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Email</label>
              <input type="email" placeholder="jane@example.com" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Phone Number</label>
              <input type="tel" placeholder="04XX XXX XXX" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Address</label>
              <input type="text" placeholder="123 Example Street, [Suburb] SA" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Job Type</label>
              <select class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm text-brand-muted focus:outline-none focus:ring-2 focus:ring-brand-accent/40">
                <option value="">Select a service</option>
                {formJobTypes.map((j) => <option>{j}</option>)}
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Preferred Date</label>
              <input type="date" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Preferred Time</label>
              <select class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm text-brand-muted focus:outline-none focus:ring-2 focus:ring-brand-accent/40">
                <option>8am</option>
                <option>10am</option>
                <option>12pm</option>
                <option>2pm</option>
                <option>Any Time</option>
              </select>
            </div>
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Notes</label>
              <textarea rows="3" placeholder="Describe the issue..." class="rounded-3xl border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40 resize-none"></textarea>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="w-full rounded-full bg-brand-accent text-white py-4 text-sm font-bold hover:bg-orange-600 transition-colors">
                Send Booking Request
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ── S10: LICENSED & PROFESSIONAL — text left, image right ────────── -->
    <section id="about" class="bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary mb-5">
            Licensed and professional plumbers who do the job the right way
          </h2>
          <p class="text-brand-text leading-relaxed mb-6">
            When you book with Plumber [Suburb], you book a fully licensed and qualified plumber
            who will give you a fixed service price before we start, allowing you to plan your day.
            Our plumbers carry fully stocked vehicles and we clean up after ourselves when the job
            is done. We also offer free quotes. If there is no work done, there is no charge.
          </p>
          <a href={`mailto:${email}`} class="inline-flex items-center justify-center rounded-full bg-brand-primary text-white px-7 py-3 text-sm font-semibold hover:bg-brand-secondary transition-colors">
            Contact Us
          </a>
        </div>
        <img
          src="/images/stock/pexels-6284228.jpg"
          alt="Clean, professional plumbing installation"
          class="w-full h-72 lg:h-80 object-cover rounded-3xl"
        />
      </div>
    </section>

    <!-- ── S11: UP FRONT AND ON TIME — image left, text right ───────────── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <img
          src="/images/stock/pexels-6422939.jpg"
          alt="A [Suburb] home we service"
          class="w-full h-72 lg:h-80 object-cover rounded-3xl order-2 lg:order-1"
        />
        <div class="order-1 lg:order-2">
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary mb-5">
            Up front and on time plumbers you can trust
          </h2>
          <p class="text-brand-text leading-relaxed mb-6">
            When you have a plumbing or gas emergency we understand that what you really need is
            someone you can trust to arrive as quickly as possible and get the job done. We
            prioritise emergencies and have a dedicated team ready to respond. We will be honest
            about our arrival time and quote on assessment so there are no surprises.
          </p>
          <a href="#services" class="inline-flex items-center justify-center rounded-full bg-brand-primary text-white px-7 py-3 text-sm font-semibold hover:bg-brand-secondary transition-colors">
            Areas We Serve
          </a>
        </div>
      </div>
    </section>

    <!-- ── S12: BRAND PROMISE — text left, image right ───────────────────── -->
    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary mb-5">
            A local plumber you can rely on for all your plumbing needs
          </h2>
          <p class="text-brand-text leading-relaxed mb-6">
            We all wish we had a trusted local plumber. Why? Because your local plumber turns up
            on time, does what they say they will do, and won't overcharge. That's what Plumber
            [Suburb] was built around. No gimmicks and no costly mark-ups. Just honest, upfront
            plumbing solutions done as quickly and efficiently as we can.
          </p>
          <a href="#about" class="inline-flex items-center justify-center rounded-full bg-brand-primary text-white px-7 py-3 text-sm font-semibold hover:bg-brand-secondary transition-colors">
            Learn More
          </a>
        </div>
        <img
          src="/images/stock/pexels-8486978.jpg"
          alt="Plumber [Suburb] licensed technician"
          class="w-full h-72 lg:h-80 object-cover rounded-3xl"
        />
      </div>
    </section>

    <!-- ── S13: HOT WATER SPOTLIGHT — text left, brand logos right ───────── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <img
          src="/images/stock/pexels-8488060.jpg"
          alt="Plumbing tools — quality parts and equipment"
          class="w-full h-72 lg:h-80 object-cover rounded-3xl"
        />
        <div>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary mb-5">
            [Suburb]'s trusted installer of hot water systems
          </h2>
          <p class="text-brand-text leading-relaxed mb-6">
            Plumber [Suburb] installs and services all major hot water system brands. Whether
            you need a new instantaneous, gas, solar or electric unit, or your existing system
            repaired, we carry the stock and expertise to meet your needs with Fixed Upfront
            Pricing on every job.
          </p>
          <div class="flex flex-wrap gap-2">
            {hotWaterBrands.filter((v, i, a) => a.indexOf(v) === i).map((b) => (
              <span class="rounded-full border border-brand-text/15 px-4 py-1.5 text-xs font-semibold text-brand-text">{b}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── S14: MILESTONE STATS — 3-column ────────────────────────────────── -->
    <section class="bg-brand-primary text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-center mb-2">We're reaching new milestones</h2>
        <p class="text-white/70 text-center mb-10 text-sm">Proud to deliver exceptional plumbing services across Adelaide.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
          {milestones.map((m) => (
            <div>
              <div class="font-heading text-5xl font-bold text-brand-accent mb-2">{m.stat}</div>
              <div class="text-white/75 text-sm">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S15: SERVICE OVERVIEW INTRO — full-width text ─────────────────── -->
    <section id="services" class="bg-white">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-14 text-center">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary mb-5">
          Having plumbing issues? We've got it covered.
        </h2>
        <p class="text-brand-text leading-relaxed">
          Our plumbers always show up on time, quote all of their work upfront and don't charge
          hidden fees. All work is carried out by a licensed and experienced plumber and we clean
          up after ourselves when the work is done. That is why Plumber [Suburb] is one of the
          highest-rated plumbing businesses in Adelaide with 500+ 5-star reviews.
        </p>
      </div>
    </section>

    <!-- ── S16: SERVICES GRID — 2-col cards (icon + title + desc + link) ── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
        <h3 class="font-heading text-lg font-bold text-brand-primary text-center mb-8 uppercase tracking-wide">Our Plumbing Services</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {serviceCards.map((s) => (
            <div class="bg-white rounded-3xl p-7 flex flex-col gap-4">
              <span class="w-10 h-10 rounded-full bg-brand-accent/10 flex items-center justify-center">
                <Icon name={s.icon} class="w-5 h-5 text-brand-accent" />
              </span>
              <h3 class="font-heading text-base font-bold text-brand-primary">{s.name}</h3>
              <p class="text-sm text-brand-muted leading-relaxed flex-1">{s.body}</p>
              <a href={`#services`} class="text-xs font-bold text-brand-accent hover:underline">Find out more →</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S17: CTA BANNER — phone + email centred ───────────────────────── -->
    <section id="contact" class="bg-brand-primary text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-center mb-8">
          A local plumber you can rely on for all your plumbing needs
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href={phoneHref} class="inline-flex items-center gap-3 text-white hover:text-brand-accent transition-colors">
            <Icon name="phone" class="w-5 h-5 text-brand-accent" />
            <span class="font-heading text-xl font-bold">{phone}</span>
          </a>
          <span class="hidden sm:block text-white/30">|</span>
          <a href={`mailto:${email}`} class="inline-flex items-center gap-3 text-white hover:text-brand-accent transition-colors">
            <Icon name="mail" class="w-5 h-5 text-brand-accent" />
            <span class="text-sm font-semibold">{email}</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── S18: BRAND PARTNERS — horizontal logo row ─────────────────────── -->
    <section class="bg-white border-b border-brand-surface">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-brand-muted text-center mb-5">Our Trusted Suppliers</p>
        <div class="flex flex-wrap justify-center gap-4">
          {hotWaterBrands.filter((v, i, a) => a.indexOf(v) === i).map((b) => (
            <div class="rounded-2xl bg-brand-surface px-6 py-3">
              <span class="text-sm font-bold text-brand-primary">{b}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── S19: BOOKING FORM #2 (footer form) ────────────────────────────── -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-brand-primary text-center mb-2">Book a plumber now</h2>
        <p class="text-brand-muted text-center mb-10">We'll be in touch within the hour</p>
        <div class="bg-white rounded-3xl p-8 shadow-sm">
          <form class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">First Name</label>
              <input type="text" placeholder="Jane" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Last Name</label>
              <input type="text" placeholder="Smith" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Email</label>
              <input type="email" placeholder="jane@example.com" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Phone Number</label>
              <input type="tel" placeholder="04XX XXX XXX" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Address</label>
              <input type="text" placeholder="123 Example Street, [Suburb] SA" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Job Type</label>
              <select class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm text-brand-muted focus:outline-none focus:ring-2 focus:ring-brand-accent/40">
                <option value="">Select a service</option>
                {formJobTypes.map((j) => <option>{j}</option>)}
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Preferred Date</label>
              <input type="date" class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Preferred Time</label>
              <select class="rounded-full border border-brand-surface bg-brand-surface px-4 py-3 text-sm text-brand-muted focus:outline-none focus:ring-2 focus:ring-brand-accent/40">
                <option>8am</option>
                <option>10am</option>
                <option>12pm</option>
                <option>2pm</option>
                <option>Any Time</option>
              </select>
            </div>
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label class="text-xs font-bold text-brand-text">Notes</label>
              <textarea rows="3" placeholder="Describe the issue..." class="rounded-3xl border border-brand-surface bg-brand-surface px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-accent/40 resize-none"></textarea>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="w-full rounded-full bg-brand-accent text-white py-4 text-sm font-bold hover:bg-orange-600 transition-colors">
                Send Booking Request
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BrandPartners from '../components/BrandPartners.astro';
import ServiceTiles from '../components/ServiceTiles.astro';
import Ratings from '../components/Ratings.astro';
---

<Layout title="Contact Hilton Plumbing Adelaide | 1300 872 343">

<Nav />

<!-- HERO -->
<section style="background:#0E151B; overflow:hidden;">
  <div class="hero-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:380px;">
    <div style="display:flex; flex-direction:column; justify-content:center; padding:80px 40px 80px 20px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; margin:0 0 16px;">Get in Touch</p>
      <h1 style="font-family:var(--font-heading); font-size:clamp(2rem,4vw,3.2rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 16px;">Contact Hilton<br/>Plumbing Today</h1>
      <p style="font-size:16px; color:rgba(255,255,255,0.75); line-height:1.7; margin:0; max-width:480px;">Fixed upfront pricing. No call-out fees. We respond within 2 hours during business hours. For emergencies, we're available 24/7.</p>
    </div>
    <div class="hero-img-col" style="position:relative; overflow:hidden;">
      <img
        src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/05/img-hero-banner01.png.webp"
        alt="Hilton Plumbing Adelaide"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;"
      />
    </div>
  </div>
</section>

<ServiceTiles />

<!-- CONTACT DETAILS + FORM -->
<section style="background:#fff; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div class="two-col" style="display:grid; grid-template-columns:1fr 1.6fr; gap:60px; align-items:start;">

      <!-- Left: contact info -->
      <div>
        <h2 style="font-family:var(--font-heading); font-size:clamp(1.4rem,2.5vw,1.8rem); font-weight:800; color:#0E151B; margin:0 0 32px; line-height:1.2;">Contact Information</h2>

        <div style="display:flex; flex-direction:column; gap:24px; margin-bottom:40px;">
          {[
            {
              icon:'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
              label:'Address',
              value:'38 Sphinx Way, Bibra Lake 6163',
              href: null,
            },
            {
              icon:'M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z',
              label:'Phone',
              value:'1300 872 343',
              href:'tel:1300872343',
            },
            {
              icon:'M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
              label:'Email',
              value:'enquiries@hiltonplumbing.com.au',
              href:'mailto:enquiries@hiltonplumbing.com.au',
            },
          ].map(c => (
            <div style="display:flex; gap:16px; align-items:flex-start;">
              <div style="width:44px; height:44px; border-radius:10px; background:#FFF4ED; border:1px solid rgba(232,96,0,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="20" height="20" fill="#E86000" viewBox="0 0 24 24"><path d={c.icon}/></svg>
              </div>
              <div>
                <div style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#6d6d6d; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:4px;">{c.label}</div>
                {c.href
                  ? <a href={c.href} style="font-size:16px; color:#0E151B; text-decoration:none; font-weight:600;">{c.value}</a>
                  : <p style="font-size:16px; color:#0E151B; margin:0; font-weight:600;">{c.value}</p>
                }
              </div>
            </div>
          ))}
        </div>

        <!-- Office hours -->
        <div style="background:#F9F9F9; border-radius:10px; padding:28px;">
          <h3 style="font-family:var(--font-heading); font-size:14px; font-weight:700; color:#0E151B; margin:0 0 16px; text-transform:uppercase; letter-spacing:0.08em;">Office Hours</h3>
          <div style="display:flex; flex-direction:column; gap:10px;">
            {[
              { day:'Monday – Friday', hours:'7:00am – 5:00pm' },
              { day:'Saturday',        hours:'8:00am – 12:00pm' },
              { day:'Sunday',          hours:'Closed' },
              { day:'Emergency',       hours:'24 / 7' },
            ].map(h => (
              <div style="display:flex; justify-content:space-between; gap:12px; padding-bottom:10px; border-bottom:1px solid #eee;">
                <span style="font-size:14px; color:#4a4a4a;">{h.day}</span>
                <span style="font-size:14px; color:#E86000; font-weight:700;">{h.hours}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: enquiry form -->
      <div>
        <h2 style="font-family:var(--font-heading); font-size:clamp(1.4rem,2.5vw,1.8rem); font-weight:800; color:#0E151B; margin:0 0 32px; line-height:1.2;">Send an Enquiry</h2>
        <form style="display:flex; flex-direction:column; gap:16px;" action="#" method="POST">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">First Name</label>
              <input type="text" name="first_name" placeholder="First name" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">Last Name</label>
              <input type="text" name="last_name" placeholder="Last name" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
          </div>
          <div>
            <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">Phone</label>
            <input type="tel" name="phone" placeholder="04xx xxx xxx" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
          </div>
          <div>
            <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">Email</label>
            <input type="email" name="email" placeholder="your@email.com" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
          </div>
          <div>
            <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">Message</label>
            <textarea name="message" rows="5" placeholder="How can we help?" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa; resize:vertical;"></textarea>
          </div>
          <button type="submit" style="background:#E86000; color:#fff; border:none; padding:16px; border-radius:6px; font-family:var(--font-heading); font-size:16px; font-weight:700; cursor:pointer;">Send Message &rarr;</button>
          <p style="font-size:12px; color:#6d6d6d; margin:0; text-align:center;">We respond within 2 hours during business hours.</p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- EMERGENCY CTA STRIP -->
<section style="background:#012D5E; padding:48px 20px; position:relative; overflow:hidden;">
  <div style="position:absolute; inset:0; opacity:0.04; background-image:repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px);"></div>
  <div style="position:relative; z-index:1; max-width:1260px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:32px;">
    <div style="display:flex; align-items:center; gap:24px;">
      <div style="width:60px; height:60px; border-radius:50%; background:rgba(232,96,0,0.15); border:1.5px solid rgba(232,96,0,0.4); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg width="28" height="28" fill="#E86000" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <div>
        <p style="font-family:var(--font-heading); font-size:11px; font-weight:700; color:#E86000; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 6px;">24/7 Emergency Plumbing</p>
        <p style="font-family:var(--font-heading); font-size:clamp(1.3rem,2.5vw,1.8rem); font-weight:800; color:#fff; margin:0 0 6px; line-height:1.2;">Plumbing emergency? We're on our way.</p>
        <p style="font-size:14px; color:rgba(255,255,255,0.65); margin:0;">No call-out fees &nbsp;&middot;&nbsp; Fixed upfront pricing &nbsp;&middot;&nbsp; Lic. #333997</p>
      </div>
    </div>
    <div style="display:flex; flex-direction:column; gap:10px; align-items:flex-end;">
      <a href="tel:1300872343" style="display:inline-flex; align-items:center; gap:10px; background:#E86000; color:#fff; text-decoration:none; padding:15px 36px; border-radius:5px; font-family:var(--font-heading); font-size:1.2rem; font-weight:800; white-space:nowrap;">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        1300 872 343
      </a>
      <p style="font-size:12px; color:rgba(255,255,255,0.45); margin:0; text-align:right;">Available 24 hours, 7 days a week</p>
    </div>
  </div>
</section>

<Ratings />
<BrandPartners />
<Footer />

</Layout>

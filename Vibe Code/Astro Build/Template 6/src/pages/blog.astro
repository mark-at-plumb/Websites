---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BookingForm from '../components/BookingForm.astro';
import BrandPartners from '../components/BrandPartners.astro';
import ServiceTiles from '../components/ServiceTiles.astro';
import Ratings from '../components/Ratings.astro';

const posts = [
  { title:'7 Reasons Why You Should Switch to a Heat Pump Hot Water System', date:'15 July 2024', category:'Hot Water', excerpt:'Heat pump systems use the ambient air to heat water, using up to 70% less energy than a conventional electric heater. Here\'s why Adelaide homeowners are making the switch.', img:'/images/hello-plumbing-hot-water-system-electrician.webp' },
  { title:'How to Know If You Have a Hidden Water Leak in Your Home',          date:'8 July 2024',  category:'Leak Detection', excerpt:'Hidden leaks can cause thousands in damage before they\'re noticed. Learn the warning signs — from rising water bills to damp patches — and when to call a leak detection specialist.', img:'/images/Plumbing-Leak-Detection-Service.webp' },
  { title:'Choosing the Right Drain Cleaning Service for Your Adelaide Home',  date:'1 July 2024',  category:'Blocked Drains', excerpt:'Not all blocked drain services are equal. We explain the difference between a cable snake, CCTV inspection, and high-pressure hydrojetting — and which method suits your situation.', img:'/images/blocked-drain-plumber-baulkham-hills.webp' },
  { title:'Gas Fitting Safety: What Every Adelaide Homeowner Should Know',     date:'24 June 2024', category:'Gas Fitting',    excerpt:'Gas leaks are dangerous and often odourless without the added odorant. We cover the safety checks, signs of a gas leak, and why only a licensed gas fitter should touch your appliances.', img:'/images/Gas-fitter-and-plumber-baulkham-hills.webp' },
  { title:'Commercial Plumbing Basics for Adelaide Businesses',                date:'17 June 2024', category:'Commercial',     excerpt:'Commercial plumbing is a different beast from residential work. From backflow prevention to grease traps and preventative maintenance, here\'s what business owners need to know.', img:'/images/commercial-plumbing.webp' },
  { title:'Emergency Plumbing: What to Do Before the Plumber Arrives',        date:'10 June 2024', category:'Emergency',      excerpt:'A burst pipe at 2am is stressful. Knowing where your main shutoff valve is and what to do in the first five minutes can prevent thousands of dollars in water damage.', img:'/images/Plumbing-Emergency-Near-Me.webp' },
  { title:'The Complete Guide to Hot Water System Maintenance',                date:'3 June 2024',  category:'Hot Water',      excerpt:'A well-maintained hot water system lasts years longer and runs more efficiently. Here is the annual maintenance checklist our plumbers run through on every service call.', img:'/images/hello-plumbing-residential-plumber-and-van.webp' },
];
---

<Layout title="Plumbing Blog | Tips & Advice | Hilton Plumbing Adelaide">

<Nav />

<!-- HERO -->
<section style="background:#0E151B; overflow:hidden;">
  <div class="hero-grid" style="max-width:1260px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; min-height:400px;">
    <div style="display:flex; flex-direction:column; justify-content:center; padding:80px 40px 80px 20px;">
      <p style="color:#E86000; font-family:var(--font-heading); font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; margin:0 0 16px;">Plumbing Tips &amp; Advice</p>
      <h1 style="font-family:var(--font-heading); font-size:clamp(2rem,4vw,3.2rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 16px;">The Hilton Plumbing Blog</h1>
      <p style="font-size:16px; color:rgba(255,255,255,0.75); line-height:1.7; margin:0; max-width:480px;">Practical advice on hot water systems, blocked drains, leak detection, emergency plumbing, and everything in between from Adelaide's trusted plumbers.</p>
    </div>
    <div class="hero-img-col" style="position:relative; overflow:hidden;">
      <img
        src="https://www.hiltonplumbing.com.au/wp-content/uploads/2023/05/img-hero-banner01.png.webp"
        alt="Hilton Plumbing Adelaide"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;"
      />
    </div>
  </div>
</section>

<ServiceTiles />

<!-- BLOG GRID -->
<section style="background:#F3F3F3; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div class="three-col" style="display:grid; grid-template-columns:repeat(3,1fr); gap:28px;">
      {posts.map(p => (
        <article style="background:#fff; border-radius:10px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.07); display:flex; flex-direction:column; transition:transform 0.2s, box-shadow 0.2s;" class="svc-card">
          <div style="position:relative; overflow:hidden;">
            <img src={p.img} alt={p.title} style="width:100%; height:200px; object-fit:cover; display:block;" />
            <div style="position:absolute; top:12px; left:12px; background:#E86000; color:#fff; font-family:var(--font-heading); font-size:11px; font-weight:700; letter-spacing:0.06em; padding:4px 10px; border-radius:3px;">{p.category}</div>
          </div>
          <div style="padding:24px; flex:1; display:flex; flex-direction:column;">
            <div style="font-size:12px; color:#6d6d6d; font-family:var(--font-heading); font-weight:600; margin-bottom:10px;">{p.date}</div>
            <h2 style="font-family:var(--font-heading); font-size:1.05rem; font-weight:800; color:#0E151B; margin:0 0 12px; line-height:1.4;">{p.title}</h2>
            <p style="font-size:14px; color:#4a4a4a; line-height:1.7; margin:0 0 20px; flex:1;">{p.excerpt}</p>
            <a href="#" style="display:inline-flex; align-items:center; gap:6px; color:#E86000; font-family:var(--font-heading); font-weight:700; font-size:13px; text-decoration:none;">
              Read more
              <svg width="13" height="13" fill="none" stroke="#E86000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<Ratings />
<BrandPartners />
<BookingForm />
<Footer />

</Layout>

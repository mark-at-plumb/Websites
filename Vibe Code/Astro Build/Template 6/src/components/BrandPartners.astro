<section style="background:#F3F3F3; padding:52px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div style="display:flex; align-items:center; gap:24px; margin-bottom:36px;">
      <div style="flex:1; height:1px; background:#e0e0e0;"></div>
      <p style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#b9b9b9; letter-spacing:0.14em; text-transform:uppercase; white-space:nowrap; margin:0;">Trusted Brands We Supply &amp; Install</p>
      <div style="flex:1; height:1px; background:#e0e0e0;"></div>
    </div>
    <div class="marquee-wrap">
      <div class="marquee-track">
        {[
          { name: 'Bosch',     detail: 'Water Heaters' },
          { name: 'Rinnai',    detail: 'Hot Water' },
          { name: 'Rheem',     detail: 'Hot Water' },
          { name: 'Dux',       detail: 'Hot Water' },
          { name: 'iStore',    detail: 'Heat Pumps' },
          { name: 'Tradelink', detail: 'Plumbing Supplies' },
          { name: 'Bosch',     detail: 'Water Heaters' },
          { name: 'Rinnai',    detail: 'Hot Water' },
          { name: 'Rheem',     detail: 'Hot Water' },
          { name: 'Dux',       detail: 'Hot Water' },
          { name: 'iStore',    detail: 'Heat Pumps' },
          { name: 'Tradelink', detail: 'Plumbing Supplies' },
        ].map(b => (
          <div style="flex-shrink:0; background:#fff; border:1px solid #e8e8e8; border-radius:8px; padding:18px 32px; margin-right:12px; text-align:center; min-width:160px;">
            <div style="font-family:var(--font-heading); font-size:17px; font-weight:800; color:#0E151B; margin-bottom:3px;">{b.name}</div>
            <div style="font-size:11px; color:#6d6d6d; font-weight:500; letter-spacing:0.04em;">{b.detail}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

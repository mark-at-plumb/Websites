<footer style="background:#0E151B; padding:60px 20px 0;">
  <div style="max-width:1260px; margin:0 auto;">
    <div class="footer-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:40px; padding-bottom:48px; border-bottom:1px solid rgba(255,255,255,0.1);">

      <div>
        <img src="/images/Hilton_plumbing_logo.svg" alt="Hilton Plumbing Adelaide" style="height:38px; width:auto; margin-bottom:20px; filter:brightness(0) invert(1);" />
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
          <li style="display:flex; gap:10px; align-items:flex-start;">
            <svg width="14" height="14" fill="#E86000" viewBox="0 0 24 24" style="flex-shrink:0; margin-top:2px;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            <span style="font-size:14px; color:rgba(255,255,255,0.6); line-height:1.5;">38 Sphinx Way, Bibra Lake 6163</span>
          </li>
          <li>
            <a href="tel:1300872343" style="display:flex; gap:10px; align-items:center; text-decoration:none; color:rgba(255,255,255,0.6); font-size:14px;">
              <svg width="14" height="14" fill="#E86000" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
              1300 872 343
            </a>
          </li>
          <li>
            <a href="mailto:enquiries@hiltonplumbing.com.au" style="display:flex; gap:10px; align-items:center; text-decoration:none; color:rgba(255,255,255,0.6); font-size:13px; word-break:break-all;">
              <svg width="14" height="14" fill="#E86000" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              enquiries@hiltonplumbing.com.au
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#fff; margin:0 0 18px; letter-spacing:0.08em; text-transform:uppercase;">Services</h4>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:9px;">
          {['Burst Pipes', 'Blocked Drains', 'Leak Detection', 'Hot Water Systems', 'Gas Fitting', 'Emergency Plumbing'].map(s => (
            <li><a href="/services/" style="font-size:14px; color:rgba(255,255,255,0.55); text-decoration:none;">{s}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#fff; margin:0 0 18px; letter-spacing:0.08em; text-transform:uppercase;">Quick Links</h4>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:9px;">
          {[['About Us', '/about/'], ['Blog', '/blog/'], ['Contact', '/contact/'], ['Privacy Policy', '#'], ['Terms & Conditions', '#']].map(([l, h]) => (
            <li><a href={h} style="font-size:14px; color:rgba(255,255,255,0.55); text-decoration:none;">{l}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 style="font-family:var(--font-heading); font-size:12px; font-weight:700; color:#fff; margin:0 0 18px; letter-spacing:0.08em; text-transform:uppercase;">Office Hours</h4>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:9px;">
          {[
            { day: 'Monday – Friday', hours: '7am – 5pm' },
            { day: 'Saturday',        hours: '8am – 12pm' },
            { day: 'Sunday',          hours: 'Closed' },
            { day: 'Emergency',       hours: '24/7' },
          ].map(h => (
            <li style="display:flex; justify-content:space-between; gap:10px;">
              <span style="font-size:13px; color:rgba(255,255,255,0.55);">{h.day}</span>
              <span style="font-size:13px; color:#E86000; font-weight:600; white-space:nowrap;">{h.hours}</span>
            </li>
          ))}
        </ul>
        <div style="display:flex; gap:10px; margin-top:22px;">
          <a href="#" aria-label="Facebook" style="display:flex; align-items:center; justify-content:center; width:32px; height:32px; border:1px solid rgba(255,255,255,0.15); border-radius:5px;">
            <svg width="14" height="14" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" style="display:flex; align-items:center; justify-content:center; width:32px; height:32px; border:1px solid rgba(255,255,255,0.15); border-radius:5px;">
            <svg width="14" height="14" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="rgba(255,255,255,0.6)" stroke="none"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" style="display:flex; align-items:center; justify-content:center; width:32px; height:32px; border:1px solid rgba(255,255,255,0.15); border-radius:5px;">
            <svg width="14" height="14" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

    </div>

    <div style="padding:20px 0; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
      <p style="font-size:13px; color:rgba(255,255,255,0.35); margin:0;">
        &copy; {new Date().getFullYear()} Hilton Plumbing Adelaide. All rights reserved. Lic. #333997. ABN 52 668 135 886.
      </p>
      <p style="font-size:12px; color:rgba(255,255,255,0.25); margin:0;">PL9300 &nbsp;&middot;&nbsp; VIC 129883 &nbsp;&middot;&nbsp; GL13608</p>
    </div>

  </div>
</footer>

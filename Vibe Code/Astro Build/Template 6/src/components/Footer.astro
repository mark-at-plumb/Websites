---
const serviceLinks = ['Burst Pipes', 'Blocked Drains', 'Hot Water Systems', 'Leak Detection', 'Gas Fitting'];
const quickLinks = ['Service Areas', 'Privacy Policy', 'Terms of Use', 'Lifetime Labour Warranty', 'Financing', 'Contact'];
---

<footer class="bg-brand-secondary text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <img src="/images/logo.svg" alt="Plumber [Suburb]" class="h-10 w-auto mb-4 bg-white rounded-xl px-2 py-1" />
        <p class="text-sm text-white/70 leading-relaxed">
          Plumber [Suburb] is a local, family-owned plumbing business serving [Suburb] and the
          surrounding suburbs. Lifetime Labour Warranty. Fixed Upfront Pricing. 24/7 emergency response.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-brand-accent mb-4">Services</h3>
        <ul class="space-y-2 text-sm text-white/70">
          {serviceLinks.map((s) => <li><a href="#services" class="hover:text-white transition-colors">{s}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-brand-accent mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm text-white/70">
          {quickLinks.map((q) => <li><a href="#" class="hover:text-white transition-colors">{q}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-brand-accent mb-4">Office Hours</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>Monday – Friday: 7am – 5pm</li>
          <li>Saturday: 8am – 12pm</li>
          <li>Sunday: Closed</li>
          <li class="pt-2 font-semibold text-white">24/7 emergency callouts</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between text-xs text-white/50">
      <p>&copy; {new Date().getFullYear()} Plumber [Suburb]. All rights reserved.</p>
      <p>Lic. #333997. ABN 52 668 135 886. One licensed Adelaide plumbing operation, servicing [Suburb] locally.</p>
    </div>
  </div>
</footer>

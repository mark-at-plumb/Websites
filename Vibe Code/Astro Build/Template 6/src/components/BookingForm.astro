<section style="background:#012D5E; padding:64px 20px;">
  <div style="max-width:1260px; margin:0 auto;">
    <div class="book-inner" style="display:grid; grid-template-columns:1fr 2fr; gap:48px; align-items:start;">

      <div>
        <p style="color:#E86000; font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 12px;">Get in Touch</p>
        <h2 style="font-family:var(--font-heading); font-size:clamp(1.5rem,2.5vw,2rem); font-weight:800; color:#fff; margin:0 0 20px; line-height:1.2;">Book a plumber now</h2>
        <p style="font-size:15px; color:rgba(255,255,255,0.65); line-height:1.75; margin:0 0 32px;">Fill in the form and we'll be in touch shortly to confirm your booking. Fixed price, no surprises.</p>
        <div style="display:flex; flex-direction:column; gap:16px;">
          {[
            'Fixed upfront pricing',
            'No call-out fees',
            'Lifetime Labour Warranty',
            '24/7 emergency response',
            'Lic. #333997 — Master Plumber SA',
          ].map(p => (
            <div style="display:flex; align-items:center; gap:12px;">
              <div style="width:22px; height:22px; border-radius:50%; background:#E86000; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <span style="color:#fff; font-size:12px; font-weight:700;">✓</span>
              </div>
              <span style="font-size:15px; color:rgba(255,255,255,0.8); font-family:var(--font-heading); font-weight:500;">{p}</span>
            </div>
          ))}
        </div>
        <div style="margin-top:36px; padding-top:28px; border-top:1px solid rgba(255,255,255,0.12);">
          <p style="font-size:13px; color:rgba(255,255,255,0.45); margin:0 0 4px;">Or call us directly</p>
          <a href="tel:1300872343" style="display:flex; align-items:center; gap:8px; color:#fff; text-decoration:none; font-family:var(--font-heading); font-size:1.5rem; font-weight:800;">
            <svg width="18" height="18" fill="#E86000" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            1300 872 343
          </a>
        </div>
      </div>

      <div>
        <form style="background:#fff; border-radius:12px; padding:40px;" action="#" method="POST">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">First Name</label>
              <input type="text" name="first_name" placeholder="First name" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Last Name</label>
              <input type="text" name="last_name" placeholder="Last name" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Email</label>
              <input type="email" name="email" placeholder="your@email.com" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Phone</label>
              <input type="tel" name="phone" placeholder="04xx xxx xxx" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
            </div>
          </div>
          <div style="margin-bottom:16px;">
            <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Address</label>
            <input type="text" name="address" placeholder="Your address" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;" />
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Job Type</label>
              <select name="job_type" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;">
                <option value="">Select job type</option>
                <option>Blocked Drains</option>
                <option>General Plumbing</option>
                <option>Hot Water System Install / Repair</option>
                <option>Leak Detection / Burst Pipes</option>
                <option>Water Filtration</option>
                <option>Gas Detection / Repairs</option>
                <option>Emergency Plumbing</option>
              </select>
            </div>
            <div>
              <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Preferred Time</label>
              <select name="preferred_time" class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa;">
                <option>Any Time</option>
                <option>8:00 am</option>
                <option>10:00 am</option>
                <option>12:00 pm</option>
                <option>2:00 pm</option>
              </select>
            </div>
          </div>
          <div style="margin-bottom:24px;">
            <label style="display:block; font-family:var(--font-heading); font-size:12px; font-weight:700; color:#0E151B; margin-bottom:6px; letter-spacing:0.04em; text-transform:uppercase;">Notes</label>
            <textarea name="notes" rows="4" placeholder="Describe your plumbing issue..." class="form-field" style="width:100%; padding:12px 14px; border:1.5px solid #e8e8e8; border-radius:6px; font-size:15px; background:#fafafa; resize:vertical;"></textarea>
          </div>
          <button type="submit" style="width:100%; background:#E86000; color:#fff; border:none; padding:16px; border-radius:6px; font-family:var(--font-heading); font-size:16px; font-weight:700; cursor:pointer;">Send Enquiry &rarr;</button>
          <p style="text-align:center; font-size:12px; color:#6d6d6d; margin:12px 0 0;">We respond within 2 hours during business hours.</p>
        </form>
      </div>

    </div>
  </div>
</section>

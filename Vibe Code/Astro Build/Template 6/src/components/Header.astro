---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Hot Water', href: '#services' },
  { label: 'Blocked Drains', href: '#services' },
  { label: 'Emergency', href: '#emergency' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-brand-surface">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/images/logo.svg" alt="Plumber [Suburb]" class="h-10 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Primary">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-semibold text-brand-secondary hover:text-brand-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="tel:1300000000"
          class="hidden sm:flex flex-col items-end leading-tight"
        >
          <span class="text-[11px] font-semibold uppercase tracking-wide text-brand-accent">24/7 Emergency Line</span>
          <span class="text-lg font-bold text-brand-primary">1300 000 000</span>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-full bg-brand-accent px-5 py-2.5 text-sm font-bold text-white hover:opacity-90 transition-opacity"
        >
          Book Now
        </a>
      </div>
    </div>
  </div>
</header>

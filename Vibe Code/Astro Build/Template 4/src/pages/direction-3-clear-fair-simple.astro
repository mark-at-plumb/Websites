  <script>
    // Scroll reveal
    const els = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));

    // Count-up, fires once when stats become visible
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const statsWrap = document.getElementById('d3-stats');
    if (statsWrap) {
      const counts = statsWrap.querySelectorAll('.d3-count');
      const run = () => {
        counts.forEach((el) => {
          const target = Number(el.dataset.target || '0');
          const prefix = el.dataset.prefix || '';
          const suffix = el.dataset.suffix || '';
          const raw = el.dataset.raw || '';
          if (raw) { el.textContent = raw; return; }
          if (reduce) { el.textContent = prefix + target + suffix; return; }
          const dur = 1400; const start = performance.now();
          const tick = (now) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = prefix + Math.round(target * eased) + suffix;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      };
      const sio = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { run(); sio.disconnect(); }
        }
      }, { threshold: 0.4 });
      sio.observe(statsWrap);
    }
  </script>

---
import Layout from '../layouts/Layout.astro';

const directions = [
  {
    n: 1,
    name: 'Trusted Local Authority',
    slug: 'direction-1-trusted-local-authority',
    description: "Faithful to Aptec's original section rhythm. Blue/navy/orange, Plus Jakarta Sans + Inter, gentle scroll-fade and hover-lift.",
  },
  {
    n: 2,
    name: 'Happy Valley, Right Now',
    slug: 'direction-2-happy-valley-right-now',
    description: 'Bold and urgent — full-bleed hero, pulsing availability badge, count-up stats, suburb marquee. Teal/charcoal/amber, Space Grotesk + Inter.',
  },
  {
    n: 3,
    name: 'Clear, Fair, Simple',
    slug: 'direction-3-clear-fair-simple',
    description: "Premium-calm, built around the brand's own tagline. Typographic hero, quiet scroll-reveal. Steel-blue/charcoal/terracotta, Fraunces + Inter.",
  },
];
---
<Layout title="Plumber Happy Valley — Homepage Concepts">
  <main style="max-width: 680px; margin: 0 auto; padding: 4rem 1.5rem; font-family: var(--font-body);">
    <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; font-family: var(--font-heading); color: #1b3c5c;">Your Homepage Concepts</h1>
    <p style="color: #666; margin-bottom: 3rem;">All three share the same Plumber Happy Valley content (brand-voice-guide.md compliant) and the same Aptec-derived section layout. Only the visual treatment differs. Click each to preview, then scroll through fully before deciding.</p>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {directions.map(d => (
        <a href={`/${d.slug}`} style="display: block; padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.15s;">
          <div style="font-size: 0.75rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">Direction {d.n}</div>
          <div style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; font-family: var(--font-heading); color: #1b3c5c;">{d.name}</div>
          <div style="color: #555; font-size: 0.9rem; line-height: 1.5;">{d.description}</div>
        </a>
      ))}
    </div>
  </main>
</Layout>

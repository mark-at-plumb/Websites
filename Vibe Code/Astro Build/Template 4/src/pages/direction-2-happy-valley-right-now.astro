    .d2-foot-link:hover { color: #fff; }
    .d2-footer__sign {
      border-top: 1px solid rgba(255,255,255,.1); padding-top: 1.5rem;
      display: flex; flex-direction: column; gap: .6rem; font-size: .78rem; color: rgba(255,255,255,.55);
    }
    @media (min-width: 640px) { .d2-footer__sign { flex-direction: row; align-items: center; justify-content: space-between; } }

    /* hero stagger entrance */
    .d2-hero__line { opacity: 0; transform: translateY(20px); animation: d2-hero-in .8s cubic-bezier(.22,1,.36,1) forwards; }
    .d2-hero__copy .d2-hero__line:nth-child(1) { animation-delay: .05s; }
    .d2-hero__copy .d2-hero__line:nth-child(2) { animation-delay: .15s; }
    .d2-hero__copy .d2-hero__line:nth-child(3) { animation-delay: .25s; }
    .d2-hero__copy .d2-hero__line:nth-child(4) { animation-delay: .35s; }
    .d2-hero__media.d2-hero__line { animation-delay: .3s; }
    @keyframes d2-hero-in { to { opacity: 1; transform: none; } }
    @media (prefers-reduced-motion: reduce) { .d2-hero__line { opacity: 1 !important; transform: none !important; animation: none !important; } }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
    :focus-visible { outline: 3px solid var(--color-brand-accent); outline-offset: 2px; border-radius: 4px; }
  </style>

  <script>
    // Scroll reveal (single + staggered groups)
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal, .stagger').forEach((el) => io.observe(el));

    // rAF eased count-up — fires when the stat band scrolls into view
    const easeOut = (t) => 1 - Math.pow(1 - t, 3);
    function runCount(el) {
      const target = parseFloat(el.dataset.count || '0');
      const decimals = parseInt(el.dataset.decimals || '0', 10);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const dur = 1500;
      const start = performance.now();
      function frame(now) {
        const p = Math.min((now - start) / dur, 1);
        const val = target * easeOut(p);
        el.textContent = prefix + val.toFixed(decimals) + suffix;
        if (p < 1) requestAnimationFrame(frame);
        else el.textContent = prefix + target.toFixed(decimals) + suffix;
      }
      requestAnimationFrame(frame);
    }
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const statBand = document.getElementById('d2-stats');
    if (statBand) {
      const nums = statBand.querySelectorAll('.d2-stat__num');
      if (reduce) {
        nums.forEach((n) => { n.textContent = (n.dataset.prefix || '') + parseFloat(n.dataset.count || '0').toFixed(parseInt(n.dataset.decimals || '0', 10)) + (n.dataset.suffix || ''); });
      } else {
        const so = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { nums.forEach(runCount); so.disconnect(); }
          }
        }, { threshold: 0.4 });
        so.observe(statBand);
      }
    }
  </script>
</Layout>

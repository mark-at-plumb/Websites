---
import Eyebrow from './Eyebrow.astro';
---
<section id="contact" class="relative overflow-hidden bg-brand-primary py-28 text-brand-bg sm:py-36">
  <img src="/images/ab-electrical-fleet-sydney.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-20" loading="lazy" />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-primary via-brand-primary/90 to-brand-primary/60"></div>

  <div class="relative mx-auto max-w-[1100px] px-5 text-center sm:px-8">
    <div data-reveal class="flex justify-center">
      <Eyebrow label="Sydney · North Shore" align="center" tone="light" />
    </div>
    <h2 data-reveal class="mx-auto mt-7 max-w-3xl font-heading" style="font-variation-settings:'opsz' 144; font-size:clamp(2.4rem,5.5vw,4rem); line-height:1.05; letter-spacing:-0.02em;">
      Need an electrician <span class="italic font-light text-brand-accent">now</span>?
    </h2>
    <p data-reveal class="mx-auto mt-6 max-w-lg font-body text-[1.08rem] leading-[1.7] text-brand-bg/80">
      On-time service, upfront pricing, and a Lifetime Workmanship Warranty on every job. Book online or call the team direct.
    </p>
    <div data-reveal class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-brand-secondary px-8 py-4 font-body text-[0.98rem] font-semibold text-brand-bg shadow-[0_14px_36px_-14px_rgba(196,95,26,0.7)] transition-all duration-300 hover:bg-brand-accent hover:text-brand-primary">
        Book Now
      </a>
      <a href="tel:+61280000000" class="inline-flex items-center gap-2 rounded-full border border-brand-bg/30 px-8 py-4 font-body text-[0.98rem] font-semibold text-brand-bg transition-all duration-300 hover:border-brand-accent hover:text-brand-accent">
        Call (02) 8000 0000
      </a>
    </div>
    <div data-reveal class="mx-auto mt-10 flex w-fit items-center gap-4">
      <span class="h-px w-12 bg-brand-accent/50"></span>
      <p class="font-body text-[0.78rem] tracking-wide text-brand-bg/60">Highest reviewed electrician in Sydney</p>
      <span class="h-px w-12 bg-brand-accent/50"></span>
    </div>
  </div>
</section>

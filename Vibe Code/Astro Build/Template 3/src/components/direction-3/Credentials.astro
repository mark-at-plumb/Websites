---
import Eyebrow from './Eyebrow.astro';

const certs = [
  'NSW Fair Trading Licensed',
  'Master Electricians Australia Member',
  'Level 2 ASP Certified',
  'Registered Electrical Contractor',
  'Fully Insured',
];
---
<section id="credentials" class="relative overflow-hidden bg-brand-accent py-24 text-brand-primary sm:py-28">
  <div class="mx-auto grid max-w-[1100px] grid-cols-1 items-center gap-14 px-5 sm:px-8 lg:grid-cols-[40fr_60fr]">
    <div data-reveal>
      <Eyebrow num="06" label="Credentials" />
      <h2 class="mt-6 font-heading" style="font-variation-settings:'opsz' 96; font-size:clamp(2rem,4vw,2.8rem); line-height:1.1; letter-spacing:-0.02em;">
        Licensed, certified, <span class="italic font-light text-brand-primary/80">accountable</span>.
      </h2>
      <p class="mt-5 max-w-sm font-body text-[1rem] leading-[1.7] text-brand-primary/75">
        Every credential current, every job compliant. Proof that the work behind your walls is done to NSW standard.
      </p>
    </div>

    <ul class="flex flex-col" data-reveal>
      {certs.map((c, i) => (
        <li class="flex items-center gap-4 border-t border-brand-primary/15 py-5" style={`transition-delay:${i * 60}ms`}>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-brand-primary"></span>
          <span class="font-heading text-[1.15rem] font-medium" style="font-variation-settings:'opsz' 32;">{c}</span>
        </li>
      ))}
      <li class="border-t border-brand-primary/15"></li>
    </ul>
  </div>
</section>

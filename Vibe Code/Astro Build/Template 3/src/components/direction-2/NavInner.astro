---
import Bolt from './Bolt.astro';

const links = [
  { label: 'Home', href: '/direction-2-north-shore-bold' },
  { label: 'Services', href: '/d2-electrical-services' },
  { label: 'Residential', href: '/d2-residential-electrician' },
  { label: 'Locations', href: '/d2-electrician-eastern-suburbs' },
  { label: 'About', href: '/d2-about-us' },
  { label: 'Contact', href: '/d2-contact-us' },
];
---
<header id="nsb-nav" class="fixed inset-x-0 top-0 z-50 bg-brand-bg/90 shadow-lg shadow-black/40 backdrop-blur-md transition-all duration-300">
  <span class="absolute inset-x-0 bottom-0 h-0.5 bg-gradient-to-r from-brand-secondary via-brand-accent to-brand-secondary"></span>
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3.5 sm:px-8" data-navbar>
    <a href="/direction-2-north-shore-bold" class="flex items-center gap-2.5" aria-label="AB Electricians home">
      <span class="grid h-9 w-9 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-secondary);">
        <Bolt class="h-5 w-5" />
      </span>
      <span class="font-heading text-lg font-extrabold leading-none tracking-[-0.02em] text-brand-text">
        AB<span class="text-brand-accent">/</span>Electricians
      </span>
    </a>

    <div class="hidden items-center gap-8 lg:flex">
      {links.map((l) => (
        <a href={l.href} class="group relative font-body text-sm font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text">
          {l.label}
          <span class="absolute -bottom-1.5 left-0 h-[2px] w-0 -skew-x-[30deg] bg-brand-accent transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="tel:+61280000000" class="hidden font-heading text-sm font-bold text-brand-secondary transition-colors hover:text-brand-text sm:inline">(02) 8000 0000</a>
      <a href="/d2-contact-us" class="sweep-btn group relative hidden items-center gap-2 overflow-hidden px-4 py-2 font-heading text-sm font-bold text-brand-bg lg:inline-flex" style="clip-path: polygon(8% 0, 100% 0, 92% 100%, 0 100%); background: var(--color-brand-accent);">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" />
      </a>

      <a href="tel:+61280000000" aria-label="Call (02) 8000 0000" class="inline-flex h-10 items-center gap-2 border border-brand-secondary/40 px-3 font-heading text-sm font-bold text-brand-secondary sm:hidden" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%);">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Now
      </a>

      <button
        id="nsb-nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="nsb-nav-mobile"
        aria-label="Toggle menu"
        class="relative grid h-10 w-10 shrink-0 place-items-center text-brand-text lg:hidden"
      >
        <span class="relative block h-4 w-5" aria-hidden="true">
          <span class="nsb-bar absolute left-0 top-0 h-0.5 w-full bg-current transition-all duration-300"></span>
          <span class="nsb-bar absolute left-0 top-1.5 h-0.5 w-full bg-current transition-all duration-300"></span>
          <span class="nsb-bar absolute left-0 top-3 h-0.5 w-full bg-current transition-all duration-300"></span>
        </span>
      </button>
    </div>
  </nav>

  <div id="nsb-nav-mobile" class="invisible fixed inset-x-0 top-[60px] -z-10 max-h-0 overflow-hidden bg-brand-bg opacity-0 transition-all duration-300 lg:hidden" style="border-top: 1px solid rgba(232,184,75,0.15);">
    <div class="flex flex-col gap-1 px-5 pb-6 pt-4 sm:px-8">
      {links.map((l) => (
        <a href={l.href} class="px-3 py-3 font-body text-base font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text">
          {l.label}
        </a>
      ))}
      <a href="tel:+61280000000" class="mt-2 px-3 py-3 font-heading text-base font-bold text-brand-secondary">
        (02) 8000 0000
      </a>
      <a href="/d2-contact-us" class="sweep-btn group relative mt-3 inline-flex items-center justify-center gap-2 overflow-hidden px-4 py-3 font-heading text-sm font-bold text-brand-bg" style="clip-path: polygon(4% 0, 100% 0, 96% 100%, 0 100%); background: var(--color-brand-accent);">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</header>

<style>
  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: -2px -20%;
    background: var(--color-brand-secondary);
    transform: translateX(-120%) skewX(-20deg);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sweep-btn:hover::before { transform: translateX(0) skewX(-20deg); }

  #nsb-nav-mobile.is-open {
    visibility: visible;
    z-index: 40;
    max-height: calc(100vh - 60px);
    opacity: 1;
    overflow-y: auto;
  }

  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(2) { opacity: 0; }
  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
</style>

<script>
  const toggle = document.getElementById('nsb-nav-toggle');
  const menu = document.getElementById('nsb-nav-mobile');
  if (toggle && menu) {
    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.classList.remove('overflow-hidden');
    };
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      menu.classList.toggle('is-open', !isOpen);
      document.body.classList.toggle('overflow-hidden', !isOpen);
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    window.addEventListener('resize', () => { if (window.innerWidth >= 1024) closeMenu(); });
  }
</script>

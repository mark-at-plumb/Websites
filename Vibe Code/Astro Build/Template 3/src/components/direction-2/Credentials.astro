---
import Bolt from './Bolt.astro';

const creds = [
  'NSW Fair Trading Licensed',
  'Master Electricians Australia Member',
  'Level 2 ASP Certified',
  'Registered Electrical Contractor',
  'Fully Insured',
];
---
<section id="credentials" class="relative overflow-hidden py-20" style="background: linear-gradient(110deg, var(--color-brand-secondary) 0%, var(--color-brand-accent) 100%);">
  <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(-45deg, #000 0 2px, transparent 2px 22px);"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="reveal mb-10 max-w-2xl">
      <p class="mb-3 font-body text-xs font-bold uppercase tracking-[0.3em] text-brand-bg/70">The credentials behind the claim</p>
      <h2 class="font-heading text-[clamp(1.7rem,4vw,2.6rem)] font-black uppercase leading-tight tracking-tight text-brand-bg">
        Licensed, certified &amp; fully insured
      </h2>
    </div>
    <ul class="grid gap-px overflow-hidden border border-brand-bg/20 bg-brand-bg/20 sm:grid-cols-2 lg:grid-cols-5">
      {creds.map((c, i) => (
        <li class="reveal flex items-center gap-3 bg-brand-bg p-5" style={`transition-delay: ${i * 70}ms;`}>
          <span class="grid h-8 w-8 shrink-0 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-accent);">
            <Bolt class="h-4 w-4" />
          </span>
          <span class="font-heading text-sm font-bold uppercase leading-tight tracking-tight text-brand-text">{c}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

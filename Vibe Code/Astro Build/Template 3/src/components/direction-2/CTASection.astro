---
import Bolt from './Bolt.astro';
---
<section id="contact" class="relative overflow-hidden bg-brand-bg py-28">
  <img src="/images/electricians-fleet-by-the-harbour.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-30" />
  <div class="absolute inset-0" style="background: radial-gradient(circle at 30% 50%, rgba(255,107,53,0.35), transparent 55%), linear-gradient(to right, var(--color-brand-bg) 5%, rgba(13,13,26,0.65) 60%);"></div>
  <div class="pointer-events-none absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 50px 50px;"></div>

  <div class="relative mx-auto max-w-4xl px-5 text-center sm:px-8">
    <p class="reveal mb-5 inline-flex items-center gap-2 border border-brand-accent/50 bg-brand-accent/10 px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent pulse-glow">
      <Bolt class="h-3.5 w-3.5" /> 24/7 emergency callouts
    </p>
    <h2 class="reveal font-heading text-[clamp(2.2rem,6vw,4.2rem)] font-black uppercase leading-[0.95] tracking-[-0.01em] text-brand-text" style="transition-delay: 80ms;">
      Need an electrician <span class="text-brand-accent">now?</span>
    </h2>
    <p class="reveal mx-auto mt-5 max-w-xl font-body text-lg leading-relaxed text-brand-muted" style="transition-delay: 160ms;">
      Power out, switchboard tripped, or just need a sparky you can trust? We answer the phone and we turn up. Book online or call now.
    </p>
    <div class="reveal mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row" style="transition-delay: 240ms;">
      <a href="tel:+61280000000" class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden px-8 py-4 font-heading text-base font-bold text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%); background: var(--color-brand-accent);">
        <span class="relative z-10">Call (02) 8000 0000</span>
        <Bolt class="relative z-10 h-4 w-4" />
      </a>
      <a href="#contact" class="inline-flex items-center justify-center gap-2 border border-brand-secondary px-8 py-4 font-heading text-base font-bold text-brand-secondary transition-colors hover:bg-brand-secondary/10" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%);">
        Get a Free Quote
      </a>
    </div>
  </div>
</section>

<style>
  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: -2px -20%;
    background: var(--color-brand-secondary);
    transform: translateX(-120%) skewX(-20deg);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sweep-btn:hover::before { transform: translateX(0) skewX(-20deg); }
  .pulse-glow { animation: pulseGlow 2.6s ease-in-out infinite; }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.4); }
    50% { box-shadow: 0 0 20px 3px rgba(255, 107, 53, 0.5); }
  }
  @media (prefers-reduced-motion: reduce) { .pulse-glow { animation: none; } }
</style>

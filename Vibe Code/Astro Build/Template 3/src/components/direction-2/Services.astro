---
import Bolt from './Bolt.astro';

const services = [
  { title: 'Residential Electrical', desc: 'Switchboards, lighting, power points and rewires for Sydney homes — done tidy, done right.', img: '/images/ab-electrician-arriving-at-job.webp', alt: 'AB electrician arriving at a residential job' },
  { title: 'Commercial Electrical', desc: 'Fit-outs, maintenance and compliance for North Shore businesses.', img: '/images/ab-electrical-van-sydney.webp', alt: 'AB Electrical van in a Sydney commercial street' },
  { title: 'Emergency Electrical', desc: '24/7 callouts. Power loss, faults and hazards handled fast.', img: '/images/electrician-van-at-harbour-bridge.webp', alt: 'AB Electrical van by the Sydney Harbour Bridge at night' },
  { title: 'Level 2 Electrical', desc: 'ASP-certified mains, metering and network connections.', img: '/images/electrician-testing-switchboard.webp', alt: 'Electrician testing a switchboard' },
  { title: 'Data & Communications', desc: 'Data cabling, NBN, networking and comms for home and office.', img: '/images/ab-electrical-communications-van-signage.webp', alt: 'AB Electrical communications van with signage' },
  { title: 'Installations & Maintenance', desc: 'EV chargers, fans, appliances and scheduled servicing.', img: '/images/ab-electrical-electrician-with-trolley.webp', alt: 'AB electrician with a trolley of equipment' },
];
const [feature, ...rest] = services;
---
<section id="services" class="relative bg-brand-bg py-24">
  <div class="pointer-events-none absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="reveal mb-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
          <span class="inline-block h-px w-10 bg-brand-accent"></span>
          Electrical services Sydney
        </p>
        <h2 class="font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text">
          Whatever's gone wrong,<br class="hidden sm:block" /> <span class="text-brand-secondary">we sort it</span>
        </h2>
      </div>
      <a href="#contact" class="font-heading text-sm font-bold uppercase tracking-wide text-brand-accent hover:text-brand-secondary">All services →</a>
    </div>

    <div class="grid gap-5 lg:grid-cols-3 lg:grid-rows-2">
      <!-- feature card spans 2 rows -->
      <a href="#contact" class="svc reveal group relative block overflow-hidden border border-white/5 bg-brand-surface lg:col-span-2 lg:row-span-2" style="clip-path: polygon(0 0, 100% 0, 100% 95%, 97% 100%, 0 100%);">
        <span class="svc-top absolute inset-x-0 top-0 z-20 h-1 origin-left scale-x-0 bg-brand-accent transition-transform duration-300"></span>
        <div class="relative h-72 overflow-hidden lg:h-[60%]">
          <img src={feature.img} alt={feature.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-surface to-transparent"></div>
        </div>
        <div class="relative p-7">
          <span class="mb-3 inline-flex items-center gap-2 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent"><Bolt class="h-3.5 w-3.5" /> Most booked</span>
          <h3 class="font-heading text-2xl font-black uppercase leading-tight tracking-tight text-brand-secondary">{feature.title}</h3>
          <p class="mt-3 max-w-md font-body text-base leading-relaxed text-brand-muted">{feature.desc}</p>
        </div>
      </a>

      {rest.map((s, i) => (
        <a href="#contact" class="svc reveal group relative flex flex-col overflow-hidden border border-white/5 bg-brand-surface" style={`transition-delay: ${i * 80}ms; clip-path: polygon(0 0, 100% 0, 100% 90%, 94% 100%, 0 100%);`}>
          <span class="svc-top absolute inset-x-0 top-0 z-20 h-1 origin-left scale-x-0 bg-brand-accent transition-transform duration-300"></span>
          <div class="relative h-32 overflow-hidden">
            <img src={s.img} alt={s.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-surface/90 to-transparent"></div>
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h3 class="font-heading text-lg font-black uppercase leading-tight tracking-tight text-brand-secondary">{s.title}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{s.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .svc:hover .svc-top { transform: scaleX(1); }
</style>

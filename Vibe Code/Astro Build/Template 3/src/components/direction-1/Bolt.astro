---
// The recurring "circuit bolt" motif — a lightning bolt drawn as a circuit
// trace with node dots. Reused across nav, hero, dividers, cards and footer.
interface Props {
  class?: string;
  stroke?: string;
}
const { class: className = '', stroke = 'currentColor' } = Astro.props;
---
<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  stroke={stroke}
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d="M18 3 L8 17 H15 L13 29 L24 13 H17 Z" fill={stroke} fill-opacity="0.12" />
  <circle cx="18" cy="3" r="1.6" fill={stroke} stroke="none" />
  <circle cx="13" cy="29" r="1.6" fill={stroke} stroke="none" />
</svg>

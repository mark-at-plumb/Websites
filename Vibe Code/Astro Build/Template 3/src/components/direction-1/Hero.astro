---
import Bolt from './Bolt.astro';

const words = ['Highest', 'Reviewed', 'Electrician', 'in', 'Sydney'];
---
<section id="top" class="relative isolate overflow-hidden bg-brand-primary">
  <!-- Full-bleed background -->
  <img
    src="/images/electricians-fleet-by-the-harbour.webp"
    alt="AB Electricians fleet of vans parked by Sydney Harbour"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-primary via-brand-primary/90 to-brand-primary/40"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-primary via-transparent to-brand-primary/30"></div>

  <!-- Circuit motif backdrop -->
  <svg class="absolute right-0 top-0 -z-10 h-full w-1/2 opacity-[0.15]" viewBox="0 0 400 600" fill="none" aria-hidden="true">
    <path d="M40 0 V120 H160 V260 H300 V400 H180 V600" stroke="#00d082" stroke-width="2" />
    <path d="M380 40 V200 H260 V340" stroke="#007cba" stroke-width="2" />
    <circle cx="160" cy="120" r="5" fill="#00d082" />
    <circle cx="300" cy="260" r="5" fill="#00d082" />
    <circle cx="260" cy="200" r="5" fill="#007cba" />
    <circle cx="180" cy="400" r="5" fill="#00d082" />
  </svg>

  <div class="mx-auto grid max-w-7xl gap-12 px-5 pb-32 pt-36 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:pb-40 lg:pt-44">
    <div>
      <p class="hero-anim mb-5 inline-flex items-center gap-2 rounded-full border border-brand-accent/40 bg-brand-accent/10 px-4 py-1.5 font-body text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent" style="--d:0ms">
        <Bolt class="h-3.5 w-3.5" stroke="currentColor" />
        North Shore & Greater Sydney
      </p>

      <h1 class="font-heading text-[clamp(2.6rem,6.5vw,5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-white">
        {words.map((w, i) => (
          <span class="hero-word inline-block" style={`--d:${120 + i * 90}ms`}>{w}&nbsp;</span>
        ))}
      </h1>

      <p class="hero-anim mt-6 max-w-xl font-body text-lg leading-relaxed text-slate-300" style="--d:700ms">
        Sydney based licensed electricians. On-time service. Upfront pricing. Quality guaranteed.
      </p>

      <div class="hero-anim mt-8 flex flex-wrap gap-3" style="--d:820ms">
        <a href="#contact" class="sweep-btn group relative inline-flex items-center gap-2 overflow-hidden rounded-md bg-brand-accent px-7 py-3.5 font-heading text-base font-bold text-brand-primary">
          <span class="relative z-10">Book Now</span>
          <Bolt class="relative z-10 h-4 w-4" stroke="currentColor" />
        </a>
        <a href="tel:+61280000000" class="group inline-flex items-center gap-2 rounded-md border border-white/25 px-7 py-3.5 font-heading text-base font-bold text-white transition-colors hover:border-brand-accent hover:text-brand-accent">
          Call Now
        </a>
      </div>

      <div class="hero-anim mt-10 flex items-center gap-6 border-t border-white/10 pt-6" style="--d:940ms">
        <div>
          <div class="font-heading text-3xl font-extrabold text-white"><span data-count="500" data-suffix="+">0</span></div>
          <div class="font-body text-xs uppercase tracking-[0.14em] text-slate-400">Five-star reviews</div>
        </div>
        <span class="h-10 w-px bg-white/15"></span>
        <div>
          <div class="font-heading text-3xl font-extrabold text-white"><span data-count="10" data-suffix=" yrs">0</span></div>
          <div class="font-body text-xs uppercase tracking-[0.14em] text-slate-400">On the tools</div>
        </div>
        <span class="h-10 w-px bg-white/15"></span>
        <div>
          <div class="font-heading text-3xl font-extrabold text-brand-accent">∞</div>
          <div class="font-body text-xs uppercase tracking-[0.14em] text-slate-400">Workmanship warranty</div>
        </div>
      </div>
    </div>

    <!-- Floating card / secondary image -->
    <div class="hero-anim relative hidden lg:block" style="--d:600ms">
      <div class="overflow-hidden rounded-2xl border border-white/10 shadow-2xl shadow-black/40">
        <img src="/images/ab-electricians-north-sydney-skyline.webp" alt="AB Electricians van against the North Sydney skyline" class="h-[420px] w-full object-cover" loading="eager" />
      </div>
      <div class="absolute -bottom-6 -left-6 max-w-[15rem] rounded-xl border border-brand-accent/30 bg-white/95 p-5 shadow-xl backdrop-blur">
        <div class="flex items-center gap-1 text-brand-accent" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => (
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9z"/></svg>
          ))}
        </div>
        <p class="mt-2 font-heading text-sm font-bold leading-tight text-brand-primary">Highest reviewed electrician in Sydney</p>
        <p class="mt-1 font-body text-xs text-brand-muted">Verified across hundreds of local jobs.</p>
      </div>
    </div>
  </div>

  <!-- Angled cut into the founder section -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0">
    <svg class="block h-[60px] w-full sm:h-[90px]" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
      <polygon points="0,90 1440,30 1440,90" fill="#f8fafc" />
    </svg>
  </div>
</section>

<style>
  .hero-anim, .hero-word {
    opacity: 0;
    transform: translateY(18px);
    animation: heroIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-anim, .hero-word { animation: none; opacity: 1; transform: none; }
  }
</style>

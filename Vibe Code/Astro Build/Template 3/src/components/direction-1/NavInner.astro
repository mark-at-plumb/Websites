---
import Bolt from './Bolt.astro';

const links = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/electrical-services' },
  { label: 'Residential', href: '/residential-electrician' },
  { label: 'Locations', href: '/electrician-eastern-suburbs' },
  { label: 'About', href: '/about-us' },
  { label: 'Contact', href: '/contact-us' },
];
---
<header id="ab-nav" class="fixed inset-x-0 top-0 z-50 bg-brand-primary/85 backdrop-blur-md shadow-lg shadow-black/20 transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3 transition-all duration-300 sm:px-8" data-navbar>
    <a href="/" class="flex items-center gap-2.5 text-white" aria-label="AB Electricians home">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-brand-accent text-brand-primary">
        <Bolt class="h-5 w-5" stroke="currentColor" />
      </span>
      <span class="font-heading text-lg font-extrabold leading-none tracking-[-0.02em]">
        AB<span class="text-brand-accent">.</span>Electricians
      </span>
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {links.map((l) => (
        <a href={l.href} class="group relative font-body text-sm font-medium text-slate-200 transition-colors hover:text-white">
          {l.label}
          <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-brand-accent transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="tel:+61280000000" class="hidden text-sm font-semibold text-slate-200 transition-colors hover:text-white sm:inline">(02) 8000 0000</a>
      <span class="hidden h-5 w-px bg-white/20 sm:block" aria-hidden="true"></span>
      <a href="/contact-us" class="sweep-btn group relative hidden items-center gap-2 overflow-hidden rounded-md bg-brand-accent px-4 py-2 font-heading text-sm font-bold text-brand-primary lg:inline-flex">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" stroke="currentColor" />
      </a>

      <a href="tel:+61280000000" aria-label="Call (02) 8000 0000" class="inline-flex h-10 items-center gap-2 rounded-md border border-white/25 px-3 font-heading text-sm font-bold text-white sm:hidden">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Now
      </a>

      <button
        id="ab-nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="ab-nav-mobile"
        aria-label="Toggle menu"
        class="relative grid h-10 w-10 shrink-0 place-items-center rounded-md text-white lg:hidden"
      >
        <span class="relative block h-4 w-5" aria-hidden="true">
          <span class="ab-nav-bar absolute left-0 top-0 h-0.5 w-full bg-white transition-all duration-300"></span>
          <span class="ab-nav-bar absolute left-0 top-1.5 h-0.5 w-full bg-white transition-all duration-300"></span>
          <span class="ab-nav-bar absolute left-0 top-3 h-0.5 w-full bg-white transition-all duration-300"></span>
        </span>
      </button>
    </div>
  </nav>

  <div id="ab-nav-mobile" class="invisible fixed inset-x-0 top-[60px] -z-10 max-h-0 overflow-hidden bg-brand-primary opacity-0 transition-all duration-300 lg:hidden">
    <div class="flex flex-col gap-1 px-5 pb-6 pt-4 sm:px-8">
      {links.map((l) => (
        <a href={l.href} class="rounded-md px-3 py-3 font-body text-base font-medium text-slate-200 transition-colors hover:bg-white/5 hover:text-white">
          {l.label}
        </a>
      ))}
      <a href="tel:+61280000000" class="mt-2 rounded-md px-3 py-3 font-body text-base font-semibold text-slate-200 transition-colors hover:bg-white/5 hover:text-white">
        (02) 8000 0000
      </a>
      <a href="/contact-us" class="sweep-btn group relative mt-3 inline-flex items-center justify-center gap-2 overflow-hidden rounded-md bg-brand-accent px-4 py-3 font-heading text-sm font-bold text-brand-primary">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" stroke="currentColor" />
      </a>
    </div>
  </div>
</header>

<style>
  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #00b06e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }
  .sweep-btn:hover::before { transform: scaleX(1); }

  #ab-nav-mobile.is-open {
    visibility: visible;
    z-index: 40;
    max-height: calc(100vh - 60px);
    opacity: 1;
    overflow-y: auto;
  }

  #ab-nav-toggle[aria-expanded='true'] .ab-nav-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #ab-nav-toggle[aria-expanded='true'] .ab-nav-bar:nth-child(2) {
    opacity: 0;
  }
  #ab-nav-toggle[aria-expanded='true'] .ab-nav-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('ab-nav-toggle');
  const menu = document.getElementById('ab-nav-mobile');

  if (toggle && menu) {
    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.classList.remove('overflow-hidden');
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      menu.classList.toggle('is-open', !isOpen);
      document.body.classList.toggle('overflow-hidden', !isOpen);
    });

    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  }
</script>

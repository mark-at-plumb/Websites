---
const certs = [
  'NSW Fair Trading Licensed',
  'Master Electricians Australia Member',
  'Level 2 ASP Certified',
  'Registered Electrical Contractor',
  'Fully Insured',
];
---
<section id="credentials" class="relative bg-brand-primary py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="reveal-up text-center" data-reveal>
      <p class="font-body text-xs font-semibold uppercase tracking-[0.2em] text-brand-accent">Licensed, certified & insured</p>
      <h2 class="mt-3 font-heading text-[clamp(1.6rem,3vw,2.4rem)] font-extrabold tracking-[-0.02em] text-white">Credentials you can check</h2>
    </div>

    <div class="reveal-up mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-5" data-reveal>
      {certs.map((c) => (
        <div class="flex flex-col items-center gap-3 rounded-xl border border-white/10 bg-white/[0.04] px-4 py-6 text-center transition-colors hover:border-brand-accent/40">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-brand-accent/15 text-brand-accent">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 2l8 3v6c0 5-3.5 8-8 11-4.5-3-8-6-8-11V5z"/></svg>
          </span>
          <span class="font-heading text-sm font-bold leading-tight text-white">{c}</span>
        </div>
      ))}
    </div>
  </div>
</section>

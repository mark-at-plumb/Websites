---
import Bolt from './Bolt.astro';

const socials = [
  { label: 'Facebook', initial: 'f' },
  { label: 'YouTube', initial: 'Y' },
  { label: 'Instagram', initial: 'I' },
  { label: 'LinkedIn', initial: 'in' },
  { label: 'Google', initial: 'G' },
];

const payments = ['Visa', 'Mastercard', 'Cash', 'Bank Transfer'];
const badges = ['NSW Fair Trading Licensed', 'Master Electricians Australia', 'Level 2 ASP', 'Fully Insured'];
---
<div class="space-y-5">
  <!-- Call Us -->
  <a href="tel:+61280000000" class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-slate-900/5">
    <div class="flex items-center gap-4">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-accent/12 text-brand-accent transition-colors group-hover:bg-brand-accent group-hover:text-brand-primary">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
        </svg>
      </span>
      <div>
        <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">Call Us</p>
        <p class="mt-1 font-heading text-2xl font-extrabold tracking-[-0.01em] text-brand-accent">(02) 8000 0000</p>
      </div>
    </div>
  </a>

  <!-- Email Us -->
  <a href="mailto:info@abelectricians.com.au" class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-slate-900/5">
    <div class="flex items-center gap-4">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-accent/12 text-brand-accent transition-colors group-hover:bg-brand-accent group-hover:text-brand-primary">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </span>
      <div>
        <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">Email Us</p>
        <p class="mt-1 break-all font-heading text-lg font-extrabold tracking-[-0.01em] text-brand-text transition-colors group-hover:text-brand-secondary">info@abelectricians.com.au</p>
      </div>
    </div>
  </a>

  <!-- Hours -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center gap-4">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-accent/12 text-brand-accent">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
      </span>
      <div>
        <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">Hours</p>
        <ul class="mt-1.5 space-y-0.5 font-body text-sm text-brand-text">
          <li><span class="font-semibold">Mon–Fri</span> 7am–6pm</li>
          <li><span class="font-semibold">Saturday</span> 8am–4pm</li>
          <li><span class="font-semibold text-brand-accent">Emergency</span> 24/7</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- We Accept -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">We Accept</p>
    <ul class="mt-3 flex flex-wrap gap-2">
      {payments.map((p) => (
        <li class="rounded-lg border border-slate-200 bg-brand-surface px-3 py-1.5 font-heading text-xs font-bold text-brand-text">{p}</li>
      ))}
    </ul>
  </div>

  <!-- Social links -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">Follow Us</p>
    <div class="mt-3 flex flex-wrap gap-2.5">
      {socials.map((s) => (
        <a href="#" aria-label={s.label} class="group flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 transition-colors hover:border-brand-accent hover:bg-brand-accent/5">
          <span class="grid h-7 w-7 place-items-center rounded-md bg-brand-primary font-heading text-xs font-bold text-white transition-colors group-hover:bg-brand-accent group-hover:text-brand-primary">{s.initial}</span>
          <span class="font-body text-sm font-medium text-brand-text">{s.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Trust badges -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-muted">Accredited &amp; Insured</p>
    <ul class="mt-3 grid gap-2.5 sm:grid-cols-2">
      {badges.map((b) => (
        <li class="flex items-center gap-2 font-body text-sm font-medium text-brand-text">
          <Bolt class="h-4 w-4 shrink-0 text-brand-accent" stroke="currentColor" />
          {b}
        </li>
      ))}
    </ul>
  </div>

  <!-- Fleet image -->
  <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
    <img src="/images/electricians-van-rear-with-contact.webp" alt="AB Electricians van rear with contact details" class="h-56 w-full object-cover" loading="lazy" />
  </div>
</div>

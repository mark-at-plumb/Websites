---
import Layout from '../layouts/Layout.astro';
import NavInner from '../components/direction-1/NavInner.astro';
import Footer from '../components/direction-1/Footer.astro';
import Bolt from '../components/direction-1/Bolt.astro';
import ContactPanel from '../components/direction-1/ContactPanel.astro';
import ContactForm from '../components/direction-1/ContactForm.astro';

const areas = ['North Shore', 'Eastern Suburbs', 'Inner West', 'Northern Beaches', 'Hills District'];
---

<style is:global>
  :root {
    --color-brand-primary:   #011835;
    --color-brand-secondary: #007cba;
    --color-brand-accent:    #00d082;
    --color-brand-bg:        #f8fafc;
    --color-brand-surface:   #edf2f7;
    --color-brand-text:      #0f172a;
    --color-brand-muted:     #64748b;
    --font-heading: 'Archivo Variable', system-ui, sans-serif;
    --font-body:    'Inter Variable', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  /* Scroll-reveal system */
  [data-reveal] {
    opacity: 0;
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--rd, 0ms);
  }
  .reveal-up   { transform: translateY(32px); }
  .reveal-left { transform: translateX(-40px); }
  .reveal-right{ transform: translateX(40px); }
  [data-reveal].is-visible { opacity: 1; transform: none; }

  :focus-visible { outline: 2px solid #00d082; outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none; }
  }

  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #00b06e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }
  .sweep-btn:hover::before { transform: scaleX(1); }
</style>

<Layout title="Contact AB Electricians — Sydney's Highest Reviewed Electricians" description="Get in touch with AB Electrical & Communications. Fill in the form or call (02) 8000 0000 for fast, licensed electrical service across Greater Sydney.">
  <NavInner />
  <main id="top">

    <!-- 1. Page Hero -->
    <section class="relative overflow-hidden bg-brand-primary text-white">
      <div class="absolute inset-0">
        <img src="/images/ab-electrical-vans-harbour.webp" alt="" aria-hidden="true" class="h-full w-full object-cover opacity-30" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-brand-primary via-brand-primary/95 to-brand-primary/60"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-5 pb-20 pt-32 sm:px-8 sm:pb-28 sm:pt-40">
        <nav aria-label="Breadcrumb" class="font-body text-sm text-slate-300" data-reveal>
          <ol class="flex flex-wrap items-center gap-2">
            <li><a href="/" class="transition-colors hover:text-brand-accent">Home</a></li>
            <li aria-hidden="true" class="text-slate-500">/</li>
            <li class="text-white">Contact Us</li>
          </ol>
        </nav>

        <div class="mt-8 max-w-3xl">
          <p data-reveal class="reveal-up flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-[0.18em] text-brand-accent">
            <Bolt class="h-4 w-4" stroke="currentColor" /> Contact Us
          </p>
          <h1 data-reveal class="reveal-up mt-4 font-heading text-4xl font-extrabold leading-[1.05] tracking-[-0.02em] sm:text-5xl lg:text-6xl" style="--rd:80ms">
            Looking Forward to Hearing From You
          </h1>
          <p data-reveal class="reveal-up mt-5 max-w-2xl font-body text-lg leading-relaxed text-slate-200" style="--rd:160ms">
            Fill in the form and we'll be in touch shortly — or call us now for a faster response.
          </p>

          <ul data-reveal class="reveal-up mt-7 flex flex-wrap gap-2.5" style="--rd:240ms">
            {['5-Star Rated', 'Lifetime Warranty', 'Upfront Pricing', 'Licensed & Insured'].map((b) => (
              <li class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 font-heading text-xs font-bold uppercase tracking-[0.08em] text-slate-100">
                <Bolt class="h-3 w-3 text-brand-accent" stroke="currentColor" /> {b}
              </li>
            ))}
          </ul>

          <div data-reveal class="reveal-up mt-9 flex flex-col gap-3 sm:flex-row" style="--rd:320ms">
            <a href="#contact-form" class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden rounded-md bg-brand-accent px-6 py-3.5 font-heading text-base font-bold text-brand-primary">
              <span class="relative z-10">Get a Free Quote</span>
              <Bolt class="relative z-10 h-4 w-4" stroke="currentColor" />
            </a>
            <a href="tel:+61280000000" class="inline-flex items-center justify-center gap-2 rounded-md border border-white/20 px-6 py-3.5 font-heading text-base font-bold text-white transition-colors hover:border-brand-accent hover:text-brand-accent">
              Call (02) 8000 0000
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Main Contact Section -->
    <section class="bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-start gap-12 px-5 sm:px-8 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
        <!-- Right panel renders first on mobile (form first) -->
        <div class="reveal-left order-2 lg:order-1" data-reveal>
          <ContactPanel />
        </div>
        <div class="reveal-right order-1 lg:order-2" data-reveal style="--rd:100ms">
          <ContactForm />
        </div>
      </div>
    </section>

    <!-- 3. Map / Service Area teaser -->
    <section class="relative overflow-hidden bg-brand-primary py-20 sm:py-28">
      <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-2 lg:gap-16">
        <div class="reveal-left overflow-hidden rounded-2xl border border-white/10 shadow-2xl shadow-black/40" data-reveal>
          <img src="/images/Sydney-map.webp" alt="Map of AB Electricians' Greater Sydney service area" class="h-[24rem] w-full object-cover" loading="lazy" />
        </div>
        <div class="reveal-right" data-reveal style="--rd:100ms">
          <p class="mb-3 flex items-center gap-2 font-body text-xs font-semibold uppercase tracking-[0.2em] text-brand-accent">
            <Bolt class="h-4 w-4" stroke="currentColor" />
            Service Area
          </p>
          <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-[-0.02em] text-white">We Cover Greater Sydney</h2>
          <p class="mt-4 max-w-lg font-body text-base leading-relaxed text-slate-300">
            From the harbour to the hills, our licensed team services homes and businesses right across Sydney. A few of the areas we cover:
          </p>
          <ul class="mt-7 grid gap-3 sm:grid-cols-2">
            {areas.map((a) => (
              <li class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 font-heading text-sm font-bold text-white">
                <Bolt class="h-4 w-4 text-brand-accent" stroke="currentColor" />
                {a}
              </li>
            ))}
          </ul>
          <a href="/#areas" class="mt-8 inline-flex items-center gap-2 font-heading text-sm font-bold text-brand-accent transition-colors hover:text-white">
            See all service areas
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  // Scroll-triggered reveals
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    reveals.forEach((el) => io.observe(el));
  } else {
    reveals.forEach((el) => el.classList.add('is-visible'));
  }
</script>

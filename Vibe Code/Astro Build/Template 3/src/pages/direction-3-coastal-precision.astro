---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-3/Nav.astro';
import Hero from '../components/direction-3/Hero.astro';
import Founder from '../components/direction-3/Founder.astro';
import Testimonials from '../components/direction-3/Testimonials.astro';
import Services from '../components/direction-3/Services.astro';
import USPs from '../components/direction-3/USPs.astro';
import Process from '../components/direction-3/Process.astro';
import Credentials from '../components/direction-3/Credentials.astro';
import CTASection from '../components/direction-3/CTASection.astro';
import ServiceAreas from '../components/direction-3/ServiceAreas.astro';
import Footer from '../components/direction-3/Footer.astro';
---
<style is:global>
  :root {
    --color-brand-primary:   #1e3a5f;
    --color-brand-secondary: #c45f1a;
    --color-brand-accent:    #00a3b4;
    --color-brand-bg:        #fafaf8;
    --color-brand-surface:   #f0ede8;
    --color-brand-text:      #1a1a1a;
    --color-brand-muted:     #7a7a7a;
    --font-heading: 'Fraunces Variable', Georgia, serif;
    --font-body:    'Source Sans 3 Variable', system-ui, sans-serif;
  }
  html { scroll-behavior: smooth; }
  /* Section-level scroll reveal (refined fade-up) */
  [data-reveal] { opacity: 0; transform: translateY(28px); }
  [data-reveal].cp-in {
    opacity: 1; transform: translateY(0);
    transition: opacity 600ms cubic-bezier(0.16,1,0.3,1), transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
  :focus-visible { outline: 2px solid var(--color-brand-accent); outline-offset: 3px; border-radius: 2px; }
</style>

<Layout title="AB Electricians — Highest Reviewed Electrician in Sydney">
  <Nav />
  <main id="cp-main">
    <Hero />
    <Founder />
    <Testimonials />
    <Services />
    <USPs />
    <Process />
    <Credentials />
    <CTASection />
    <ServiceAreas />
  </main>
  <Footer />
</Layout>

<script>
  // Global reveal observer — Hero manages its own staggered entrance.
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('cp-in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
  const hero = document.getElementById('top');
  document.querySelectorAll('#cp-main [data-reveal]').forEach((el) => {
    if (hero && hero.contains(el)) return; // Hero runs its own stagger
    io.observe(el);
  });
</script>

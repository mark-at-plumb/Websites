---
import Layout from '../layouts/Layout.astro';
import NavInner from '../components/direction-1/NavInner.astro';
import Footer from '../components/direction-1/Footer.astro';
import Bolt from '../components/direction-1/Bolt.astro';
import CTASection from '../components/direction-1/CTASection.astro';
import ServiceAreas from '../components/direction-1/ServiceAreas.astro';

const trustBadges = ['5-Star Rated', 'Lifetime Warranty', 'Upfront Pricing', 'Licensed & Insured'];

const services = [
  { title: 'Residential Electrical', href: '/residential-electrician', img: '/images/ab-electrician-arriving-at-job.webp', desc: 'From safety switches and lighting installs through to full home rewires, for Sydney homes.', feature: true },
  { title: 'Commercial Electrical', href: '#', img: '/images/ab-electrical-van-sydney.webp', desc: 'Fit-outs, maintenance and compliance for North Shore and Sydney businesses.' },
  { title: 'Emergency Electrical', href: '#', img: '/images/electrician-van-at-harbour-bridge.webp', desc: '24/7 callouts. Power loss, faults and hazards sorted fast — any time, any day.' },
  { title: 'Switchboard Upgrades', href: '#', img: '/images/electrician-testing-switchboard.webp', desc: 'Old fuse boards replaced with modern safety switches and RCBOs. Compliant and safe.' },
  { title: 'Electrical Repairs', href: '#', img: '/images/ab-electrician-securing-equipment.webp', desc: 'Fault finding and repairs for anything electrical in your home or business.' },
  { title: 'Lighting Installation', href: '#', img: '/images/electrician-loading-tools.webp', desc: 'Downlights, pendants, outdoor lighting and smart lighting solutions installed properly.' },
  { title: 'Data & Communications', href: '#', img: '/images/ab-electrical-communications-van-rear.webp', desc: 'Network cabling, data points, NBN and comms for home and office.' },
  { title: 'Strata Maintenance', href: '#', img: '/images/ab-electricians-north-sydney-fleet.webp', desc: 'Ongoing electrical maintenance for strata buildings, common areas and compliance.' },
  { title: 'Smoke Alarm Compliance', href: '#', img: '/images/ab-electrician-arriving-at-job.webp', desc: 'NSW smoke alarm compliance assessments and installations for homes and rentals.' },
  { title: 'Level 2 ASP Work', href: '#', img: '/images/electrician-van-skyline.webp', desc: 'ASP-certified mains connections, metering and overhead/underground work.' },
];

const reasons = [
  { title: 'Insurance and Compliance', desc: 'Unlicensed work voids home insurance and can block property sales. Every AB Electrical job is documented and compliant.' },
  { title: 'One Team, Consistent Quality', desc: 'The same licensed team handles every job. No subcontractors, no variable quality, no handoff problems.' },
  { title: 'NSW Compliance Built In', desc: 'Every job meets AS/NZS 3000 standards. We issue certificates of compliance for all notifiable work.' },
  { title: 'Emergency Response Built In', desc: 'A licensed team that knows your home can respond faster in an emergency. We keep records of every job we’ve done for you.' },
];

const steps = [
  { n: '01', title: 'Phone Brief', desc: 'Tell us what’s going on and what you need. We ask the right questions up front so nothing gets missed on site.' },
  { n: '02', title: 'Fixed Quote', desc: 'You get a clear, upfront price before any work begins. No hourly surprises, no hidden extras at the end.' },
  { n: '03', title: 'The Work', desc: 'The same licensed team carries out the job to AS/NZS 3000 standards. We protect your home and work tidy.' },
  { n: '04', title: 'Certificate & Cleanup', desc: 'We issue your certificate of compliance and leave the site clean. Your records are kept on file for next time.' },
];

const certifications = [
  'NSW Fair Trading Licensed',
  'Master Electricians Australia',
  'Level 2 ASP Certified',
  'Registered Electrical Contractor',
  'Fully Insured',
];

const credentialImages = [
  { src: '/images/ab-electricians-north-sydney-fleet.webp', alt: 'AB Electricians fleet across North Sydney' },
  { src: '/images/electrician-testing-switchboard.webp', alt: 'AB Electrical electrician testing a switchboard' },
  { src: '/images/ab-electrical-communications-van-rear.webp', alt: 'AB Electrical communications van' },
];
---

<style is:global>
  :root {
    --color-brand-primary:   #011835;
    --color-brand-secondary: #007cba;
    --color-brand-accent:    #00d082;
    --color-brand-bg:        #f8fafc;
    --color-brand-surface:   #edf2f7;
    --color-brand-text:      #0f172a;
    --color-brand-muted:     #64748b;
    --font-heading: 'Archivo Variable', system-ui, sans-serif;
    --font-body:    'Inter Variable', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  /* Scroll-reveal system */
  [data-reveal] {
    opacity: 0;
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--rd, 0ms);
  }
  .reveal-up   { transform: translateY(32px); }
  .reveal-left { transform: translateX(-40px); }
  .reveal-right{ transform: translateX(40px); }
  [data-reveal].is-visible { opacity: 1; transform: none; }

  :focus-visible { outline: 2px solid #00d082; outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none; }
  }

  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #00b06e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }
  .sweep-btn:hover::before { transform: scaleX(1); }
</style>

<Layout
  title="Electrical Services Sydney — AB Electricians"
  description="Full-spectrum electrical services for Sydney homes, businesses, strata buildings and emergencies — all under one licensed roof. Fully licensed & insured."
>
  <NavInner />
  <main id="top">

    <!-- 1. PAGE HERO -->
    <section class="relative overflow-hidden bg-brand-primary text-white">
      <div class="absolute inset-0">
        <img src="/images/ab-electrical-vans-harbour.webp" alt="AB Electricians vans at Sydney Harbour" class="h-full w-full object-cover opacity-30" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-brand-primary via-brand-primary/95 to-brand-primary/60"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-5 pb-20 pt-32 sm:px-8 sm:pb-28 sm:pt-40">
        <nav aria-label="Breadcrumb" class="font-body text-sm text-slate-300" data-reveal>
          <ol class="flex flex-wrap items-center gap-2">
            <li><a href="/" class="transition-colors hover:text-brand-accent">Home</a></li>
            <li aria-hidden="true" class="text-slate-500">/</li>
            <li class="text-white">Electrical Services</li>
          </ol>
        </nav>

        <div class="mt-8 max-w-3xl">
          <p data-reveal class="reveal-up flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-[0.18em] text-brand-accent">
            <Bolt class="h-4 w-4" stroke="currentColor" /> Our Services
          </p>
          <h1 data-reveal class="reveal-up mt-4 font-heading text-4xl font-extrabold leading-[1.05] tracking-[-0.02em] sm:text-5xl lg:text-6xl" style="--rd:80ms">
            Electrical Services Sydney
          </h1>
          <p data-reveal class="reveal-up mt-5 max-w-2xl font-body text-lg leading-relaxed text-slate-200" style="--rd:160ms">
            Full-spectrum electrical services for Sydney homes, businesses, strata buildings, and emergencies — all under one licensed roof.
          </p>

          <ul data-reveal class="reveal-up mt-7 flex flex-wrap gap-2.5" style="--rd:240ms">
            {trustBadges.map((b) => (
              <li class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 font-heading text-xs font-bold uppercase tracking-[0.08em] text-slate-100">
                <Bolt class="h-3 w-3 text-brand-accent" stroke="currentColor" /> {b}
              </li>
            ))}
          </ul>

          <div data-reveal class="reveal-up mt-9 flex flex-col gap-3 sm:flex-row" style="--rd:320ms">
            <a href="/contact-us" class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden rounded-md bg-brand-accent px-6 py-3.5 font-heading text-base font-bold text-brand-primary">
              <span class="relative z-10">Get a Free Quote</span>
              <Bolt class="relative z-10 h-4 w-4" stroke="currentColor" />
            </a>
            <a href="tel:+61280000000" class="inline-flex items-center justify-center gap-2 rounded-md border border-white/20 px-6 py-3.5 font-heading text-base font-bold text-white transition-colors hover:border-brand-accent hover:text-brand-accent">
              Call (02) 8000 0000
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SERVICES GRID -->
    <section id="services" class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal-up max-w-2xl" data-reveal>
          <p class="mb-3 flex items-center gap-2 font-body text-xs font-semibold uppercase tracking-[0.2em] text-brand-muted">
            <span class="h-px w-8 bg-brand-accent"></span>
            Our Services
          </p>
          <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-[-0.02em] text-brand-text">
            Everything Electrical, One Licensed Team
          </h2>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((s, i) => (
            <a
              href={s.href}
              class="reveal-up group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/50 hover:shadow-lg"
              data-reveal
              style={`--rd:${(i % 3) * 80}ms`}
            >
              <div class="relative overflow-hidden">
                <img src={s.img} alt={`AB Electricians — ${s.title}`} class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <span class="absolute left-4 top-4 grid h-9 w-9 place-items-center rounded-md bg-brand-accent text-brand-primary shadow-lg">
                  <Bolt class="h-4 w-4" stroke="currentColor" />
                </span>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg font-extrabold tracking-[-0.01em] text-brand-text">{s.title}</h3>
                <p class="mt-3 font-body text-sm leading-relaxed text-brand-muted">{s.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. WHY LICENSED MATTERS -->
    <section id="why" class="relative overflow-hidden bg-white py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal-up max-w-3xl" data-reveal>
          <p class="flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-[0.18em] text-brand-accent">
            <Bolt class="h-4 w-4" stroke="currentColor" /> Why It Matters
          </p>
          <h2 class="mt-4 font-heading text-3xl font-extrabold leading-tight tracking-[-0.02em] text-brand-text sm:text-4xl">
            Why Licensed Sydney Electrical Services Actually Matter
          </h2>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2">
          {reasons.map((r, i) => (
            <article class="reveal-up rounded-xl border border-slate-200 bg-brand-surface p-6 transition-colors hover:border-brand-accent/50" data-reveal style={`--rd:${(i % 2) * 100}ms`}>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-accent/15 text-brand-accent">
                  <Bolt class="h-5 w-5" stroke="currentColor" />
                </span>
                <div>
                  <h3 class="font-heading text-lg font-bold tracking-[-0.01em] text-brand-text">{r.title}</h3>
                  <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{r.desc}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. PROCESS -->
    <section id="process" class="relative isolate overflow-hidden bg-brand-primary py-20 text-white sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal-up max-w-2xl" data-reveal>
          <p class="mb-3 flex items-center gap-2 font-body text-xs font-semibold uppercase tracking-[0.2em] text-brand-accent">
            <span class="h-px w-8 bg-brand-accent"></span>
            How We Work
          </p>
          <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-[-0.02em] text-white">
            Our Sydney Electrical Services Process
          </h2>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {steps.map((s, i) => (
            <div class="reveal-up relative rounded-2xl border border-white/10 bg-white/[0.04] p-7 transition-colors duration-300 hover:border-brand-accent/40 hover:bg-white/[0.07]" data-reveal style={`--rd:${i * 90}ms`}>
              <span class="font-heading text-4xl font-extrabold tracking-[-0.03em] text-brand-accent/40">{s.n}</span>
              <h3 class="mt-3 font-heading text-lg font-extrabold tracking-[-0.01em] text-white">{s.title}</h3>
              <p class="mt-2 font-body text-sm leading-relaxed text-slate-300">{s.desc}</p>
              {i < steps.length - 1 && (
                <span class="absolute right-5 top-7 hidden text-white/15 lg:block">
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12m0 0l-5-5m5 5l-5 5"/></svg>
                </span>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. TRUST STRIP -->
    <section id="credentials" class="bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="max-w-3xl" data-reveal>
          <p class="flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-[0.18em] text-brand-secondary">
            <Bolt class="h-4 w-4" stroke="currentColor" /> Credentials
          </p>
          <h2 class="mt-4 font-heading text-3xl font-extrabold leading-tight tracking-[-0.02em] text-brand-text sm:text-4xl">
            Licensed, Certified and Fully Insured
          </h2>
        </div>

        <ul class="mt-10 flex flex-wrap gap-3" data-reveal>
          {certifications.map((c) => (
            <li class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 font-heading text-sm font-bold text-brand-text">
              <Bolt class="h-4 w-4 text-brand-accent" stroke="currentColor" /> {c}
            </li>
          ))}
        </ul>

        <div class="mt-10 grid gap-5 sm:grid-cols-3">
          {credentialImages.map((img, i) => (
            <div data-reveal class="reveal-up overflow-hidden rounded-xl border border-slate-200 shadow-sm" style={`--rd:${i * 90}ms`}>
              <img src={img.src} alt={img.alt} class="h-56 w-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 6. CTA -->
    <ServiceAreas />
    <CTASection />
    <Footer />
</Layout>

<script>
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    reveals.forEach((el) => io.observe(el));
  } else {
    reveals.forEach((el) => el.classList.add('is-visible'));
  }
</script>

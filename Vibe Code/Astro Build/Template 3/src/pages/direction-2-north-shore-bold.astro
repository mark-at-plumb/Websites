---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-2/Nav.astro';
import Hero from '../components/direction-2/Hero.astro';
import Founder from '../components/direction-2/Founder.astro';
import Testimonials from '../components/direction-2/Testimonials.astro';
import Services from '../components/direction-2/Services.astro';
import USPs from '../components/direction-2/USPs.astro';
import Process from '../components/direction-2/Process.astro';
import Credentials from '../components/direction-2/Credentials.astro';
import CTASection from '../components/direction-2/CTASection.astro';
import ServiceAreas from '../components/direction-2/ServiceAreas.astro';
import Footer from '../components/direction-2/Footer.astro';
---
<style is:global>
  :root {
    --color-brand-primary:   #1a1a2e;
    --color-brand-secondary: #e8b84b;
    --color-brand-accent:    #ff6b35;
    --color-brand-bg:        #0d0d1a;
    --color-brand-surface:   #1e1e30;
    --color-brand-text:      #f0f0f5;
    --color-brand-muted:     #9090a8;
    --font-heading: 'Exo 2 Variable', system-ui, sans-serif;
    --font-body:    'DM Sans Variable', system-ui, sans-serif;
  }
  html { scroll-behavior: smooth; }
  body { background: var(--color-brand-bg); color: var(--color-brand-text); font-family: var(--font-body); }
  ::selection { background: var(--color-brand-accent); color: var(--color-brand-bg); }

  .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.6s cubic-bezier(0.2,0.8,0.2,1), transform 0.6s cubic-bezier(0.2,0.8,0.2,1); }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<Layout title="AB Electricians — Highest Reviewed Electrician in Sydney">
  <Nav />
  <main>
    <Hero />
    <Founder />
    <Testimonials />
    <Services />
    <USPs />
    <Process />
    <Credentials />
    <CTASection />
    <ServiceAreas />
  </main>
  <Footer />
</Layout>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-2/Nav.astro';
import Masthead from '../components/direction-2/Masthead.astro';
import TrustStrip from '../components/direction-2/TrustStrip.astro';
import About from '../components/direction-2/About.astro';
import Services from '../components/direction-2/Services.astro';
import LocalContext from '../components/direction-2/LocalContext.astro';
import Emergency from '../components/direction-2/Emergency.astro';
import Testimonials from '../components/direction-2/Testimonials.astro';
import Process from '../components/direction-2/Process.astro';
import WhyChoose from '../components/direction-2/WhyChoose.astro';
import Comparison from '../components/direction-2/Comparison.astro';
import Credentials from '../components/direction-2/Credentials.astro';
import ServiceAreas from '../components/direction-2/ServiceAreas.astro';
import FinalCTA from '../components/direction-2/FinalCTA.astro';
import FAQs from '../components/direction-2/FAQs.astro';
import Footer from '../components/direction-2/Footer.astro';
---

<Layout title="The Neighbourhood Paper — Plumber Happy Valley">
  <style is:global>
    :root {
      --color-brand-primary:   #C45B2A;
      --color-brand-secondary: #8C3D1A;
      --color-brand-accent:    #D4922A;
      --color-brand-bg:        #FAF8F4;
      --color-brand-surface:   #EDE9DC;
      --color-brand-text:      #1A1208;
      --color-brand-muted:     #9A8878;
      --font-heading: 'Fraunces Variable', Georgia, serif;
      --font-body:    'Source Sans 3 Variable', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--color-brand-bg);
      color: var(--color-brand-text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    *, *::before, *::after { box-sizing: border-box; }
    a { color: inherit; }
    :focus-visible {
      outline: 2px solid var(--color-brand-primary);
      outline-offset: 3px;
    }

    /* ---- shared layout primitives (np- prefix avoids collisions) ---- */
    .np-wrap { max-width: 1240px; margin: 0 auto; padding: 0 2rem; }
    .np-section { padding: 4.5rem 0; border-bottom: 1px solid color-mix(in srgb, var(--color-brand-primary) 40%, transparent); }
    @media (max-width: 640px) { .np-section { padding: 3rem 0; } .np-wrap { padding: 0 1.25rem; } }

    /* recurring hairline rule motif */
    .np-rule { height: 1px; width: 100%; background: color-mix(in srgb, var(--color-brand-primary) 40%, transparent); }
    .np-rule-light { background: color-mix(in srgb, var(--color-brand-accent) 35%, transparent); }

    .np-sec-head { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.25rem; }
    .np-marker {
      font-family: var(--font-body);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-brand-primary);
      margin: 0;
    }
    .np-marker-light { color: var(--color-brand-accent); }
    .np-h2 {
      font-family: var(--font-heading);
      font-optical-sizing: auto;
      font-variation-settings: 'opsz' 60;
      font-weight: 600;
      font-size: clamp(1.9rem, 4vw, 3rem);
      line-height: 1.04;
      letter-spacing: -0.012em;
      color: var(--color-brand-text);
      margin: 0;
    }
    .np-h2-light { color: var(--color-brand-bg); }

    /* ---- buttons: flat, no shadow, smooth bg transition only ---- */
    .np-btn {
      display: inline-block;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.98rem;
      letter-spacing: 0.01em;
      text-decoration: none;
      padding: 0.78rem 1.4rem;
      border-radius: 0;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
    }
    .np-btn-outline {
      border: 1px solid var(--color-brand-primary);
      color: var(--color-brand-primary);
      background: transparent;
    }
    .np-btn-outline:hover { background: var(--color-brand-primary); color: var(--color-brand-bg); }
    .np-btn-solid { background: var(--color-brand-primary); color: var(--color-brand-bg); border: 1px solid var(--color-brand-primary); }
    .np-btn-solid:hover { background: var(--color-brand-secondary); border-color: var(--color-brand-secondary); }
    .np-btn-text {
      color: var(--color-brand-text);
      padding: 0.78rem 0.25rem;
      border-bottom: 1px solid transparent;
    }
    .np-btn-text:hover { border-bottom-color: var(--color-brand-primary); color: var(--color-brand-primary); }
    .np-btn-dark { background: var(--color-brand-text); color: var(--color-brand-bg); border: 1px solid var(--color-brand-text); }
    .np-btn-dark:hover { background: transparent; color: var(--color-brand-text); }
    .np-btn-dark-outline { background: transparent; color: var(--color-brand-text); border: 1px solid var(--color-brand-text); }
    .np-btn-dark-outline:hover { background: var(--color-brand-text); color: var(--color-brand-primary); }

    /* ---- scroll reveal ---- */
    .np-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease-out, transform 0.4s ease-out; }
    .np-reveal.is-visible { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .np-reveal { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <Nav />
  <main>
    <Masthead />
    <TrustStrip />
    <About />
    <Services />
    <LocalContext />
    <Emergency />
    <Testimonials />
    <Process />
    <WhyChoose />
    <Comparison />
    <Credentials />
    <ServiceAreas />
    <FinalCTA />
    <FAQs />
  </main>
  <Footer />

  <script>
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = Array.from(document.querySelectorAll('.np-reveal'));
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach((el) => io.observe(el));
    }
  </script>
</Layout>

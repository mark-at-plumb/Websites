---
import Layout from '../layouts/Layout.astro';
import '@fontsource-variable/exo-2';
import '@fontsource-variable/dm-sans';
import Nav from '../components/direction-5/Nav.astro';
import Hero from '../components/direction-5/Hero.astro';
import UspStrip from '../components/direction-5/UspStrip.astro';
import WhyChoose from '../components/direction-5/WhyChoose.astro';
import QuoteBanner from '../components/direction-5/QuoteBanner.astro';
import Services from '../components/direction-5/Services.astro';
import Emergency from '../components/direction-5/Emergency.astro';
import Deals from '../components/direction-5/Deals.astro';
import Process from '../components/direction-5/Process.astro';
import ServiceList from '../components/direction-5/ServiceList.astro';
import About from '../components/direction-5/About.astro';
import ServiceArea from '../components/direction-5/ServiceArea.astro';
import Testimonials from '../components/direction-5/Testimonials.astro';
import Faqs from '../components/direction-5/Faqs.astro';
import ContactCta from '../components/direction-5/ContactCta.astro';
import Footer from '../components/direction-5/Footer.astro';
---
<Layout title="The Bold Tradie — Plumber Happy Valley">
  <style is:global>
    :root {
      --color-brand-primary:   #E8930D;
      --color-brand-secondary: #111111;
      --color-brand-accent:    #F5A623;
      --color-brand-bg:        #FFFFFF;
      --color-brand-surface:   #F5F5F5;
      --color-brand-text:      #111111;
      --color-brand-muted:     #666666;
      --font-heading: 'Exo 2 Variable', system-ui, sans-serif;
      --font-body:    'DM Sans Variable', system-ui, sans-serif;
    }

    .d5-root * { box-sizing: border-box; }
    .d5-root {
      font-family: var(--font-body);
      color: var(--color-brand-text);
      background: var(--color-brand-bg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .d5-root img { display: block; max-width: 100%; }
    .d5-root a { color: inherit; text-decoration: none; }
    .d5-wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; width: 100%; }

    /* shared type */
    .d5-eyebrow {
      font-family: var(--font-heading); font-weight: 700;
      color: var(--color-brand-primary); text-transform: uppercase;
      letter-spacing: 0.14em; font-size: 0.8rem; margin: 0 0 1rem;
    }
    .d5-h2 {
      font-family: var(--font-heading); font-weight: 800;
      font-size: clamp(1.9rem, 4vw, 2.8rem); line-height: 1.08;
      letter-spacing: -0.02em; margin: 0 0 1.1rem;
    }
    .d5-body { font-size: 1.05rem; color: var(--color-brand-muted); margin: 0 0 1.4rem; }
    .d5-center { text-align: center; }
    .d5-narrow { max-width: 620px; margin-left: auto; margin-right: auto; }
    .d5-white { color: #fff; }
    .d5-muted-light { color: rgba(255,255,255,0.75); }
    .d5-orange { color: var(--color-brand-primary); }
    .d5-section-head { margin-bottom: 3rem; }

    .d5-textlink {
      font-family: var(--font-heading); font-weight: 700;
      color: var(--color-brand-primary); text-transform: uppercase;
      letter-spacing: 0.06em; font-size: 0.85rem;
      display: inline-block; transition: opacity .2s;
    }
    .d5-textlink:hover { opacity: .65; }

    .d5-bullet-dot {
      width: 9px; height: 9px; border-radius: 50%;
      background: var(--color-brand-primary); flex: 0 0 auto;
    }

    /* buttons */
    .d5-btn {
      font-family: var(--font-heading); font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.03em;
      font-size: 0.9rem; padding: 14px 26px; border-radius: 0;
      display: inline-flex; align-items: center; justify-content: center;
      border: 2px solid transparent; cursor: pointer; transition: transform .15s, background .2s, color .2s;
      line-height: 1;
    }
    .d5-btn-primary { background: var(--color-brand-primary); color: #111; border-color: var(--color-brand-primary); }
    .d5-btn-primary:hover { background: #c97c06; border-color: #c97c06; }
    .d5-btn-ghost { background: transparent; color: #fff; border-color: var(--color-brand-primary); }
    .d5-btn-ghost:hover { background: var(--color-brand-primary); color: #111; }
    .d5-btn-lg { padding: 18px 34px; font-size: 1rem; }
    .d5-btn-block { width: 100%; }
    .d5-btn:active { transform: translateY(1px); }

    .d5-logo {
      font-family: var(--font-heading); font-weight: 800;
      font-size: 1.25rem; letter-spacing: -0.01em; color: var(--color-brand-text);
      display: inline-flex; align-items: center; gap: 10px;
    }
    .d5-badge {
      font-family: var(--font-body); font-weight: 600;
      font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.08em;
      background: var(--color-brand-primary); color: #111;
      padding: 3px 7px; border-radius: 3px;
    }

    /* 1. utility */
    .d5-utility { background: var(--color-brand-primary); height: 40px; display: flex; align-items: center; }
    .d5-utility-inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; color: #111; font-size: 0.8rem; font-weight: 500; }
    .d5-utility-right { display: flex; align-items: center; gap: 12px; }
    .d5-utility-right a { font-weight: 700; }
    .d5-dot-sep { opacity: .5; }
    .d5-bolt { font-size: .9rem; }

    /* 2. nav */
    .d5-nav { position: sticky; top: 0; z-index: 50; background: #fff; height: 70px; display: flex; align-items: center; transition: box-shadow .25s; }
    .d5-nav.is-scrolled { box-shadow: 0 2px 14px rgba(0,0,0,0.10); }
    .d5-nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
    .d5-nav-links { display: flex; gap: 26px; }
    .d5-nav-links a { font-family: var(--font-heading); font-weight: 600; font-size: 0.95rem; transition: color .2s; }
    .d5-nav-links a:hover { color: var(--color-brand-primary); }
    .d5-nav-cta { font-family: var(--font-heading); font-weight: 700; font-size: 0.85rem; background: var(--color-brand-primary); color: #111; padding: 12px 18px; text-transform: uppercase; letter-spacing: .02em; transition: background .2s; }
    .d5-nav-cta:hover { background: #c97c06; }
    .d5-burger { display: none; background: none; border: 0; flex-direction: column; gap: 5px; padding: 8px; cursor: pointer; }
    .d5-burger span { width: 24px; height: 2px; background: #111; display: block; }
    .d5-mobile-menu { display: none; }

    /* 3. hero */
    .d5-hero { background: var(--color-brand-secondary); min-height: 85vh; display: flex; align-items: stretch; overflow: hidden; }
    .d5-hero-grid { display: grid; grid-template-columns: 55% 45%; align-items: center; gap: 0; }
    .d5-hero-text { padding: 4rem 4rem 4rem 0; }
    .d5-hero-h1 { font-family: var(--font-heading); font-weight: 800; color: #fff; font-size: clamp(2.6rem, 5.2vw, 4.5rem); line-height: 1.02; letter-spacing: -0.02em; margin: 0 0 1.4rem; }
    .d5-hero-sub { color: rgba(255,255,255,0.75); font-size: 1.1rem; max-width: 540px; margin: 0 0 2rem; }
    .d5-hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 1.6rem; }
    .d5-hero-trust { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 18px; color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 600; }
    .d5-hero-trust li { color: rgba(255,255,255,0.85); }
    .d5-hero-photo { position: relative; align-self: stretch; min-height: 85vh; }
    .d5-hero-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .d5-hero-photo::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(232,147,13,0.45), transparent 35%); pointer-events: none; }

    /* page-load animations */
    .d5-anim { opacity: 0; transform: translateY(20px); }
    @keyframes d5-rise { to { opacity: 1; transform: translateY(0); } }
    @keyframes d5-wipe { from { clip-path: inset(0 0 0 100%); } to { clip-path: inset(0 0 0 0); } }
    .d5-anim-1 { animation: d5-rise .5s cubic-bezier(.16,1,.3,1) .12s forwards; }
    .d5-anim-2 { animation: d5-rise .5s cubic-bezier(.16,1,.3,1) .2s forwards; }
    .d5-anim-3 { animation: d5-rise .4s cubic-bezier(.16,1,.3,1) .35s forwards; }
    .d5-anim-4 { animation: d5-rise .35s cubic-bezier(.16,1,.3,1) .5s forwards; }
    .d5-hero-photo img { animation: d5-wipe .6s cubic-bezier(.16,1,.3,1) .1s both; }

    /* 4. usp */
    .d5-usp { background: var(--color-brand-primary); padding: 3rem 0; }
    .d5-usp-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
    .d5-usp-col { padding: 0.5rem 2rem; color: #fff; border-left: 1px solid rgba(255,255,255,0.2); }
    .d5-usp-col:first-child { border-left: 0; padding-left: 0; }
    .d5-usp-icon { color: #fff; margin-bottom: 0.9rem; }
    .d5-usp-title { font-family: var(--font-heading); font-weight: 700; font-size: 1.15rem; margin: 0 0 .4rem; color: #fff; }
    .d5-usp-text { font-size: 0.875rem; color: rgba(255,255,255,0.92); margin: 0; }

    /* 5. why choose */
    .d5-why { display: grid; grid-template-columns: 45% 55%; background: #fff; }
    .d5-why-photo { position: relative; min-height: 560px; }
    .d5-why-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .d5-why-photo::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(232,147,13,0.35), transparent 30%); }
    .d5-why-text { display: flex; align-items: center; padding: 4rem; }
    .d5-why-inner { max-width: 620px; }
    .d5-benefits { list-style: none; margin: 0 0 1.8rem; padding: 0; display: grid; gap: 1rem; }
    .d5-benefits li { display: flex; gap: 12px; align-items: flex-start; font-size: 1rem; color: var(--color-brand-text); }
    .d5-benefits strong { font-family: var(--font-heading); }
    .d5-tick { flex: 0 0 auto; width: 24px; height: 24px; border-radius: 50%; background: rgba(232,147,13,0.14); color: var(--color-brand-primary); display: grid; place-items: center; margin-top: 2px; }

    /* 6. quote banner */
    .d5-qbanner { background: var(--color-brand-secondary); border-left: 4px solid var(--color-brand-primary); padding: 2.5rem 0; }
    .d5-qbanner-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .d5-qbanner-text { font-family: var(--font-heading); font-weight: 800; color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); margin: 0; letter-spacing: -0.01em; }

    /* 7. services */
    .d5-services { background: #fff; padding: 5rem 0; }
    .d5-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .d5-service-card { background: #fff; border: 1px solid #eaeaea; overflow: hidden; transition: transform .2s, box-shadow .2s; position: relative; }
    .d5-service-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--color-brand-primary); transform: scaleX(0); transform-origin: left; transition: transform .25s; z-index: 2; }
    .d5-service-card:hover { transform: translateY(-5px); box-shadow: 0 16px 36px rgba(0,0,0,0.12); }
    .d5-service-card:hover::before { transform: scaleX(1); }
    .d5-service-photo { height: 200px; overflow: hidden; }
    .d5-service-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
    .d5-service-card:hover .d5-service-photo img { transform: scale(1.05); }
    .d5-service-body { padding: 1.5rem; }
    .d5-service-name { font-family: var(--font-heading); font-weight: 700; font-size: 1.25rem; margin: 0 0 .6rem; }
    .d5-service-text { font-size: 0.95rem; color: var(--color-brand-muted); margin: 0 0 1rem; }

    /* 8. emergency */
    .d5-emergency { background: var(--color-brand-secondary); }
    .d5-emergency-grid { display: grid; grid-template-columns: 60% 40%; align-items: stretch; }
    .d5-emergency-text { padding: 5rem 4rem 5rem 0; }
    .d5-emergency-bullets { list-style: none; margin: 0 0 2rem; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem 2rem; }
    .d5-emergency-bullets li { display: flex; align-items: center; gap: 12px; color: #fff; font-weight: 600; font-family: var(--font-heading); }
    .d5-emergency-photo { position: relative; min-height: 460px; }
    .d5-emergency-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .d5-emergency-photo::after { content: ""; position: absolute; inset: 0; background: rgba(17,17,17,0.35); }

    /* 9. deals */
    .d5-deals { background: #fff; padding: 5rem 0; }
    .d5-deals .d5-h2 { margin-bottom: 3rem; }
    .d5-deals-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    .d5-deal-card { border: 1px solid var(--color-brand-primary); border-top: 4px solid var(--color-brand-primary); background: #fff; padding: 2rem 1.6rem; text-align: center; transition: box-shadow .2s, transform .2s; }
    .d5-deal-card:hover { box-shadow: 0 14px 30px rgba(232,147,13,0.18); transform: translateY(-3px); }
    .d5-deal-big { font-family: var(--font-heading); font-weight: 900; font-size: 2.6rem; color: var(--color-brand-primary); margin: 0 0 .4rem; letter-spacing: -0.02em; }
    .d5-deal-title { font-family: var(--font-heading); font-weight: 700; font-size: 1.2rem; margin: 0 0 .7rem; }
    .d5-deal-text { font-size: 0.9rem; color: var(--color-brand-muted); margin: 0; }

    /* 10. process */
    .d5-process { background: #1a1a1a; padding: 5rem 0; }
    .d5-process .d5-h2 { margin-bottom: 3.5rem; }
    .d5-process-grid { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: start; gap: 1rem; }
    .d5-process-step { text-align: center; }
    .d5-process-num { font-family: var(--font-heading); font-weight: 900; font-size: 4.5rem; color: var(--color-brand-primary); line-height: 1; display: block; margin-bottom: 1rem; }
    .d5-process-photo { width: 140px; height: 140px; border-radius: 50%; overflow: hidden; margin: 0 auto 1.4rem; border: 3px solid var(--color-brand-primary); }
    .d5-process-photo img { width: 100%; height: 100%; object-fit: cover; }
    .d5-process-title { font-family: var(--font-heading); font-weight: 700; color: #fff; font-size: 1.3rem; margin: 0 0 .6rem; }
    .d5-process-text { color: rgba(255,255,255,0.7); font-size: 0.95rem; margin: 0; max-width: 280px; margin-inline: auto; }
    .d5-process-arrow { color: var(--color-brand-primary); display: grid; place-items: center; padding-top: 4.6rem; }

    /* 11. service list */
    .d5-slist { background: #fff; padding: 5rem 0; }
    .d5-slist-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 3.5rem; align-items: start; }
    .d5-slist-items { list-style: none; margin: 1.6rem 0 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem 1.5rem; }
    .d5-slist-items li { display: flex; align-items: center; gap: 12px; font-family: var(--font-heading); font-weight: 600; font-size: 1.02rem; }
    .d5-slist-right { display: grid; gap: 1rem; }
    .d5-statbox { border: 1px solid var(--color-brand-primary); border-left: 4px solid var(--color-brand-primary); padding: 1.4rem 1.6rem; display: flex; flex-direction: column; }
    .d5-statbox-big { font-family: var(--font-heading); font-weight: 900; font-size: 2.4rem; color: var(--color-brand-primary); line-height: 1; }
    .d5-statbox-text { font-size: 0.92rem; color: var(--color-brand-muted); margin-top: .4rem; }

    /* 12. about */
    .d5-about { background: var(--color-brand-secondary); }
    .d5-about-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; gap: 0; }
    .d5-about-photo { position: relative; min-height: 480px; }
    .d5-about-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .d5-about-text { padding: 5rem 0 5rem 4rem; display: flex; flex-direction: column; justify-content: center; }

    /* 13. area */
    .d5-area { background: #fff; padding: 5rem 0; }
    .d5-area-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: center; }
    .d5-area-list { list-style: none; margin: 1.6rem 0 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.8rem 1.5rem; }
    .d5-area-list a { display: flex; align-items: center; gap: 12px; font-family: var(--font-heading); font-weight: 600; transition: color .2s; }
    .d5-area-list a:hover { color: var(--color-brand-primary); }
    .d5-area-photo { position: relative; min-height: 380px; border-radius: 0; overflow: hidden; }
    .d5-area-photo img { width: 100%; height: 100%; min-height: 380px; object-fit: cover; }
    .d5-area-tint { position: absolute; inset: 0; background: var(--color-brand-primary); opacity: 0.15; }

    /* 14. testimonials */
    .d5-testi { background: var(--color-brand-surface); padding: 5rem 0; }
    .d5-testi .d5-h2 { margin-bottom: 3rem; }
    .d5-testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
    .d5-testi-card { background: #fff; padding: 2.4rem 2rem 2rem; box-shadow: 0 8px 24px rgba(0,0,0,0.06); position: relative; }
    .d5-testi-quotemark { position: absolute; top: 0.2rem; left: 1.2rem; font-family: var(--font-heading); font-weight: 900; font-size: 4.5rem; color: var(--color-brand-primary); opacity: 0.25; line-height: 1; }
    .d5-testi-stars { color: #F5A623; letter-spacing: 2px; margin: 0 0 1rem; position: relative; }
    .d5-testi-quote { font-size: 1rem; color: var(--color-brand-text); margin: 0 0 1.4rem; }
    .d5-testi-meta { font-size: 0.88rem; color: var(--color-brand-muted); margin: 0; }
    .d5-testi-meta strong { color: var(--color-brand-text); font-family: var(--font-heading); }

    /* 15. faqs */
    .d5-faqs { background: #fff; padding: 5rem 0; }
    .d5-faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 2.5rem; align-items: start; }
    .d5-faq { border-bottom: 1px solid #e6e6e6; }
    .d5-faq summary { list-style: none; cursor: pointer; padding: 1.1rem 0; display: flex; align-items: center; justify-content: space-between; gap: 16px; font-family: var(--font-heading); font-weight: 700; font-size: 1.05rem; }
    .d5-faq summary::-webkit-details-marker { display: none; }
    .d5-faq-ind { position: relative; flex: 0 0 auto; width: 20px; height: 20px; }
    .d5-faq-ind::before, .d5-faq-ind::after { content: ""; position: absolute; background: var(--color-brand-primary); transition: transform .2s; }
    .d5-faq-ind::before { top: 9px; left: 2px; right: 2px; height: 2px; }
    .d5-faq-ind::after { left: 9px; top: 2px; bottom: 2px; width: 2px; }
    .d5-faq[open] .d5-faq-ind::after { transform: scaleY(0); }
    .d5-faq p { margin: 0 0 1.2rem; color: var(--color-brand-muted); font-size: 0.98rem; }

    /* 16. contact */
    .d5-contact { background: var(--color-brand-secondary); padding: 5rem 0; }
    .d5-contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
    .d5-contact-details { list-style: none; margin: 2rem 0 0; padding: 0; display: grid; gap: 1.1rem; }
    .d5-contact-details li { display: flex; flex-direction: column; gap: 2px; }
    .d5-contact-details span { color: var(--color-brand-primary); font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; font-size: 0.72rem; letter-spacing: .1em; }
    .d5-contact-details a, .d5-contact-details li { color: #fff; }
    .d5-form { background: #fff; padding: 2.2rem; }
    .d5-field { margin-bottom: 1.1rem; }
    .d5-field label { display: block; font-family: var(--font-heading); font-weight: 700; font-size: 0.82rem; margin-bottom: .4rem; }
    .d5-field input, .d5-field textarea { width: 100%; border: 1px solid #d4d4d4; padding: 12px 14px; font-family: var(--font-body); font-size: 0.98rem; border-radius: 0; background: #fafafa; }
    .d5-field input:focus, .d5-field textarea:focus { outline: 2px solid var(--color-brand-primary); outline-offset: 1px; border-color: var(--color-brand-primary); }
    .d5-field textarea { resize: vertical; }
    .d5-form-done { margin: 1rem 0 0; color: #1a7a2e; font-weight: 600; font-size: 0.95rem; }

    /* 17. footer */
    .d5-footer { background: #0D0D0D; color: rgba(255,255,255,0.7); }
    .d5-footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; padding: 4rem 24px 3rem; }
    .d5-logo-light { color: #fff; margin-bottom: 1rem; }
    .d5-footer-brand p { margin: 1rem 0 1.6rem; max-width: 360px; font-size: 0.95rem; }
    .d5-footer-col h4 { font-family: var(--font-heading); font-weight: 700; color: #fff; font-size: 1rem; margin: 0 0 1rem; }
    .d5-footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.7rem; }
    .d5-footer-col a { font-size: 0.95rem; transition: color .2s; }
    .d5-footer-col a:hover { color: var(--color-brand-primary); }
    .d5-footer-bar { border-top: 1px solid rgba(255,255,255,0.1); padding: 1.4rem 0; }
    .d5-footer-bar-inner { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-size: 0.82rem; }
    .d5-footer-bar a:hover { color: var(--color-brand-primary); }

    /* focus visibility */
    .d5-root a:focus-visible, .d5-root button:focus-visible, .d5-root summary:focus-visible {
      outline: 2px solid var(--color-brand-primary); outline-offset: 3px;
    }

    /* responsive */
    @media (max-width: 980px) {
      .d5-nav-links, .d5-nav-cta { display: none; }
      .d5-burger { display: flex; }

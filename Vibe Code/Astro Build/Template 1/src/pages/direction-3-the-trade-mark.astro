    .tm-svc:hover { border-left: 2px solid var(--color-brand-primary); background: var(--color-brand-surface); }
    .tm-svc__t { font-weight: 700; font-size: 1.15rem; letter-spacing: -0.02em; margin-bottom: 0.6rem; }
    .tm-svc__d { font-size: 0.92rem; color: var(--color-brand-muted); margin: 0; }
    @media (max-width: 860px) { .tm-services__grid { grid-template-columns: repeat(2, 1fr); } }

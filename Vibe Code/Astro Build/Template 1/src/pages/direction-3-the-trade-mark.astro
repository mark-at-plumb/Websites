    /* TESTIMONIALS */
    .tm-testi .tm-label { margin-bottom: 2rem; }
    .tm-testi__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
    .tm-testi__cell { margin: 0; padding-top: 1rem; border-top: 2px solid var(--color-brand-text); }
    .tm-testi__mark { font-family: var(--font-heading); font-weight: 800; font-size: 4rem; color: var(--color-brand-primary); line-height: 0.6; display: block; }
    .tm-testi__q { margin: 1rem 0; font-size: 1.25rem; font-weight: 500; letter-spacing: -0.01em; line-height: 1.4; }
    .tm-testi__a { color: var(--color-brand-muted); font-weight: 600; font-family: var(--font-heading); font-size: 0.9rem; }

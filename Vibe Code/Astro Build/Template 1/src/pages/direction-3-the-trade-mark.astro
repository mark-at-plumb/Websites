    .tm-cta__btn { border-color: var(--color-brand-text); color: var(--color-brand-text); }
    .tm-cta__btn:hover { background: var(--color-brand-text); color: #fff; }
    @media (max-width: 640px) { .tm-cta__right { text-align: left; } }

    /* FAQs */
    .tm-faqs__head { margin-bottom: 2.5rem; }
    .tm-faqs__head .tm-label { margin-bottom: 0.75rem; }
    .tm-faqs__list { max-width: 820px; }
    .tm-faq { border-top: 1px solid #D5D5D5; }
    .tm-faq:last-child { border-bottom: 1px solid #D5D5D5; }
    .tm-faq__q {
      list-style: none; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center; gap: 1rem;
      padding: 1.4rem 0; font-family: var(--font-heading); font-weight: 700; font-size: 1.1rem;
      letter-spacing: -0.01em;
    }
    .tm-faq__q::-webkit-details-marker { display: none; }
    .tm-faq__ind { position: relative; width: 16px; height: 16px; flex: none; }
    .tm-faq__ind::before, .tm-faq__ind::after {
      content: ''; position: absolute; background: var(--color-brand-primary);
    }
    .tm-faq__ind::before { left: 0; top: 7px; width: 16px; height: 2px; }
    .tm-faq__ind::after { left: 7px; top: 0; width: 2px; height: 16px; transition: transform 0.2s ease; }
    .tm-faq[open] .tm-faq__ind::after { transform: scaleY(0); }
    .tm-faq__a { margin: 0 0 1.4rem; color: var(--color-brand-muted); max-width: 64ch; font-size: 1rem; }

    /* FOOTER */
    .tm-footer { border-top: 2px solid var(--color-brand-text); padding-block: 3rem 2rem; background: var(--color-brand-bg); }
    .tm-footer__grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 2.5rem; }
    .tm-footer__brand { font-family: var(--font-heading); font-weight: 700; font-size: 1.2rem; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
    .tm-footer__meta { color: var(--color-brand-muted); margin: 0 0 0.75rem; max-width: 38ch; font-size: 0.92rem; }
    .tm-footer__lic { font-family: var(--font-heading); font-weight: 600; font-size: 0.85rem; margin: 0; }
    .tm-footer__col-h { font-family: var(--font-heading); font-weight: 700; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-brand-muted); margin: 0 0 1rem; }
    .tm-footer__links { list-style: none; margin: 0; padding: 0; }
    .tm-footer__links li { padding: 0.4rem 0; font-size: 0.92rem; color: var(--color-brand-muted); }
    .tm-footer__links a { text-decoration: none; color: var(--color-brand-text); }
    .tm-footer__links a:hover { color: var(--color-brand-primary); }
    .tm-footer__phone { font-weight: 700; }
    .tm-footer__rule { height: 1px; background: #D5D5D5; margin: 2.5rem 0 1.25rem; }
    .tm-footer__bottom { display: flex; align-items: center; gap: 0.75rem; font-size: 0.82rem; color: var(--color-brand-muted); flex-wrap: wrap; }
    .tm-footer__bottom a { text-decoration: none; }
    .tm-footer__bottom a:hover { color: var(--color-brand-text); }
    @media (max-width: 760px) { .tm-footer__grid { grid-template-columns: 1fr; gap: 2rem; } }
  </style>

  <script>
    // Scroll reveal + rule draw-in
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-in', 'is-drawn');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.tm-reveal, .tm-rule--draw').forEach((el) => io.observe(el));

    // Draw the hero rules immediately on load
    requestAnimationFrame(() => {
      document.querySelectorAll('.tm-hero .tm-rule--draw').forEach((el, i) => {
        setTimeout(() => el.classList.add('is-drawn'), 120 + i * 120);
      });
    });

    // Count up stats
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const counted = new WeakSet();
    const countIO = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting || counted.has(e.target)) return;
        counted.add(e.target);
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0', 10);
        const suffix = el.dataset.suffix || '';
        if (reduce) { el.textContent = target + suffix; return; }
        const dur = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.tm-stat__n').forEach((el) => countIO.observe(el));
  </script>
</Layout>

    /* STATS inverted */
    .tm-stats { background: var(--color-brand-secondary); color: #fff; padding-block: clamp(3.5rem, 7vw, 6rem); }
    .tm-stats__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .tm-stat { border-left: 2px solid var(--color-brand-primary); padding-left: 1.5rem; }
    .tm-stat__n {

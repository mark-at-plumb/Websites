    .tm-areas__link:hover { background: var(--color-brand-primary); color: #fff; }
    @media (max-width: 760px) { .tm-areas__grid { grid-template-columns: repeat(2, 1fr); } }

    /* FINAL CTA */
    .tm-cta { background: var(--color-brand-primary); color: var(--color-brand-text); padding-block: clamp(3.5rem, 7vw, 5.5rem); }
    .tm-cta__inner { display: flex; justify-content: space-between; align-items: center; gap: 2.5rem; flex-wrap: wrap; }
    .tm-cta__label { color: var(--color-brand-text); opacity: 0.7; }
    .tm-cta__h { font-weight: 800; font-size: clamp(2.4rem, 6vw, 4rem); letter-spacing: -0.04em; margin: 0.75rem 0 0.75rem; }
    .tm-cta__p { margin: 0; font-weight: 600; font-size: 1.1rem; max-width: 30ch; }
    .tm-cta__right { text-align: right; }
    .tm-cta__phone {
      display: block; font-family: var(--font-heading); font-weight: 800;
      font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.04em;

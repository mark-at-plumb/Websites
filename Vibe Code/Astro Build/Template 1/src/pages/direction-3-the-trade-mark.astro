---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-3/Nav.astro';
import Rule from '../components/direction-3/Rule.astro';

const PHONE = '(08) 8000 0000';
const TEL = 'tel:0880000000';

const trust = [
  { n: '24/7', t: 'Emergency Response', d: 'We answer day or night, weekends and public holidays included.' },
  { n: '∞', t: 'Lifetime Labour Warranty', d: 'Every job we do is covered by our labour warranty for life.' },
  { n: '$0', t: 'Fixed Upfront Pricing', d: 'You get the price before we start. No surprises on the invoice.' },
  { n: '$50', t: 'Off Your First Service', d: 'New to us? Take fifty dollars off your first booking with our team.' },
];

const services = [
  { t: 'General Plumbing', d: 'Repairs, installs and maintenance for every fixture and pipe in your home, done properly the first time.' },
  { t: 'Emergency Plumbing', d: 'Burst pipes and floods at 2am. We turn up fast, stop the damage and sort the cause.' },
  { t: 'Blocked Drains', d: 'We clear blocked drains with high-pressure jetting, then check why it blocked in the first place.' },
  { t: 'Hot Water', d: 'Repairs and replacements for gas, electric and heat-pump systems. Cold shower fixed same day where we can.' },
  { t: 'Leaking Taps', d: 'A dripping tap wastes water and money. We re-seat, re-washer or replace it the right way.' },
  { t: 'Toilet Repairs', d: 'Running, blocked or wobbly toilets. We fix the cistern, the seal and the flush so it stays fixed.' },
  { t: 'Gas Fitting', d: 'Licensed gas work for cooktops, heaters and hot water. Safe, compliant and certified every time.' },
  { t: 'CCTV Drain Camera', d: 'We send a camera down your drains to find the real problem before we quote a single dollar.' },
  { t: 'Pipe Relining', d: 'We repair broken pipes from the inside, with no digging up your garden or driveway.' },
];

const stats = [
  { n: 500, suffix: '+', label: '5-star reviews from Adelaide homeowners' },
  { n: 10, suffix: '+', label: 'Years working on Happy Valley homes' },
  { n: 24, suffix: '/7', label: 'Emergency response, every day of the year' },
];

const emergencies = [
  'Burst or leaking pipes', 'No hot water', 'Blocked or overflowing toilet',
  'Flooded laundry or bathroom', 'Gas leak or smell', 'Sewer backing up',
];

const steps = [
  { t: 'Call Us', d: 'Ring our team any hour. A real person answers and books your job straight away.' },
  { t: 'Fixed Quote', d: 'We assess the problem and give you the price upfront. You approve before we start.' },
  { t: 'We Fix It', d: 'Our licensed plumber does the work properly, cleans up and respects your home.' },
  { t: 'Warranty', d: 'Your labour is covered for life. If something we did fails, we come back.' },
];

const reasons = [
  { t: 'We actually show up', d: "We book a time and we keep it. If we're held up, you get a call, not silence." },
  { t: 'One licensed local team', d: "We're family-owned, not a franchise. The same trusted plumbers work across Happy Valley." },
  { t: 'No surprise invoices', d: "You sign off on a fixed price first. The number we quote is the number you pay." },
  { t: 'Respect for your home', d: 'We wear boot covers, lay drop sheets and leave your place tidy. Like we were never there.' },
];

const compare = [
  ['Pricing', 'Fixed upfront, approved before work starts', 'Hourly, you find out at the end'],
  ['Warranty', 'Lifetime Labour Warranty on every job', 'Thirty days, if you can find them'],
  ['Availability', '24/7, weekends and public holidays', 'When they feel like answering'],
  ['Licence', 'Lic. #333997, fully insured', '“Mate of a mate”, no paperwork'],
  ['Local', 'Family-owned, based near Happy Valley', 'Drives in from the other side of town'],
  ['Reviews', '500+ verified 5-star reviews', 'A couple from family members'],
];

const certLines = [
  'Master Plumber South Australia',
  'Licence No. 333997',
  'ABN 52 668 135 886',
  '$5M Public Liability Insurance',
  'Lifetime Labour Warranty',
  '500+ Verified 5-Star Reviews',
];

const testimonials = [
  { q: "Burst pipe at midnight, water everywhere. They answered, turned up within the hour and had it stopped fast. Fixed price, no drama.", a: 'Karen M., Happy Valley' },
  { q: "Booked a hot water replacement. They quoted upfront, showed up on time and cleaned up after. You can tell they actually care about the work.", a: 'Dave R., Aberfoyle Park' },
];

const areas = ['Happy Valley', 'Aberfoyle Park', 'Flagstaff Hill', 'Reynella', 'Morphett Vale', 'Hallett Cove', 'Chandlers Hill', 'Cherry Gardens', "O'Halloran Hill", 'Trott Park', 'Old Reynella', 'Woodcroft'];

const faqs = [
  { q: 'Are you actually licensed?', a: "Yes. We hold South Australian plumbing licence number 333997 and carry $5M public liability insurance. We're happy to show you the paperwork." },
  { q: 'Do you really answer 24/7?', a: 'We do. A real person answers the phone day or night, on weekends and on public holidays. Plumbing emergencies don\'t keep business hours, so neither do we.' },
  { q: 'How does fixed upfront pricing work?', a: 'We assess the job, then give you one fixed price before any work begins. You approve it first. The price we quote is the price you pay.' },
  { q: 'What does the Lifetime Labour Warranty cover?', a: 'It covers the labour on every job we do, for life. If something we installed or repaired fails because of our work, we come back and put it right.' },
  { q: 'Can you get to my place within the hour?', a: 'Where availability allows, yes. We\'re local to Happy Valley, so we\'re often nearby. We\'ll always give you an honest arrival time when you call.' },
  { q: 'Do you charge extra on weekends?', a: 'We\'ll always tell you the price before we start, including any after-hours rate. There are no hidden charges added to your invoice afterward.' },
];
---
<Layout title="The Trade Mark — Plumber Happy Valley">
  <style is:global>
    :root {
      --color-brand-primary:   #D93B1F;
      --color-brand-secondary: #1F1F1F;
      --color-brand-accent:    #FF6B35;
      --color-brand-bg:        #FFFFFF;
      --color-brand-surface:   #F4F4F4;
      --color-brand-text:      #0F0F0F;
      --color-brand-muted:     #777777;
      --font-heading: 'Plus Jakarta Sans Variable', system-ui, sans-serif;
      --font-body:    'Plus Jakarta Sans Variable', system-ui, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: 80px; }
    body {
      margin: 0;
      font-family: var(--font-body);
      color: var(--color-brand-text);
      background: var(--color-brand-bg);
      font-weight: 400;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; }

    .tm-wrap { max-width: 1280px; margin: 0 auto; padding-inline: 1.5rem; }

    .tm-label {
      font-family: var(--font-heading);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-brand-primary);
      display: block;
    }

    .tm-section { padding-block: clamp(3.5rem, 7vw, 6rem); }
    .tm-section--surface { background: var(--color-brand-surface); }

    h1, h2, h3 {
      font-family: var(--font-heading);
      margin: 0;
      letter-spacing: -0.04em;
      line-height: 1.02;
    }
    h2.tm-h2 {
      font-weight: 800;
      font-size: clamp(2rem, 4vw, 3rem);
      max-width: 16ch;
    }

    .tm-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: -0.01em;
      padding: 0.95rem 1.6rem;
      border: 2px solid var(--color-brand-text);
      text-decoration: none;
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    .tm-btn--solid {
      background: var(--color-brand-primary);
      border-color: var(--color-brand-primary);
      color: #fff;
    }
    .tm-btn--solid:hover { background: var(--color-brand-text); border-color: var(--color-brand-text); }
    .tm-btn--outline { background: transparent; color: var(--color-brand-text); }
    .tm-btn--outline:hover { background: var(--color-brand-text); color: #fff; }
    .tm-btn--orange {
      background: transparent;
      border-color: var(--color-brand-primary);
      color: var(--color-brand-primary);
    }
    .tm-btn--orange:hover { background: var(--color-brand-primary); color: #fff; }

    /* scroll reveal */
    .tm-reveal { opacity: 0; transform: translateY(14px); }
    .tm-reveal.is-in {
      opacity: 1; transform: none;
      transition: opacity 0.25s ease-out, transform 0.25s ease-out;
    }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .tm-reveal { opacity: 1; transform: none; }
    }
  </style>

  <span id="top"></span>
  <Nav />

  <!-- ===== HERO ===== -->
  <section class="tm-hero">
    <div class="tm-wrap">
      <span class="tm-label tm-hero__eyebrow">Licensed · Insured · Family-Owned · Happy Valley</span>
    </div>
    <Rule />
    <div class="tm-wrap tm-hero__grid">
      <div class="tm-hero__left tm-reveal">
        <h1 class="tm-hero__h1">24/7 Emergency<br />Plumber in<br />Happy Valley</h1>
        <p class="tm-hero__sub">Fixed upfront pricing. Lifetime Labour Warranty.<br />We show up when we say.</p>
        <div class="tm-hero__cta">
          <a href={TEL} class="tm-btn tm-btn--solid">Call {PHONE}</a>
          <a href="#quote" class="tm-btn tm-btn--outline">Get a Free Quote</a>
        </div>
      </div>
      <div class="tm-hero__rule" aria-hidden="true"></div>
      <div class="tm-hero__right">
        <span class="tm-label">Call 24/7</span>
        <a href={TEL} class="tm-hero__phone">{PHONE}</a>
        <p class="tm-hero__note">Within the hour where available.</p>
      </div>
    </div>
    <Rule />
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="tm-section tm-trust">
    <div class="tm-wrap">
      <div class="tm-trust__grid">
        {trust.map((c) => (
          <div class="tm-trust__cell tm-reveal">
            <span class="tm-trust__n">{c.n}</span>
            <h3 class="tm-trust__t">{c.t}</h3>
            <p class="tm-trust__d">{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Rule />

  <!-- ===== ABOUT ===== -->
  <section class="tm-section tm-section--surface tm-about">
    <div class="tm-wrap tm-about__grid">
      <div class="tm-reveal">
        <span class="tm-label">About Us</span>
        <h2 class="tm-h2 tm-about__h">Happy Valley's Local Plumber</h2>
      </div>
      <div class="tm-about__body tm-reveal">
        <p>We're a family-owned plumbing business working on Happy Valley homes for over ten years. Not a franchise, not a call centre. When you ring us, you get a licensed local plumber who knows the area and treats your home with respect. We fix the problem properly, charge a fair fixed price, and stand behind every job for life.</p>
        <dl class="tm-facts">
          <div class="tm-facts__row"><dt>Licence</dt><dd>#333997</dd></div>
          <div class="tm-facts__row"><dt>Established</dt><dd>10+ years</dd></div>
          <div class="tm-facts__row"><dt>Reviews</dt><dd>500+ 5-star</dd></div>
          <div class="tm-facts__row"><dt>ABN</dt><dd>52 668 135 886</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="tm-section tm-services" id="services">
    <div class="tm-wrap">
      <div class="tm-services__head tm-reveal">
        <span class="tm-label">Services</span>
        <h2 class="tm-h2">What We Fix</h2>
      </div>
      <div class="tm-services__grid">
        {services.map((s, i) => (
          <article class="tm-svc tm-reveal" style={`--row:${Math.floor(i / 3)}`}>
            <h3 class="tm-svc__t">{s.t}</h3>
            <p class="tm-svc__d">{s.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== STATS (inverted) ===== -->
  <section class="tm-stats" id="stats">
    <div class="tm-wrap">
      <div class="tm-stats__grid">
        {stats.map((s) => (
          <div class="tm-stat tm-reveal">
            <span class="tm-stat__n" data-count={s.n} data-suffix={s.suffix}>0{s.suffix}</span>
            <p class="tm-stat__label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== LOCAL CONTEXT ===== -->
  <section class="tm-section tm-section--surface tm-local">
    <div class="tm-wrap tm-local__wrap">
      <span class="tm-label tm-reveal">Local Knowledge</span>
      <h2 class="tm-h2 tm-reveal">Plumbing in Happy Valley</h2>
      <div class="tm-local__cols tm-reveal">
        <p>Happy Valley has a mix of older brick homes and newer builds, and the plumbing tells the story. In the established streets we often find ageing galvanised pipe, original clay sewer lines and hot water systems well past their prime. These show up as low pressure, slow drains and the odd nasty leak inside the wall.</p>
        <p>Tree root intrusion is the big one around here. Mature gums and established gardens send roots straight into old joints, blocking drains and cracking pipe. We use a CCTV camera to find the exact problem, then reline or clear it without tearing up your yard. Knowing the local ground and the local homes means we fix the cause, not just the symptom.</p>
      </div>
    </div>
  </section>

  <!-- ===== EMERGENCY ===== -->
  <section class="tm-section tm-emergency">
    <div class="tm-wrap tm-emergency__grid">
      <div class="tm-reveal">
        <span class="tm-label">Emergency Plumber</span>
        <h2 class="tm-h2 tm-emergency__h">Emergency Plumber Happy Valley</h2>
        <p class="tm-emergency__p">We answer 24/7, including weekends and public holidays. If it's an emergency, don't wait. Call us now.</p>
        <a href={TEL} class="tm-emergency__phone">{PHONE}</a>
      </div>
      <ul class="tm-emergency__list tm-reveal">
        {emergencies.map((e) => (<li>{e}</li>))}
      </ul>
    </div>
  </section>

  <Rule />

  <!-- ===== PROCESS ===== -->
  <section class="tm-section tm-section--surface tm-process">
    <div class="tm-wrap">
      <div class="tm-process__head tm-reveal">
        <span class="tm-label">How It Works</span>
        <h2 class="tm-h2">Four Steps, No Surprises</h2>
      </div>
      <div class="tm-process__rule" aria-hidden="true"></div>
      <div class="tm-process__grid">
        {steps.map((s, i) => (
          <div class="tm-step tm-reveal">
            <span class="tm-step__n">{i + 1}</span>
            <h3 class="tm-step__t">{s.t}</h3>
            <p class="tm-step__d">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE ===== -->
  <section class="tm-section tm-why">
    <div class="tm-wrap">
      <div class="tm-why__head tm-reveal">
        <span class="tm-label">Why Locals Choose Us</span>
        <h2 class="tm-h2">No-Nonsense Plumbing</h2>
      </div>
      <div class="tm-why__grid">
        {reasons.map((r) => (
          <div class="tm-why__cell tm-reveal">
            <h3 class="tm-why__t">{r.t}</h3>
            <p class="tm-why__d">{r.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON ===== -->
  <section class="tm-section tm-section--surface tm-compare">
    <div class="tm-wrap">
      <div class="tm-compare__head tm-reveal">
        <span class="tm-label">Plumber Happy Valley vs. The Alternative</span>
        <h2 class="tm-h2">The Difference Is Documented</h2>
      </div>
      <table class="tm-table tm-reveal">
        <thead>
          <tr>
            <th></th>
            <th>Plumber Happy Valley</th>
            <th>A Generic Tradie</th>
          </tr>
        </thead>
        <tbody>
          {compare.map((row) => (
            <tr>
              <th scope="row">{row[0]}</th>
              <td class="tm-table__us">{row[1]}</td>
              <td class="tm-table__them">{row[2]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ===== CREDENTIALS CERTIFICATE ===== -->
  <section class="tm-section tm-cred" id="credentials">
    <div class="tm-wrap">
      <div class="tm-cert tm-reveal">
        <div class="tm-cert__head">
          <span class="tm-label tm-cert__label">Licence · Credentials · Guarantees</span>
        </div>
        <div class="tm-cert__seal" aria-hidden="true">
          <span>SA</span>
        </div>
        <h2 class="tm-cert__title">Certificate of Trade</h2>
        <p class="tm-cert__sub">Plumber Happy Valley · Family-Owned Adelaide</p>
        <dl class="tm-cert__lines">
          {certLines.map((line) => (<div class="tm-cert__row"><dt>{line}</dt></div>))}
        </dl>
        <div class="tm-cert__foot">
          <span>Verified</span>
          <span>Happy Valley · SA</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="tm-section--surface tm-testi tm-section">
    <div class="tm-wrap">
      <span class="tm-label tm-reveal">What Locals Say</span>
      <div class="tm-testi__grid">
        {testimonials.map((t) => (
          <figure class="tm-testi__cell tm-reveal">
            <span class="tm-testi__mark" aria-hidden="true">&ldquo;</span>
            <blockquote class="tm-testi__q">{t.q}</blockquote>
            <figcaption class="tm-testi__a">{t.a}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICE AREAS ===== -->
  <section class="tm-section tm-areas" id="areas">
    <div class="tm-wrap">
      <span class="tm-label tm-reveal">Service Area</span>
      <h2 class="tm-h2 tm-reveal tm-areas__h">Suburbs We Cover</h2>
      <div class="tm-areas__grid tm-reveal">
        {areas.map((a) => (<a href="#quote" class="tm-areas__link">{a}</a>))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="tm-cta" id="quote">
    <div class="tm-wrap tm-cta__inner">
      <div>
        <span class="tm-label tm-cta__label">Ready When You Are</span>
        <h2 class="tm-cta__h">Ready to Book?</h2>
        <p class="tm-cta__p">Call now, or get a free quote. A real local plumber will pick up.</p>
      </div>
      <div class="tm-cta__right">
        <a href={TEL} class="tm-cta__phone">{PHONE}</a>
        <a href="#quote" class="tm-btn tm-btn--outline tm-cta__btn">Get a Free Quote</a>
      </div>
    </div>
  </section>

  <!-- ===== FAQs ===== -->
  <section class="tm-section tm-section--surface tm-faqs" id="faqs">
    <div class="tm-wrap">
      <div class="tm-faqs__head tm-reveal">
        <span class="tm-label">FAQs</span>
        <h2 class="tm-h2">Straight Answers</h2>
      </div>
      <div class="tm-faqs__list">
        {faqs.map((f) => (
          <details class="tm-faq tm-reveal">
            <summary class="tm-faq__q">
              <span>{f.q}</span>
              <span class="tm-faq__ind" aria-hidden="true"></span>
            </summary>
            <p class="tm-faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="tm-footer">
    <div class="tm-wrap">
      <div class="tm-footer__grid">
        <div>
          <p class="tm-footer__brand">Plumber Happy Valley</p>
          <p class="tm-footer__meta">Family-owned, licensed Adelaide plumbing. Local to Happy Valley and the surrounding southern suburbs.</p>
          <p class="tm-footer__lic">Lic. #333997 · ABN 52 668 135 886</p>
        </div>
        <div>
          <p class="tm-footer__col-h">Services</p>
          <ul class="tm-footer__links">
            {services.slice(0, 6).map((s) => (<li><a href="#services">{s.t}</a></li>))}
          </ul>
        </div>
        <div>
          <p class="tm-footer__col-h">Contact</p>
          <ul class="tm-footer__links">
            <li><a href={TEL} class="tm-footer__phone">{PHONE}</a></li>
            <li>24/7 Emergency Response</li>
            <li>Happy Valley, SA</li>
            <li><a href="#quote">Get a Free Quote</a></li>
          </ul>
        </div>
      </div>
      <div class="tm-footer__rule" aria-hidden="true"></div>
      <div class="tm-footer__bottom">
        <span>© 2026 Plumber Happy Valley</span>
        <span class="tm-footer__sep">·</span>
        <a href="#">Privacy</a>
        <span class="tm-footer__sep">·</span>
        <a href="#">Terms</a>
      </div>
    </div>
  </footer>

  <style>
    /* HERO */
    .tm-hero__eyebrow { padding-block: 1.25rem 1rem; }
    .tm-hero__grid {
      display: grid;
      grid-template-columns: 1.5fr 1px 1fr;
      gap: clamp(1.5rem, 4vw, 3.5rem);
      align-items: center;
      padding-block: clamp(2.5rem, 5vw, 4rem);
    }
    .tm-hero__rule { background: var(--color-brand-text); width: 1px; align-self: stretch; }
    .tm-hero__h1 {
      font-weight: 800;
      font-size: clamp(2.6rem, 6vw, 5rem);
      letter-spacing: -0.04em;
    }
    .tm-hero__sub {
      margin: 1.5rem 0 2rem;
      font-size: 1.1rem;
      color: var(--color-brand-muted);
      font-weight: 500;
      max-width: 32ch;
    }
    .tm-hero__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
    .tm-hero__right { text-align: right; }
    @media (max-width: 860px) { .tm-hero__right { text-align: left; } }
    .tm-hero__phone {
      display: block;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: clamp(2.6rem, 7vw, 4.5rem);
      letter-spacing: -0.04em;
      color: var(--color-brand-secondary);
      text-decoration: none;
      margin-top: 0.75rem;
      padding-top: 0.85rem;
      border-top: 4px solid var(--color-brand-primary);
      line-height: 0.95;
      animation: tm-slide-right 0.4s 0.2s ease-out both;
    }
    .tm-hero__note { margin: 1rem 0 0; color: var(--color-brand-muted); font-weight: 500; }
    @keyframes tm-slide-right {
      from { opacity: 0; transform: translateX(28px); }
      to { opacity: 1; transform: none; }
    }
    @media (prefers-reduced-motion: reduce) { .tm-hero__phone { animation: none; } }
    @media (max-width: 860px) {
      .tm-hero__grid { grid-template-columns: 1fr; }
      .tm-hero__rule { display: none; }
      .tm-hero__right { border-top: 2px solid var(--color-brand-text); padding-top: 1.5rem; }
    }

    /* TRUST */
    .tm-trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); }
    .tm-trust__cell {
      padding: 1.75rem;
      border: 1px solid #E0E0E0;
      margin-left: -1px;
      margin-top: -1px;
    }
    .tm-trust__n {
      display: block;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 2.75rem;
      color: var(--color-brand-primary);
      letter-spacing: -0.04em;
      line-height: 1;
    }
    .tm-trust__t { font-weight: 700; font-size: 1.05rem; margin: 0.9rem 0 0.5rem; letter-spacing: -0.02em; }
    .tm-trust__d { font-size: 0.9rem; color: var(--color-brand-muted); margin: 0; }
    @media (max-width: 860px) { .tm-trust__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .tm-trust__grid { grid-template-columns: 1fr; } }

    /* ABOUT */
    .tm-about__grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
    .tm-about__h { margin-top: 0.9rem; }
    .tm-about__body p { font-size: 1.05rem; margin: 0 0 2rem; }
    .tm-facts { margin: 0; }
    .tm-facts__row {
      display: flex; justify-content: space-between; gap: 1rem;
      padding: 0.9rem 0;
      border-top: 1px solid #D5D5D5;
      font-family: var(--font-heading);
    }
    .tm-facts__row:last-child { border-bottom: 1px solid #D5D5D5; }
    .tm-facts__row dt { color: var(--color-brand-muted); font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.78rem; align-self: center; }
    .tm-facts__row dd { margin: 0; font-weight: 700; font-size: 1.05rem; }
    @media (max-width: 760px) { .tm-about__grid { grid-template-columns: 1fr; } }

    /* SERVICES */
    .tm-services__head { margin-bottom: 2.5rem; }
    .tm-services__head .tm-label { margin-bottom: 0.75rem; }
    .tm-services__grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    .tm-svc {
      padding: 1.75rem;

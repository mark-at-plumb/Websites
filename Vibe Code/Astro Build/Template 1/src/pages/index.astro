---
import Layout from '../layouts/Layout.astro';
const directions = [
  {
    n: 1,
    name: 'The Trusted Local',
    slug: 'direction-1-the-trusted-local',
    palette: 'Navy #1A2E44 · Amber #D4882E · Off-White',
    fonts: 'Montserrat + DM Sans',
    description: 'Split-screen hero with a navy panel and amber CTAs. Suburb badge in the sticky nav. Large stat counters. Warm, residential confidence.',
    tag: null,
    dot: '#D4882E',
  },
  {
    n: '1b',
    name: 'The Professional',
    slug: 'direction-4-the-professional',
    palette: 'Slate #1E2D3D · Teal #0E7490 · White',
    fonts: 'Outfit + Inter',
    description: 'Same layout as Direction 1 — split-screen hero, suburb badge, stats section — but a cooler, more authoritative palette with a full orchestrated animation system.',
    tag: 'Variant',
    dot: '#0E7490',
  },
  {
    n: 2,
    name: 'The Neighbourhood Paper',
    slug: 'direction-2-the-neighbourhood-paper',
    palette: 'Paper #FAF8F4 · Copper #C45B2A · Ink #1A1208',
    fonts: 'Fraunces + Source Sans 3',
    description: 'Suburb name as newspaper masthead. Hairline copper rules. Editorial two-column grid. Testimonial pull-quotes in large Fraunces italic.',
    tag: null,
    dot: '#C45B2A',
  },
  {
    n: 3,
    name: 'The Trade Mark',
    slug: 'direction-3-the-trade-mark',
    palette: 'White · Charcoal #1F1F1F · Red-Orange #D93B1F',
    fonts: 'Plus Jakarta Sans + Inter',
    description: 'Phone number as the visual hero at 72px. Horizontal rule system. Credentials displayed as a licence certificate. Sharp, zero-radius, trade-precise.',
    tag: null,
    dot: '#D93B1F',
  },
  {
    n: 5,
    name: 'The Bold Tradie',
    slug: 'direction-5-the-bold-tradie',
    palette: 'Black #111111 · Orange #E8930D · White',
    fonts: 'Exo 2 + DM Sans',
    description: 'Dark/orange high-impact layout modelled on the jimmysparkselectrical.com.au reference. Orange utility bar, 6-card photo services grid, deals strip, 3-step process, dark alternating sections, full contact form.',
    tag: 'New',
    dot: '#E8930D',
  },
];
---
<Layout title="Your Homepage Concepts — Plumber Happy Valley">
  <main style="max-width: 700px; margin: 0 auto; padding: 4rem 1.5rem; font-family: var(--font-body);">
    <div style="margin-bottom: 2.5rem;">
      <div style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-brand-muted); margin-bottom: 0.5rem;">Plumber Happy Valley · Homepage Prototypes</div>
      <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0 0 0.5rem; font-family: var(--font-heading); color: var(--color-brand-text);">Your Homepage Concepts</h1>
      <p style="color: var(--color-brand-muted); font-size: 0.95rem; line-height: 1.6; margin: 0;">Click each direction to preview the full homepage. Scroll through each one fully before deciding.</p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {directions.map(d => (
        <a href={`/${d.slug}`} style="display: block; padding: 1.5rem 1.75rem; border: 1px solid #e0ddd8; border-radius: 10px; text-decoration: none; color: inherit; background: var(--color-brand-surface); position: relative;">
          {d.tag && (
            <span style={`position: absolute; top: 1rem; right: 1rem; background: ${d.dot}; color: ${d.dot === '#E8930D' ? '#111' : 'white'}; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 4px;`}>{d.tag}</span>
          )}
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.6rem;">
            <span style={`width: 10px; height: 10px; border-radius: 50%; background: ${d.dot}; flex: none;`}></span>
            <div style="font-size: 0.7rem; font-weight: 600; color: var(--color-brand-muted); text-transform: uppercase; letter-spacing: 0.08em;">Direction {d.n}</div>
            <div style="font-size: 1.1rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-brand-text);">{d.name}</div>
          </div>
          <div style="font-size: 0.78rem; color: var(--color-brand-muted); margin-bottom: 0.5rem; padding-left: 1.6rem;">{d.palette} · {d.fonts}</div>
          <div style="color: #555; font-size: 0.88rem; line-height: 1.55; padding-left: 1.6rem;">{d.description}</div>
        </a>
      ))}
    </div>

    <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #e0ddd8; font-size: 0.8rem; color: var(--color-brand-muted); line-height: 1.6;">
      <strong style="color: var(--color-brand-text);">What to look for:</strong> Scroll through each one fully without analysing. Which one makes you lean forward? Which looks like YOUR brand? Tell me what you love from each and I'll build the final design from your feedback.
    </div>
  </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-1/Nav.astro';
import Hero from '../components/direction-1/Hero.astro';
import UspStrip from '../components/direction-1/UspStrip.astro';
import About from '../components/direction-1/About.astro';
import Services from '../components/direction-1/Services.astro';
import Stats from '../components/direction-1/Stats.astro';
import LocalContext from '../components/direction-1/LocalContext.astro';
import Emergency from '../components/direction-1/Emergency.astro';
import Process from '../components/direction-1/Process.astro';
import WhyChoose from '../components/direction-1/WhyChoose.astro';
import Comparison from '../components/direction-1/Comparison.astro';
import Credentials from '../components/direction-1/Credentials.astro';
import ServiceAreas from '../components/direction-1/ServiceAreas.astro';
import FinalCta from '../components/direction-1/FinalCta.astro';
import Faqs from '../components/direction-1/Faqs.astro';
import Footer from '../components/direction-1/Footer.astro';
---
<Layout title="The Trusted Local — Plumber Happy Valley">
  <style is:global>
    :root {
      --color-brand-primary:   #D4882E;
      --color-brand-secondary: #1A2E44;
      --color-brand-accent:    #E8A44A;
      --color-brand-bg:        #F8F6F2;
      --color-brand-surface:   #EEE9E0;
      --color-brand-text:      #1A2E44;
      --color-brand-muted:     #8A9CAD;
      --font-heading: 'Montserrat Variable', system-ui, sans-serif;
      --font-body:    'DM Sans Variable', system-ui, sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--color-brand-bg); color: var(--color-brand-text); font-family: var(--font-body); -webkit-font-smoothing: antialiased; }
    img, svg { max-width: 100%; }

    /* Shared button styles used in the hero */
    .btn { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; border-radius: 12px; font-family: var(--font-heading); font-weight: 800; transition: transform .25s ease, box-shadow .25s ease, background .25s ease, color .25s ease; }
    .btn--amber { background: var(--color-brand-primary); color: #fff; font-size: 18px; padding: 16px 26px; box-shadow: 0 14px 30px rgba(212,136,46,.4); }
    .btn--amber:hover { transform: translateY(-3px); box-shadow: 0 22px 44px rgba(212,136,46,.5); }
    .btn--ghost { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.3); font-size: 16px; font-weight: 700; padding: 15px 24px; }
    .btn--ghost:hover { border-color: var(--color-brand-accent); color: var(--color-brand-accent); }

    /* Global scroll-reveal system */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s cubic-bezier(.16,1,.3,1); transition-delay: var(--rd, 0ms); }
    .reveal.in { opacity: 1; transform: none; }
    /* Hero handles its own reveal timing via .in toggling */
    .hero .reveal { transition-delay: 0ms; }

    :focus-visible { outline: 3px solid var(--color-brand-primary); outline-offset: 3px; border-radius: 4px; }

    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .reveal { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <Nav />
  <main>
    <Hero />
    <UspStrip />
    <About />
    <Services />
    <Stats />
    <LocalContext />
    <Emergency />
    <Process />
    <WhyChoose />
    <Comparison />
    <Credentials />
    <ServiceAreas />
    <FinalCta />
    <Faqs />
  </main>
  <Footer />

  <script>
    // Global scroll-reveal observer (skips hero, which sequences itself)
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.reveal').forEach((el) => {
      if (el.closest('.hero')) return;
      io.observe(el);
    });
  </script>
</Layout>

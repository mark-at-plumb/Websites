---
import Tick from './Tick.astro';
const pills = ['Lic. #333997', '500+ Reviews', '$50 Off First Service', '24/7 Emergency'];
const HERO = 'https://jimmysparkselectrical.com.au/wp-content/uploads/2026/03/jimmy-sparks-electrical-electrician-with-dog-branded-ute-4-copy-1.webp';
---
<section class="d6-hero" id="top">
  <div class="d6-hero__wrap d6-wrap">
    <div class="d6-hero__text">
      <span class="d6-hero__eyebrow" data-anim="eyebrow">Happy Valley's #1 Rated Plumber</span>
      <h1 class="d6-hero__h1" data-anim="h1">Fast, <span>Licensed</span> Plumbing in Happy Valley</h1>
      <p class="d6-hero__sub" data-anim="sub">
        Fixed upfront pricing. Lifetime Labour Warranty. 24/7 emergency response.
        We show up when we say we will.
      </p>
      <ul class="d6-hero__pills" data-anim="pills">
        {pills.map((p, i) => (
          <li style={`--i:${i}`}><Tick size={13} color="var(--color-brand-primary)" />{p}</li>
        ))}
      </ul>
      <div class="d6-hero__cta" data-anim="cta">
        <a class="d6-btn d6-btn--primary" href="tel:0880000000">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1Z" fill="currentColor"/></svg>
          CALL (08) 8000 0000
        </a>
        <a class="d6-btn d6-btn--ghost-orange" href="#contact">GET A FREE QUOTE</a>
      </div>
      <p class="d6-hero__trust" data-anim="cta">Lic. #333997 · ABN 52 668 135 886</p>
    </div>

    <div class="d6-hero__media">
      <div class="d6-hero__photo">
        <img src={HERO} alt="Licensed Happy Valley plumber with branded ute and dog" loading="eager" width="900" height="1100" />
        <div class="d6-hero__overlay" aria-hidden="true"></div>
        <span class="d6-hero__cap">Licensed local plumbers, Happy Valley &amp; surrounds</span>
      </div>
    </div>
  </div>
</section>

<style>
  .d6-hero { background: var(--color-brand-secondary); min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
  .d6-hero__wrap { display: grid; grid-template-columns: 55fr 45fr; gap: clamp(28px,4vw,56px); align-items: center; width: 100%; padding-top: 56px; padding-bottom: 56px; }

  .d6-hero__eyebrow {
    display: inline-block; font-family: var(--font-body); font-weight: 700; text-transform: uppercase;
    letter-spacing: .16em; font-size: 12px; color: var(--color-brand-primary); margin-bottom: 20px;
  }
  .d6-hero__h1 {
    font-family: var(--font-heading); font-weight: 800; letter-spacing: -.02em; line-height: 1.04;
    color: #fff; font-size: clamp(44px, 5vw, 72px); margin: 0 0 20px;
  }
  .d6-hero__h1 span { color: var(--color-brand-primary); }
  .d6-hero__sub { font-family: var(--font-body); font-size: 17px; line-height: 1.62; color: rgba(255,255,255,.72); margin: 0 0 26px; max-width: 50ch; }
  .d6-hero__pills { list-style: none; padding: 0; margin: 0 0 30px; display: flex; flex-wrap: wrap; gap: 10px; }
  .d6-hero__pills li {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-body); font-weight: 600; font-size: 13px; color: #fff;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12);
    padding: 9px 13px; border-radius: 4px;
  }
  .d6-hero__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }
  .d6-hero__trust { font-family: var(--font-body); font-size: 12.5px; color: rgba(255,255,255,.5); margin: 0; }

  .d6-hero__media { position: relative; }
  .d6-hero__photo {
    position: relative; border-radius: 8px; overflow: hidden; aspect-ratio: 4/5;
    box-shadow: 0 30px 60px rgba(0,0,0,.4);
    clip-path: inset(0 100% 0 0);
    animation: d6-wipe .65s ease-out .05s forwards;
  }
  @keyframes d6-wipe { to { clip-path: inset(0 0% 0 0); } }
  .d6-hero__photo img { width: 100%; height: 100%; object-fit: cover; display: block; animation: d6-kenburns 12s ease-in-out infinite alternate; }
  @keyframes d6-kenburns { from { transform: scale(1); } to { transform: scale(1.03); } }
  .d6-hero__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(15,25,35,.7) 0%, rgba(15,25,35,0) 45%); }
  .d6-hero__cap {
    position: absolute; left: 18px; bottom: 18px; right: 18px;
    font-family: var(--font-body); font-size: 13px; font-weight: 500; color: #fff;
    border-left: 3px solid var(--color-brand-primary); padding-left: 10px;
  }

  [data-anim] { opacity: 0; }
  .d6-hero.seq [data-anim="eyebrow"] { animation: d6-rise .4s ease-out .15s forwards; --from: 12px; }
  .d6-hero.seq [data-anim="h1"]      { animation: d6-rise .55s var(--d6-ease) .28s forwards; --from: 18px; }
  .d6-hero.seq [data-anim="sub"]     { animation: d6-rise .4s ease-out .42s forwards; --from: 12px; }
  .d6-hero.seq [data-anim="pills"]   { opacity: 1; }
  .d6-hero.seq [data-anim="cta"]     { animation: d6-rise .4s ease-out .72s forwards; --from: 10px; }
  @keyframes d6-rise { from { opacity: 0; transform: translateY(var(--from,14px)); } to { opacity: 1; transform: none; } }
  .d6-hero__pills li { opacity: 0; }
  .d6-hero.seq .d6-hero__pills li { animation: d6-rise .4s ease-out forwards; animation-delay: calc(550ms + var(--i) * 70ms); --from: 10px; }

  @media (max-width: 900px) {
    .d6-hero__wrap { grid-template-columns: 1fr; }
    .d6-hero__media { order: -1; }
    .d6-hero__photo { aspect-ratio: 16/10; }
  }
  @media (prefers-reduced-motion: reduce) {
    .d6-hero__photo { clip-path: none; animation: none; }
    .d6-hero__photo img { animation: none; }
    [data-anim], .d6-hero__pills li { opacity: 1 !important; transform: none !important; animation: none !important; }
  }
</style>

<script>
  const hero = document.getElementById('top');
  requestAnimationFrame(() => hero?.classList.add('seq'));
</script>

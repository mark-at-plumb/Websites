---
const items = [
  { title: '$50 Off First Service', text: 'New customers save on their first call-out.',
    icon: '<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { title: '$0 Call Out Fee', text: 'We charge for the job, not the drive.',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M5 5l14 14"/>' },
  { title: 'Free Quotes', text: 'Fixed upfront price before we lift a tool.',
    icon: '<path d="M4 4h12l4 4v12H4z"/><path d="M8 9h8M8 13h8M8 17h5"/>' },
  { title: 'Same-Day Service', text: 'On the van and on the way within the hour.',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>' },
];
---
<!-- Section 4: USP Strip -->
<section class="d5-usp">
  <div class="d5-wrap d5-usp-grid">
    {items.map((it) => (
      <div class="d5-usp-col">
        <svg class="d5-usp-icon" width="32" height="32" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          aria-hidden="true" set:html={it.icon} />
        <h3 class="d5-usp-title">{it.title}</h3>
        <p class="d5-usp-text">{it.text}</p>
      </div>
    ))}
  </div>
</section>

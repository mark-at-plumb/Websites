---
const PHONE = '(08) 8000 0000';
---
<!-- Section 1: Utility bar -->
<div class="d5-utility">
  <div class="d5-wrap d5-utility-inner">
    <span class="d5-utility-left"><span class="d5-bolt">⚡</span> Emergency Plumbing — Happy Valley &amp; surrounds</span>
    <span class="d5-utility-right">
      <a href={`tel:${PHONE.replace(/[^0-9+]/g,'')}`}>{PHONE}</a>
      <span class="d5-dot-sep">|</span>
      <span>Mon–Sun, 24/7</span>
    </span>
  </div>
</div>

<!-- Section 2: Navigation -->
<header class="d5-nav" id="d5-nav">
  <div class="d5-wrap d5-nav-inner">
    <a href="#top" class="d5-logo">
      Plumber Happy Valley
      <span class="d5-badge">Happy Valley</span>
    </a>
    <nav class="d5-nav-links" aria-label="Primary">
      <a href="#services">Services</a>
      <a href="#about">About</a>
      <a href="#reviews">Reviews</a>
      <a href="#faq">FAQ</a>
      <a href="#contact">Contact</a>
    </nav>
    <a href={`tel:${PHONE.replace(/[^0-9+]/g,'')}`} class="d5-nav-cta">CALL NOW {PHONE}</a>
    <button class="d5-burger" aria-label="Toggle menu" aria-expanded="false" id="d5-burger">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="d5-mobile-menu" id="d5-mobile-menu" aria-label="Mobile">
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#reviews">Reviews</a>
    <a href="#faq">FAQ</a>
    <a href="#contact">Contact</a>
    <a href={`tel:${PHONE.replace(/[^0-9+]/g,'')}`} class="d5-mobile-cta">CALL NOW {PHONE}</a>
  </nav>
</header>

<script>
  const nav = document.getElementById('d5-nav');
  const onScroll = () => {
    if (window.scrollY > 50) nav?.classList.add('is-scrolled');
    else nav?.classList.remove('is-scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const burger = document.getElementById('d5-burger');
  const menu = document.getElementById('d5-mobile-menu');
  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
    })
  );
</script>

---
const { id = '' } = Astro.props;
---
<!-- Section 6: Quote Banner -->
<section class="d5-qbanner" id={id}>
  <div class="d5-wrap d5-qbanner-inner">
    <p class="d5-qbanner-text">Get a fast quote on <span class="d5-orange">plumbing services</span></p>
    <a href="#contact" class="d5-btn d5-btn-primary">GET A FREE QUOTE</a>
  </div>
</section>

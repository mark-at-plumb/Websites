---
const faqs = [
  { q: 'Do you really answer 24/7?', a: 'Yes. We answer the phone any hour, any day, including weekends and public holidays. A burst pipe at 2am gets the same response as one at 2pm.' },
  { q: 'How does fixed upfront pricing work?', a: 'We look at the job, then give you a set price before we start. You agree to it first. The price does not change once the work is done.' },
  { q: 'What does the Lifetime Labour Warranty cover?', a: 'It covers the labour on every job we do, for life. If our workmanship fails, we come back and put it right at no cost to you.' },
  { q: 'Are you licensed?', a: 'Yes. We are fully licensed under Lic. #333997 and we are Master Plumbers in South Australia. We are happy to show you our credentials.' },
  { q: 'Do you charge a call-out fee?', a: 'We are upfront about any call-out before we come. There are no hidden fees, and your first service is $50 off.' },
  { q: 'Which areas do you cover?', a: 'We cover Happy Valley and the surrounding suburbs, including Aberfoyle Park, Flagstaff Hill, Reynella, and Morphett Vale.' },
];
---

<section class="np-faqs np-section np-reveal" id="faqs">
  <div class="np-wrap">
    <div class="np-sec-head">
      <p class="np-marker">06 / FAQs</p>
      <h2 class="np-h2">Questions locals ask</h2>
    </div>
    <div class="np-rule"></div>
    <div class="np-faq-list">
      {faqs.map((f) => (
        <details class="np-faq">
          <summary class="np-faq-q">
            <span>{f.q}</span>
            <span class="np-faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="np-faq-a-wrap"><p class="np-faq-a">{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .np-faq-list { margin-top: 2rem; }
  .np-faq {
    border-bottom: 1px solid color-mix(in srgb, var(--color-brand-primary) 30%, transparent);
  }
  .np-faq:first-child { border-top: 1px solid color-mix(in srgb, var(--color-brand-primary) 30%, transparent); }
  .np-faq-q {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0;
    font-family: var(--font-heading);
    font-variation-settings: 'opsz' 24;
    font-weight: 600;
    font-size: clamp(1.1rem, 1.8vw, 1.32rem);
    color: var(--color-brand-text);
  }
  .np-faq-q::-webkit-details-marker { display: none; }
  .np-faq-icon {
    flex-shrink: 0;
    width: 14px; height: 14px;
    position: relative;
  }
  .np-faq-icon::before, .np-faq-icon::after {
    content: ''; position: absolute; background: var(--color-brand-primary);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .np-faq-icon::before { left: 0; top: 50%; width: 100%; height: 2px; transform: translateY(-50%); }
  .np-faq-icon::after { top: 0; left: 50%; height: 100%; width: 2px; transform: translateX(-50%); }
  .np-faq[open] .np-faq-icon::after { opacity: 0; transform: translateX(-50%) scaleY(0); }

  .np-faq-a-wrap {
    display: grid;
    grid-template-rows: 1fr;
    overflow: hidden;
  }
  .np-faq-a {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--color-brand-muted);
    margin: 0;
    padding: 0 0 1.25rem;
    max-width: 64ch;
  }
  /* subtle open animation */
  .np-faq[open] .np-faq-a { animation: np-faq-in 0.3s ease-out; }
  @keyframes np-faq-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .np-faq[open] .np-faq-a { animation: none; }
  }
</style>

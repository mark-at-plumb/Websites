---
const lines = [
  'Lic. #333997',
  'Master Plumber South Australia',
  'ABN 52 668 135 886',
  'Lifetime Labour Warranty',
  '500+ 5-star reviews',
];
---

<section class="np-creds np-section np-reveal">
  <div class="np-wrap">
    <div class="np-sec-head">
      <p class="np-marker">05 / Credentials</p>
      <h2 class="np-h2">Licensed, insured, accountable</h2>
    </div>
    <div class="np-rule"></div>
    <p class="np-creds-block">
      {lines.map((l, i) => (
        <Fragment>
          <span class="np-creds-item">{l}</span>
          {i < lines.length - 1 && <span class="np-creds-sep" aria-hidden="true"> · </span>}
        </Fragment>
      ))}
    </p>
  </div>
</section>

<style>
  .np-creds-block {
    margin: 2rem 0 0;
    font-family: var(--font-heading);
    font-variation-settings: 'opsz' 30;
    font-weight: 500;
    font-size: clamp(1.25rem, 2.4vw, 1.85rem);
    line-height: 1.45;
    color: var(--color-brand-text);
  }
  .np-creds-item { white-space: nowrap; }
  .np-creds-sep { color: var(--color-brand-primary); padding: 0 0.25em; }
</style>

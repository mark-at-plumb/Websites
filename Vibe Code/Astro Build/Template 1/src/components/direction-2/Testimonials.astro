---
const quotes = [
  {
    quote: 'They turned up within the hour on a Sunday when our hot water tank burst. Fixed the price before they started. No surprises.',
    name: 'Margaret R.',
    suburb: 'Happy Valley',
    date: 'March 2026',
  },
  {
    quote: 'Honest and tidy. He explained what was wrong with our drain, showed me on the camera, and the relining held up perfectly.',
    name: 'David T.',
    suburb: 'Happy Valley',
    date: 'January 2026',
  },
  {
    quote: 'We have used them three times now. Same plumber each time, always on time, always sorted properly. You cannot ask for more.',
    name: 'Jenny & Paul S.',
    suburb: 'Aberfoyle Park',
    date: 'November 2025',
  },
];
---

<section class="np-reviews np-section np-reveal" id="reviews">
  <div class="np-wrap">
    <div class="np-sec-head">
      <p class="np-marker">04 / What Locals Say</p>
      <h2 class="np-h2">From your neighbours</h2>
    </div>

    <div class="np-rule"></div>

    <div class="np-rev-grid">
      {quotes.map((q) => (
        <figure class="np-rev">
          <blockquote class="np-rev-quote">
            <span class="np-rev-mark" aria-hidden="true">&ldquo;</span>{q.quote}
          </blockquote>
          <figcaption class="np-rev-cap">
            <span class="np-rev-name">{q.name}</span>
            <span class="np-rev-meta">{q.suburb} · {q.date}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .np-rev-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 2rem;
  }
  .np-rev {
    margin: 0;
    padding: 0 1.75rem;
    border-left: 1px solid color-mix(in srgb, var(--color-brand-primary) 30%, transparent);
    display: flex;
    flex-direction: column;
  }
  .np-rev:first-child { padding-left: 0; border-left: none; }
  .np-rev-quote {
    margin: 0;
    position: relative;
    font-family: var(--font-heading);
    font-style: italic;
    font-variation-settings: 'opsz' 36;
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1.32;
    color: var(--color-brand-text);
    flex: 1;
  }
  .np-rev-mark {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-brand-primary);
    font-size: 2.6rem;
    line-height: 0;
    margin-right: 0.12em;
    vertical-align: -0.35em;
  }
  .np-rev-cap {
    margin-top: 1.25rem;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in srgb, var(--color-brand-primary) 40%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .np-rev-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-brand-text);
  }
  .np-rev-meta {
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-muted);
  }

  /* pull-quote fade + slight scale */
  .np-rev { opacity: 0; transform: scale(0.97); }
  .np-reveal.is-visible .np-rev {
    animation: np-quote-in 0.6s ease-out forwards;
  }
  .np-reveal.is-visible .np-rev:nth-child(2) { animation-delay: 0.1s; }
  .np-reveal.is-visible .np-rev:nth-child(3) { animation-delay: 0.2s; }
  @keyframes np-quote-in { to { opacity: 1; transform: scale(1); } }

  @media (max-width: 820px) {
    .np-rev-grid { grid-template-columns: 1fr; gap: 1.75rem; }
    .np-rev { padding: 1.5rem 0 0; border-left: none; border-top: 1px solid color-mix(in srgb, var(--color-brand-primary) 30%, transparent); }
    .np-rev:first-child { padding-top: 0; border-top: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .np-rev { opacity: 1; transform: none; }
    .np-reveal.is-visible .np-rev { animation: none; }
  }
</style>

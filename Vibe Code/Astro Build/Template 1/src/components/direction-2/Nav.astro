---
const phone = '(08) 8000 0000';
---

<nav class="np-nav" id="np-nav">
  <div class="np-nav-inner">
    <a href="#top" class="np-logo">Plumber Happy&nbsp;Valley</a>
    <div class="np-nav-right">
      <ul class="np-nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#local">Local Knowledge</a></li>
        <li><a href="#reviews">Reviews</a></li>
        <li><a href="#faqs">FAQs</a></li>
      </ul>
      <a class="np-nav-phone" href={`tel:${phone.replace(/[^\d+]/g, '')}`}>{phone}</a>
    </div>
  </div>
</nav>

<style>
  .np-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-brand-bg);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .np-nav.is-scrolled {
    border-bottom: 1px solid color-mix(in srgb, var(--color-brand-primary) 40%, transparent);
  }
  .np-nav-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0.85rem 2rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .np-logo {
    font-family: var(--font-heading);
    font-optical-sizing: auto;
    font-variation-settings: 'opsz' 30;
    font-weight: 600;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
    color: var(--color-brand-text);
    text-decoration: none;
  }
  .np-nav-right {
    display: flex;
    align-items: baseline;
    gap: 1.75rem;
  }
  .np-nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: baseline;
  }
  .np-nav-links li { position: relative; }
  .np-nav-links li + li {
    margin-left: 1.1rem;
    padding-left: 1.1rem;
  }
  /* hairline rule motif between nav items */
  .np-nav-links li + li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 0.85em;
    width: 1px;
    background: color-mix(in srgb, var(--color-brand-primary) 40%, transparent);
  }
  .np-nav-links a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brand-text);
    text-decoration: none;
    opacity: 0.78;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .np-nav-links a:hover { opacity: 1; color: var(--color-brand-primary); }
  .np-nav-phone {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-brand-primary);
    text-decoration: none;
    white-space: nowrap;
  }
  .np-nav-phone:hover { color: var(--color-brand-secondary); }

  @media (max-width: 860px) {
    .np-nav-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; padding: 0.7rem 1.25rem; }
    .np-nav-right { width: 100%; justify-content: space-between; flex-wrap: wrap; gap: 0.6rem 1rem; }
    .np-nav-links { flex-wrap: wrap; }
  }
  @media (max-width: 520px) {
    .np-nav-links { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('np-nav');
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle('is-scrolled', window.scrollY > 30);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

---
// Sticky nav framed by the 2px black rule motif. Black top border always;
// a black bottom border draws in once the page scrolls past 30px.
---
<header class="tm-nav" id="tm-nav">
  <div class="tm-nav__topline" aria-hidden="true"></div>
  <div class="tm-nav__inner">
    <a href="#top" class="tm-nav__brand">Plumber Happy&nbsp;Valley</a>
    <nav class="tm-nav__links" aria-label="Primary">
      <a href="#services">Services</a>
      <a href="#credentials">Credentials</a>
      <a href="#areas">Service Area</a>
      <a href="#faqs">FAQs</a>
    </nav>
    <div class="tm-nav__cta">
      <a href="tel:0880000000" class="tm-nav__phone">
        <span class="tm-nav__phone-label">Emergency?</span>
        Call (08)&nbsp;8000&nbsp;0000
      </a>
      <a href="#quote" class="tm-btn tm-btn--outline tm-nav__quote">Get a Quote</a>
    </div>
  </div>
  <div class="tm-nav__botline" aria-hidden="true"></div>
</header>

<style>
  .tm-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-brand-bg);
  }
  .tm-nav__topline {
    height: 2px;
    background: var(--color-brand-text);
  }
  .tm-nav__botline {
    height: 2px;
    background: var(--color-brand-text);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .tm-nav.is-scrolled .tm-nav__botline {
    transform: scaleX(1);
  }
  .tm-nav__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .tm-nav__brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: var(--color-brand-text);
    text-decoration: none;
    white-space: nowrap;
  }
  .tm-nav__links {
    display: flex;
    gap: 1.4rem;
    margin-left: 1rem;
  }
  .tm-nav__links a {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-brand-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .tm-nav__links a:hover {
    color: var(--color-brand-text);
  }
  .tm-nav__cta {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .tm-nav__phone {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    text-decoration: none;
    white-space: nowrap;
  }
  .tm-nav__phone-label {
    color: var(--color-brand-muted);
    font-weight: 500;
    margin-right: 0.35rem;
  }
  @media (max-width: 980px) {
    .tm-nav__links { display: none; }
  }
  @media (max-width: 640px) {
    .tm-nav__phone-label,
    .tm-nav__quote { display: none; }
    .tm-nav__inner { padding: 0.75rem 1rem; gap: 0.75rem; }
  }
</style>

<script>
  const nav = document.getElementById('tm-nav');
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle('is-scrolled', window.scrollY > 30);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

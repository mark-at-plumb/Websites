---
const items = ['Burst Pipes', 'Blocked Drains', 'Gas Leaks', 'No Hot Water', 'Overflowing Toilets', 'Roof Leaks'];
---
<section class="emg" id="quote">
  <div class="emg__inner">
    <div class="emg__copy">
      <span class="emg__eyebrow"><span class="emg__pulse"></span>We answer 24/7</span>
      <h2 class="reveal">Emergency Plumber Happy Valley, We Answer 24/7</h2>
      <p class="reveal">
        Plumbing emergencies don't wait for business hours, and neither do we. Call us any time,
        any day, and a licensed local plumber will be on the way. No answering machines. No call
        centres. Just us.
      </p>
      <a class="emg__call reveal" href="tel:0880000000">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1Z" fill="currentColor"/></svg>
        Call (08) 8000 0000
      </a>
    </div>
    <ul class="emg__grid">
      {items.map((i) => (
        <li class="reveal"><span class="emg__tick">!</span>{i}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .emg { background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-accent)); color: #fff; padding: clamp(64px,8vw,100px) 0; }
  .emg__inner { max-width: 1140px; margin: 0 auto; padding: 0 clamp(16px,4vw,40px); display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(36px,5vw,72px); align-items: center; }
  .emg__eyebrow { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-body); font-weight: 700; text-transform: uppercase; letter-spacing: .14em; font-size: 12px; background: rgba(26,46,68,.18); padding: 7px 14px; border-radius: 999px; margin-bottom: 18px; }
  .emg__pulse { width: 8px; height: 8px; border-radius: 50%; background: #fff; animation: emgPulse 1.6s ease-out infinite; }
  @keyframes emgPulse { 0% { box-shadow: 0 0 0 0 rgba(255,255,255,.7); } 70% { box-shadow: 0 0 0 9px rgba(255,255,255,0); } 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); } }
  .emg__copy h2 { font-family: var(--font-heading); font-weight: 900; letter-spacing: -.03em; line-height: 1.05; font-size: clamp(28px,3.4vw,42px); margin: 0 0 16px; }
  .emg__copy p { font-family: var(--font-body); font-size: 17px; line-height: 1.7; color: rgba(255,255,255,.92); max-width: 48ch; margin: 0 0 28px; }
  .emg__call { display: inline-flex; align-items: center; gap: 10px; background: var(--color-brand-secondary); color: #fff; font-family: var(--font-heading); font-weight: 800; font-size: 18px; padding: 16px 26px; border-radius: 12px; text-decoration: none; box-shadow: 0 14px 30px rgba(26,46,68,.3); transition: transform .25s ease, box-shadow .25s ease; }
  .emg__call:hover { transform: translateY(-3px); box-shadow: 0 22px 44px rgba(26,46,68,.42); }
  .emg__grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .emg__grid li { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,.16); border: 1px solid rgba(255,255,255,.25); border-radius: 10px; padding: 16px 18px; font-family: var(--font-heading); font-weight: 700; font-size: 15px; }
  .emg__tick { display: grid; place-items: center; width: 26px; height: 26px; flex: none; border-radius: 50%; background: var(--color-brand-secondary); color: var(--color-brand-accent); font-weight: 900; }
  @media (max-width: 820px) { .emg__inner { grid-template-columns: 1fr; } }
  @media (max-width: 420px) { .emg__grid { grid-template-columns: 1fr; } }
  @media (prefers-reduced-motion: reduce) { .emg__pulse { animation: none; } }
</style>

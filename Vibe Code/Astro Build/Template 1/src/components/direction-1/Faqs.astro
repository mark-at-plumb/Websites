---
import SectionHead from './SectionHead.astro';
const faqs = [
  { q: 'Do you really answer the phone 24/7?', a: 'Yes. We answer calls any time of day, on weekends and public holidays. You get a real local plumber, not an answering service.' },
  { q: 'How does your fixed upfront pricing work?', a: 'We look at the job, then give you a set price before we start. You agree to it first. The price we quote is the price you pay, with no hourly surprises.' },
  { q: 'What does the Lifetime Labour Warranty cover?', a: 'It covers our workmanship for life. If the work we did ever fails, we come back and fix it at no cost to you.' },
  { q: 'Are you licensed and insured?', a: 'We are. We hold Lic. #333997 and carry $5M public liability cover. We are also accredited with Master Plumbers South Australia.' },
  { q: 'My home in Happy Valley is older. Can you help?', a: 'Absolutely. We work on older Happy Valley homes all the time, including those with cast-iron and earthenware pipes. A camera inspection helps us see what is going on.' },
  { q: 'Do you offer any discounts?', a: 'Yes. New customers get $50 off their first service, and we offer a 10% discount for pensioners. Just mention it when you call.' },
];
---
<section class="faq" id="faqs">
  <div class="faq__inner">
    <SectionHead eyebrow="Good questions" title="Happy Valley Plumbing FAQs" align="center" />
    <div class="faq__list">
      {faqs.map((f, i) => (
        <div class="faq__item reveal" style={`--rd:${i * 60}ms`}>
          <button class="faq__q" aria-expanded="false">
            <span>{f.q}</span>
            <span class="faq__icon" aria-hidden="true"></span>
          </button>
          <div class="faq__a"><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding: clamp(72px,9vw,116px) 0; }
  .faq__inner { max-width: 820px; margin: 0 auto; padding: 0 clamp(16px,4vw,40px); }
  .faq__list { display: flex; flex-direction: column; gap: 12px; }
  .faq__item { background: #fff; border: 1px solid rgba(26,46,68,.08); border-radius: 10px; box-shadow: 0 8px 22px rgba(26,46,68,.05); overflow: hidden; }
  .faq__q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; background: none; border: 0; cursor: pointer; padding: 20px 24px; text-align: left; font-family: var(--font-heading); font-weight: 700; font-size: 16px; color: var(--color-brand-secondary); }
  .faq__icon { position: relative; width: 18px; height: 18px; flex: none; }
  .faq__icon::before, .faq__icon::after { content: ''; position: absolute; background: var(--color-brand-primary); border-radius: 2px; transition: transform .3s ease; }
  .faq__icon::before { top: 8px; left: 0; width: 18px; height: 2.5px; }
  .faq__icon::after { left: 8px; top: 0; width: 2.5px; height: 18px; }
  .faq__q[aria-expanded="true"] .faq__icon::after { transform: scaleY(0); }
  .faq__a { max-height: 0; overflow: hidden; transition: max-height .35s ease; }
  .faq__a p { padding: 0 24px 22px; margin: 0; font-family: var(--font-body); font-size: 15px; line-height: 1.7; color: #51606e; }
  @media (prefers-reduced-motion: reduce) { .faq__a { transition: none; } }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      const panel = btn.nextElementSibling as HTMLElement;
      btn.setAttribute('aria-expanded', String(!open));
      panel.style.maxHeight = open ? '0px' : panel.scrollHeight + 'px';
    });
  });
</script>

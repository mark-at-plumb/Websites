---
import Pipe from './Pipe.astro';
const creds = [
  { k: 'Licence', v: 'Lic. #333997' },
  { k: 'Registered business', v: 'ABN 52 668 135 886' },
  { k: 'Accreditation', v: 'Master Plumber South Australia' },
  { k: 'Reputation', v: '500+ 5-star reviews' },
  { k: 'Insurance', v: '$5M public liability cover' },
];
---
<section class="cred">
  <div class="cred__inner">
    <div class="cred__head">
      <span class="cred__eyebrow"><Pipe width="26px" color="var(--color-brand-accent)" />Licensed and insured</span>
      <h2 class="reveal">The Paperwork, Done Properly</h2>
      <p class="reveal">We're a fully licensed and insured Adelaide plumbing business. Here's the proof.</p>
    </div>
    <ul class="cred__list">
      {creds.map((c, i) => (
        <li class="reveal" style={`--rd:${i * 70}ms`}>
          <span class="cred__k">{c.k}</span>
          <span class="cred__v">{c.v}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .cred { background: var(--color-brand-secondary); color: #fff; padding: clamp(64px,8vw,104px) 0; }
  .cred__inner { max-width: 1040px; margin: 0 auto; padding: 0 clamp(16px,4vw,40px); display: grid; grid-template-columns: 1fr 1.3fr; gap: clamp(36px,5vw,72px); align-items: center; }
  .cred__eyebrow { display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: .15em; font-size: 12px; color: var(--color-brand-accent); margin-bottom: 16px; }
  .cred__head h2 { font-family: var(--font-heading); font-weight: 900; letter-spacing: -.03em; font-size: clamp(28px,3.4vw,42px); line-height: 1.05; margin: 0 0 14px; }
  .cred__head p { font-family: var(--font-body); font-size: 16px; line-height: 1.7; color: rgba(255,255,255,.74); margin: 0; max-width: 36ch; }
  .cred__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .cred__list li { display: flex; flex-direction: column; gap: 4px; background: rgba(255,255,255,.05); border-left: 4px solid var(--color-brand-primary); border-radius: 8px; padding: 16px 20px; }
  .cred__k { font-family: var(--font-body); font-size: 12px; text-transform: uppercase; letter-spacing: .1em; color: var(--color-brand-muted); }
  .cred__v { font-family: var(--font-heading); font-weight: 800; font-size: 18px; color: #fff; }
  @media (max-width: 760px) { .cred__inner { grid-template-columns: 1fr; } }
</style>

---
import SectionHead from './SectionHead.astro';
const services = [
  { t: 'General Plumbing', d: 'Repairs, installs and maintenance for every part of your home.', icon: 'wrench' },
  { t: 'Emergency Plumbing', d: 'Burst pipes and urgent leaks handled fast, 24 hours a day.', icon: 'alert' },
  { t: 'Blocked Drains', d: 'We clear blockages and find the cause so it stays clear.', icon: 'drain' },
  { t: 'Hot Water Systems', d: 'Repairs and replacements for gas, electric and heat pump units.', icon: 'flame' },
  { t: 'Leaking Taps', d: 'We stop the drip and the wasted water, the same day.', icon: 'drop' },
  { t: 'Toilet Repairs', d: 'Running, blocked or broken toilets fixed properly first time.', icon: 'toilet' },
  { t: 'Gas Fitting', d: 'Licensed gas work for appliances, lines and safety checks.', icon: 'gas' },
  { t: 'CCTV Drain Inspection', d: 'Camera inspections that show exactly what is going on underground.', icon: 'camera' },
  { t: 'Pipe Relining', d: 'We repair damaged pipes without digging up your whole yard.', icon: 'pipe' },
];
const icons: Record<string, string> = {
  wrench: '<path d="M14 6a3.5 3.5 0 0 0 4.6 4.6L21 13l-8 8-8-8 2.4-2.4A3.5 3.5 0 0 0 12 6"/>',
  alert: '<path d="M12 4l9 16H3Z"/><path d="M12 10v4"/><path d="M12 17h.01"/>',
  drain: '<circle cx="12" cy="12" r="8"/><path d="M12 4v16M4 12h16M7 7l10 10M17 7L7 17"/>',
  flame: '<path d="M12 3c2 4 5 5 5 9a5 5 0 0 1-10 0c0-2 1-3 2-4 .5 2 1.5 2 1.5 2C11 9 12 6 12 3Z"/>',
  drop: '<path d="M12 3c4 5 6 7 6 10a6 6 0 0 1-12 0c0-3 2-5 6-10Z"/>',
  toilet: '<path d="M6 4h8v6a4 4 0 0 1-8 0Z"/><path d="M9 14l-1 6h4l-1-6"/>',
  gas: '<rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 7h6M9 11h6"/>',
  camera: '<rect x="3" y="7" width="14" height="11" rx="2"/><path d="M17 11l4-2v7l-4-2"/>',
  pipe: '<path d="M4 8h9a4 4 0 0 1 4 4v8"/><path d="M2 8h2M4 6v4M17 18h6"/>',
};
---
<section class="svc" id="services">
  <div class="svc__inner">
    <SectionHead eyebrow="What we do" title="Our Plumbing Services in Happy Valley" align="center" />
    <p class="svc__intro reveal">
      From a dripping tap to a midnight burst pipe, we cover the lot for Happy Valley homes.
      Every job is licensed, fixed-price and backed by our Lifetime Labour Warranty.
    </p>
    <div class="svc__grid">
      {services.map((s, i) => (
        <a class="svc__card reveal" href="#quote" style={`--rd:${(i % 3) * 80}ms`}>
          <span class="svc__icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
          </span>
          <h3>{s.t}</h3>
          <p>{s.d}</p>
          <span class="svc__more">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .svc { padding: clamp(72px,9vw,120px) 0; background: var(--color-brand-surface); }
  .svc__inner { max-width: 1140px; margin: 0 auto; padding: 0 clamp(16px,4vw,40px); }
  .svc__intro { text-align: center; max-width: 60ch; margin: -18px auto 44px; font-family: var(--font-body); font-size: 17px; line-height: 1.7; color: #51606e; }
  .svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .svc__card {
    display: block; background: #fff; border-radius: 10px; padding: 28px 26px; text-decoration: none;
    box-shadow: 0 10px 26px rgba(26,46,68,.07); border: 1px solid rgba(26,46,68,.05);
    transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s ease;
  }
  .svc__card:nth-child(even) { transform: translateY(-4px); }
  .svc__card:nth-child(odd) { transform: translateY(4px); }
  .svc__card:hover { transform: translateY(-10px); box-shadow: 0 26px 50px rgba(26,46,68,.16); }
  .svc__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 12px; background: var(--color-brand-secondary); color: var(--color-brand-accent); margin-bottom: 18px; }
  .svc__card h3 { font-family: var(--font-heading); font-weight: 800; font-size: 18px; letter-spacing: -.01em; color: var(--color-brand-secondary); margin: 0 0 9px; }
  .svc__card p { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #51606e; margin: 0 0 16px; }
  .svc__more { font-family: var(--font-body); font-weight: 700; font-size: 13px; color: var(--color-brand-primary); }

  @media (max-width: 900px) { .svc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc__grid { grid-template-columns: 1fr; } .svc__card:nth-child(even), .svc__card:nth-child(odd) { transform: none; } }
</style>

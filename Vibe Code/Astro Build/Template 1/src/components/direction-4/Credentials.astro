---
const creds = [
  { k: 'Licence', v: '#333997' },
  { k: 'ABN', v: '52 668 135 886' },
  { k: 'Insurance', v: 'Fully insured' },
  { k: 'Warranty', v: 'Lifetime labour' },
];
---
<section class="cred sec">
  <div class="wrap">
    <div class="cred__box reveal">
      <span class="cred__mark" aria-hidden="true"></span>
      <div class="cred__copy">
        <h2>Licensed, insured, and accountable.</h2>
        <p>The credentials behind every job. No shortcuts, no grey areas, paperwork on request.</p>
      </div>
      <ul class="cred__list">
        {creds.map((c) => (
          <li>
            <span class="cred__k">{c.k}</span>
            <span class="cred__v">{c.v}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .cred { background: var(--color-brand-bg); }
  .cred__box {
    position: relative; overflow: hidden;
    display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(28px,5vw,56px); align-items: center;
    background: var(--color-brand-secondary); border-radius: var(--radius);
    padding: clamp(32px,5vw,52px); box-shadow: var(--shadow-2);
  }
  .cred__mark {
    position: absolute; top: -20px; left: -20px; width: 130px; height: 130px; pointer-events: none;
    background-image: repeating-linear-gradient(45deg, var(--color-brand-accent) 0, var(--color-brand-accent) 1px, transparent 1px, transparent 10px);
    opacity: .14;
  }
  .cred__copy { position: relative; }
  .cred__copy h2 { font-family: var(--font-heading); font-weight: 800; letter-spacing: -.025em; font-size: clamp(24px,2.8vw,34px); line-height: 1.12; color: #fff; margin: 0 0 12px; }
  .cred__copy p { font-family: var(--font-body); font-size: 15px; line-height: 1.65; color: rgba(255,255,255,.74); margin: 0; max-width: 34ch; }
  .cred__list { position: relative; list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .cred__list li {
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12);
    border-left: 3px solid var(--color-brand-accent); border-radius: var(--radius); padding: 16px 18px;
  }
  .cred__k { display: block; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: .1em; font-size: 11px; color: var(--color-brand-accent); margin-bottom: 5px; }
  .cred__v { display: block; font-family: var(--font-heading); font-weight: 700; font-size: 17px; color: #fff; }

  @media (max-width: 760px) { .cred__box { grid-template-columns: 1fr; } }
  @media (max-width: 420px) { .cred__list { grid-template-columns: 1fr; } }
</style>

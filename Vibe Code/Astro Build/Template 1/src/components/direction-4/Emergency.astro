---
const items = [
  'Burst pipes and major leaks',
  'Blocked or overflowing toilets',
  'No hot water',
  'Gas leaks and odours',
  'Sewer backups',
  'Storm and flood damage',
];
---
<section class="emerg">
  <img class="emerg__bg" src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1400&q=80&fit=crop&crop=center" alt="A plumber responding to an after-hours emergency call in Happy Valley" loading="lazy" />
  <div class="emerg__texture" aria-hidden="true"></div>
  <div class="emerg__inner wrap">
    <div class="emerg__copy reveal">
      <span class="emerg__eyebrow">24/7 Emergency</span>
      <h2>A real plumber, on the way, any hour.</h2>
      <p>
        Plumbing emergencies don't keep business hours. Call us day or night and you'll speak to
        a licensed plumber, not an answering service. We'll talk you through making it safe, then
        get a van to your door fast.
      </p>
      <a class="btn btn--emerg" href="tel:0880000000">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1Z" fill="currentColor"/></svg>
        Call (08) 8000 0000
      </a>
    </div>
    <ul class="emerg__list reveal" style="--rd:120ms">
      {items.map((it) => (
        <li><span class="emerg__tick" aria-hidden="true"></span>{it}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .emerg { position: relative; background: var(--color-brand-primary); overflow: hidden; }
  .emerg__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; opacity: .18; }
  .emerg__texture {
    position: absolute; inset: 0; pointer-events: none; opacity: .07; z-index: 1;
    background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 1px, transparent 12px);
  }
  .emerg__inner {
    position: relative; z-index: 1; display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(32px,5vw,64px); align-items: center;
    padding-top: clamp(56px,7vw,88px); padding-bottom: clamp(56px,7vw,88px);
  }
  .emerg__eyebrow {
    display: inline-block; font-family: var(--font-body); font-weight: 600; text-transform: uppercase;
    letter-spacing: .16em; font-size: 12px; color: rgba(255,255,255,.85);
    border: 1px solid rgba(255,255,255,.4); padding: 6px 12px; border-radius: 999px; margin-bottom: 18px;
  }
  .emerg__copy h2 { font-family: var(--font-heading); font-weight: 800; letter-spacing: -.025em; font-size: clamp(26px,3.2vw,40px); line-height: 1.1; color: #fff; margin: 0 0 16px; max-width: 16ch; }
  .emerg__copy p { font-family: var(--font-body); font-size: 15.5px; line-height: 1.7; color: rgba(255,255,255,.88); margin: 0 0 26px; max-width: 46ch; }
  .btn--emerg { background: #fff; color: var(--color-brand-primary); font-size: 17px; padding: 15px 26px; box-shadow: 0 8px 22px rgba(0,0,0,.18); }
  .btn--emerg:hover { transform: scale(1.02); background: #f3fbff; }

  .emerg__list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .emerg__list li {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-body); font-weight: 500; font-size: 14px; color: #fff;
    background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.18);
    padding: 13px 15px; border-radius: var(--radius);
  }
  .emerg__tick { width: 10px; height: 10px; flex: none; border-bottom: 2px solid #fff; border-right: 2px solid #fff; transform: rotate(45deg) translateY(-1px); }

  @media (max-width: 820px) { .emerg__inner { grid-template-columns: 1fr; } }
  @media (max-width: 460px) { .emerg__list { grid-template-columns: 1fr; } }
</style>

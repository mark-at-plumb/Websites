---
import SectionHead from './SectionHead.astro';
const rows = [
  ['Fixed upfront pricing', true, false],
  ['Lifetime labour warranty', true, false],
  ['Same team start to finish', true, false],
  ['Licensed and fully insured', true, 'sometimes'],
  ['24/7 emergency callout', true, 'sometimes'],
  ['Local to the southern suburbs', true, false],
];
---
<section class="cmp sec">
  <div class="wrap">
    <SectionHead eyebrow="The Difference" title="How we compare" align="center" />
    <div class="cmp__table reveal">
      <span class="cmp__corner" aria-hidden="true"></span>
      <div class="cmp__head">
        <span>What matters</span>
        <span class="cmp__us">Plumber Happy Valley</span>
        <span class="cmp__them">Typical operator</span>
      </div>
      {rows.map((r, i) => (
        <div class="cmp__row reveal" style={`--rd:${i * 40}ms`}>
          <span class="cmp__feat">{r[0]}</span>
          <span class="cmp__cell">
            <span class="mark mark--yes" aria-label="Yes">&#10003;</span>
          </span>
          <span class="cmp__cell">
            {r[2] === true && <span class="mark mark--yes" aria-label="Yes">&#10003;</span>}
            {r[2] === false && <span class="mark mark--no" aria-label="No">&times;</span>}
            {r[2] === 'sometimes' && <span class="mark mark--maybe">Varies</span>}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cmp { background: var(--color-brand-surface); }
  .cmp__table {
    position: relative; max-width: 860px; margin: 0 auto; background: #fff;
    border: 1px solid rgba(15,23,42,.08); border-radius: var(--radius);
    box-shadow: var(--shadow-1); overflow: hidden;
  }
  .cmp__corner {
    position: absolute; top: 0; right: 0; width: 56px; height: 56px; pointer-events: none;
    background-image: repeating-linear-gradient(45deg, var(--color-brand-primary) 0, var(--color-brand-primary) 1px, transparent 1px, transparent 7px);
    opacity: .22; clip-path: polygon(100% 0, 0 0, 100% 100%);
  }
  .cmp__head, .cmp__row {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr; align-items: center;
    padding: 16px 22px; border-left: 3px solid transparent;
  }
  .cmp__head {
    background: var(--color-brand-secondary); color: #fff;
    font-family: var(--font-heading); font-weight: 600; font-size: 13.5px;
  }
  .cmp__head .cmp__us { color: var(--color-brand-accent); text-align: center; }
  .cmp__head .cmp__them { color: rgba(255,255,255,.65); text-align: center; }
  .cmp__row { border-top: 1px solid rgba(15,23,42,.06); transition: background .15s ease, border-color .15s ease; }
  .cmp__row:hover { background: var(--color-brand-surface); border-left-color: var(--color-brand-primary); }
  .cmp__feat { font-family: var(--font-body); font-weight: 500; font-size: 14.5px; color: var(--color-brand-secondary); }
  .cmp__cell { text-align: center; }
  .mark { display: inline-grid; place-items: center; }
  .mark--yes { width: 26px; height: 26px; border-radius: 50%; background: rgba(14,116,144,.12); color: var(--color-brand-primary); font-weight: 700; font-size: 15px; }
  .mark--no { width: 26px; height: 26px; border-radius: 50%; background: rgba(100,116,139,.10); color: var(--color-brand-muted); font-weight: 700; font-size: 17px; }
  .mark--maybe { font-family: var(--font-body); font-size: 12px; font-weight: 600; color: var(--color-brand-muted); }

  @media (max-width: 560px) {
    .cmp__head, .cmp__row { grid-template-columns: 1.4fr .8fr .8fr; padding: 14px; }
    .cmp__head { font-size: 11.5px; }
    .cmp__feat { font-size: 13px; }
  }
</style>

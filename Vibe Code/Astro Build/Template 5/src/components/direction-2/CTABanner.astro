---
const benefits = ['$0 Call-Out Fee','Upfront Pricing','Same-Day Service','Fully Licensed'];
---
<section id="contact" class="relative bg-brand-accent reveal scroll-mt-24 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 opacity-10" aria-hidden="true" style="background-image:repeating-linear-gradient(135deg,#000 0 1px,transparent 1px 26px)"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">
      <div>
        <div class="flex items-center gap-3 text-white/80 mb-5">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-white"></span>
          </span>
          <span class="text-[11px] font-bold uppercase tracking-[0.28em]">We’re Available Now</span>
        </div>
        <h2 class="font-heading font-extrabold text-white text-[clamp(2rem,4.5vw,3.2rem)] leading-[1.02] tracking-tight">
          Got a Plumbing Problem?<br />Let’s Get It Sorted.
        </h2>
        <div class="mt-7 flex flex-wrap gap-x-6 gap-y-2">
          {benefits.map((b) => (
            <div class="flex items-center gap-2 text-white font-semibold text-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </div>
          ))}
        </div>
      </div>
      <div class="flex flex-col sm:flex-row lg:flex-col gap-3 lg:items-stretch">
        <a href="tel:0880005050" class="flex-1 inline-flex flex-col items-center justify-center gap-0.5 bg-brand-secondary text-white px-6 py-5 rounded-sm hover:bg-brand-primary transition-colors">
          <span class="text-[11px] uppercase tracking-[0.2em] text-white/60">Call 24/7</span>
          <span class="font-heading font-extrabold text-2xl tabular-nums">(08) 8000 5050</span>
        </a>
        <a href="#" class="flex-1 inline-flex items-center justify-center bg-white text-brand-secondary px-6 py-5 rounded-sm font-bold uppercase tracking-[0.08em] text-sm hover:bg-brand-surface transition-colors">
          Book Online
        </a>
      </div>
    </div>
  </div>
</section>

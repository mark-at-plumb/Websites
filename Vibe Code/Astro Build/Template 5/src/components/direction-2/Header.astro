---
const nav = [
  { label: 'Services', href: '#services' },
  { label: 'Why Us', href: '#why-us' },
  { label: 'Areas', href: '#areas' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Contact', href: '#contact' },
];
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300 border-b border-transparent">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-3">
      <a href="#top" class="flex items-center gap-2 shrink-0">
        <img src="/images/logo.webp" alt="Aptec Plumbing" class="h-10 w-auto" width="160" height="40" />
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Primary">
        {nav.map((item) => (
          <a
            href={item.href}
            class="nav-link text-[13px] font-semibold uppercase tracking-[0.14em] text-brand-secondary/80 hover:text-brand-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="tel:0880005050"
          class="hidden sm:flex flex-col items-end leading-tight group"
        >
          <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-brand-muted">24/7 Line</span>
          <span class="text-[15px] font-bold text-brand-secondary group-hover:text-brand-primary transition-colors tabular-nums">(08) 8000 5050</span>
        </a>
        <a
          href="#"
          class="relative inline-flex items-center gap-2 bg-brand-accent px-5 py-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-white rounded-sm hover:brightness-95 transition-all corner-bracket-btn"
        >
          Book Online
        </a>
        <button id="mobile-toggle" class="lg:hidden p-2 text-brand-secondary" aria-label="Open menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-brand-secondary/10 bg-brand-bg">
    <nav class="px-4 py-4 flex flex-col gap-1" aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="mobile-link py-3 px-2 text-sm font-semibold uppercase tracking-[0.12em] text-brand-secondary border-b border-brand-secondary/5">{item.label}</a>
      ))}
      <a href="tel:0880005050" class="mt-3 py-3 text-center font-bold text-brand-secondary border border-brand-secondary/20 rounded-sm">(08) 8000 5050</a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (window.scrollY > 24) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>

<style>
  .h-18 { height: 4.5rem; }
  .header-scrolled {
    background: color-mix(in srgb, var(--color-brand-bg) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom-color: color-mix(in srgb, var(--color-brand-secondary) 12%, transparent);
    box-shadow: 0 1px 0 0 color-mix(in srgb, var(--color-brand-secondary) 6%, transparent);
  }
  .nav-link { position: relative; }
  .nav-link::after {
    content: ''; position: absolute; left: 0; bottom: -6px; height: 2px; width: 0;
    background: var(--color-brand-accent); transition: width 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-link:hover::after { width: 100%; }
</style>

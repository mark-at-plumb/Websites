---
import { Image } from 'astro:assets';
---
<section id="top" class="relative bg-brand-bg pt-36 lg:pt-44 overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-12 items-center pb-12 lg:pb-20">
      <!-- Copy -->
      <div class="relative">
        <div class="hero-stagger" style="--d:0ms">
          <div class="flex items-center gap-3 text-brand-muted mb-6">
            <span class="h-px w-8 bg-brand-accent block"></span>
            <span class="text-[11px] font-bold uppercase tracking-[0.28em]">Licensed Plumber · Lic. #333997</span>
          </div>
        </div>

        <h1 class="hero-stagger font-heading font-extrabold text-brand-secondary leading-[0.98] text-[clamp(2.6rem,6vw,4.6rem)] tracking-tight" style="--d:80ms">
          <span class="inline-flex items-center gap-3 align-middle">
            <span class="text-brand-accent">5★ Rated</span>
          </span>
          <span class="block">$0 Call-Out Fee.</span>
          <span class="block text-brand-primary">No Fuss. Done Right.</span>
        </h1>

        <p class="hero-stagger mt-6 max-w-xl text-[17px] leading-relaxed text-brand-muted" style="--d:160ms">
          Fast, professional and genuinely affordable plumbing for Happy Valley
          and southern Adelaide. Same-day service, upfront pricing, and a fully
          licensed team that turns up when we say we will.
        </p>

        <div class="hero-stagger mt-8 flex flex-col sm:flex-row gap-3" style="--d:240ms">
          <a href="tel:0880005050" class="group inline-flex items-center justify-center gap-2 bg-brand-secondary text-white px-6 py-4 rounded-sm font-bold uppercase tracking-[0.08em] text-sm hover:bg-brand-primary transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (08) 8000 5050
          </a>
          <a href="#" class="inline-flex items-center justify-center gap-2 bg-brand-accent text-white px-6 py-4 rounded-sm font-bold uppercase tracking-[0.08em] text-sm hover:brightness-95 transition-all corner-bracket-btn">
            Book Online
          </a>
        </div>

        <div class="hero-stagger mt-10 flex flex-wrap items-center gap-x-7 gap-y-3 border-t border-brand-secondary/10 pt-6" style="--d:320ms">
          {[
            ['15+', 'Years Family-Owned'],
            ['30–60', 'Min Response'],
            ['24/7', 'Emergency Cover'],
          ].map(([n, l]) => (
            <div class="flex flex-col">
              <span class="font-heading font-extrabold text-2xl text-brand-secondary tabular-nums leading-none">{n}</span>
              <span class="text-[11px] uppercase tracking-[0.14em] text-brand-muted mt-1">{l}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Image with corner brackets -->
      <div class="hero-stagger relative" style="--d:200ms">
        <div class="relative bracket-frame">
          <Image src="/images/Aptec-Hero-Section.webp" alt="Aptec Plumbing technician at work" width={760} height={760} class="w-full h-[clamp(320px,46vw,560px)] object-cover rounded-sm" />
          <!-- Available 24/7 badge -->
          <div class="absolute -bottom-4 left-4 sm:left-6 flex items-center gap-3 bg-brand-secondary text-white px-5 py-3 rounded-sm">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-accent"></span>
            </span>
            <div class="leading-tight">
              <div class="text-[10px] uppercase tracking-[0.2em] text-white/60">Available</div>
              <div class="font-bold text-sm">24/7 — Right Now</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import Eyebrow from './Eyebrow.astro';
import { Image } from 'astro:assets';
const steps = [
  { img: '/images/Process-Step-1.webp', t: 'Give Us a Call', d: 'Ring our 24/7 line and tell us what’s going on. We’ll book you in — often for the same day.' },
  { img: '/images/Process-Step-2.webp', t: 'We Arrive On Time', d: 'A licensed plumber turns up in the agreed window, assesses the job and quotes upfront before starting.' },
  { img: '/images/Process-Step-3.webp', t: 'Job Done Right', d: 'We complete the work, clean up after ourselves and back it with our 100% satisfaction guarantee.' },
];
---
<section class="bg-brand-bg reveal">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
    <div class="max-w-2xl mb-12">
      <Eyebrow index="11" label="How It Works" />
      <h2 class="mt-4 font-heading font-extrabold text-brand-secondary text-[clamp(1.8rem,4vw,2.7rem)] leading-tight tracking-tight">
        Three Steps. No Surprises.
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {steps.map((s, i) => (
        <div class="relative reveal" style={`--stagger:${i * 120}ms`}>
          <div class="relative bracket-frame">
            <Image src={s.img} alt={s.t} width={480} height={340} class="w-full h-56 object-contain rounded-sm" />
            <span class="absolute top-3 left-3 grid place-items-center h-10 w-10 bg-brand-accent text-white font-heading font-extrabold rounded-sm tabular-nums">0{i + 1}</span>
          </div>
          <h3 class="mt-5 font-heading font-bold text-brand-secondary text-xl">{s.t}</h3>
          <p class="mt-2 text-brand-muted leading-relaxed text-[15px]">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
interface Props {
  index?: string;
  label: string;
  light?: boolean;
}
const { index, label, light = false } = Astro.props;
---
<div class={`flex items-center gap-3 ${light ? 'text-white/70' : 'text-brand-muted'}`}>
  <span class="h-px w-8 bg-brand-accent block"></span>
  {index && <span class="text-[11px] font-bold tabular-nums text-brand-accent tracking-[0.2em]">{index}</span>}
  <span class="text-[11px] font-bold uppercase tracking-[0.28em]">{label}</span>
</div>

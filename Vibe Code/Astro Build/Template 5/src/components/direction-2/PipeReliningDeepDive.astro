---
import Eyebrow from './Eyebrow.astro';
import { Image } from 'astro:assets';
import reliningImg from '../../../public/images/Pipe-Relining (1).webp';
const steps = [
  ['Inspect', 'CCTV maps the damage so we know exactly what we’re dealing with.'],
  ['Clean', 'High-pressure jetting prepares the pipe wall for a perfect bond.'],
  ['Reline', 'A resin-saturated liner is inserted and cured into a new pipe-within-a-pipe.'],
  ['Verify', 'A final camera pass confirms a smooth, structurally sound result.'],
];
---
<section class="relative bg-brand-secondary text-white reveal overflow-hidden">
  <div class="pointer-events-none absolute inset-0 opacity-[0.06]" aria-hidden="true" style="background-image:repeating-linear-gradient(135deg,#fff 0 1px,transparent 1px 22px)"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <Eyebrow index="09" label="Pipe Relining" light />
        <h2 class="mt-4 font-heading font-extrabold text-[clamp(1.8rem,4vw,2.8rem)] leading-tight tracking-tight">
          Fix the Pipe <span class="text-brand-accent">Without Digging Up the Yard</span>
        </h2>
        <p class="mt-4 text-white/70 leading-relaxed max-w-xl">
          No-dig relining repairs cracked and root-damaged pipes from the inside.
          We cure a tough new liner inside your existing pipe — no trenches, no
          torn-up driveways, and a result that outlasts traditional excavation
          at a fraction of the disruption.
        </p>
        <div class="mt-9 grid sm:grid-cols-2 gap-px bg-white/10 border border-white/10 rounded-sm overflow-hidden">
          {steps.map(([t, d], i) => (
            <div class="bg-brand-secondary p-5">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-brand-accent font-bold tabular-nums text-sm">0{i + 1}</span>
                <span class="font-heading font-bold">{t}</span>
              </div>
              <p class="text-[13px] text-white/60 leading-relaxed">{d}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="bracket-frame bracket-light">
        <Image src={reliningImg} alt="No-dig pipe relining in progress" class="w-full h-[clamp(300px,40vw,500px)] object-cover rounded-sm" />
      </div>
    </div>
  </div>
</section>

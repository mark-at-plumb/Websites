---
import Direction1Layout from '../layouts/Direction1Layout.astro';
import Drip from '../components/direction-1/Drip.astro';
import CouponStrip from '../components/direction-1/CouponStrip.astro';
import ProcessSection from '../components/direction-1/ProcessSection.astro';
import { PHONE, PHONE_HREF } from '../data/site';

const regions = [
  { name: 'Happy Valley & Reynella', areas: ['Happy Valley', 'Reynella', 'Old Reynella', 'Woodcroft', 'Sheidow Park'] },
  { name: 'Morphett Vale & Christie Downs', areas: ['Morphett Vale', 'Christie Downs', 'Trott Park'] },
  { name: 'Coastal & Southern Suburbs', areas: ['Hallett Cove', 'Noarlunga', 'Seaford', 'Lonsdale'] },
  { name: 'Hills & Flagstaff', areas: ['Aberfoyle Park', 'Flagstaff Hill', 'O’Halloran Hill'] },
];
---
<Direction1Layout title="Service Areas — Aptec Plumbing" description="Aptec Plumbing services Happy Valley and southern Adelaide, 24/7 — Reynella, Morphett Vale, Hallett Cove, Aberfoyle Park, Noarlunga, Seaford and more.">
  <div id="top">

    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-brand-secondary">
      <div class="pointer-events-none absolute inset-0" style="background: linear-gradient(135deg, #0B2847 0%, #0d3260 40%, #156ECE 100%); opacity: 0.95;"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>

      <div class="relative mx-auto grid max-w-7xl items-center gap-10 px-5 py-14 md:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:py-20">
        <div class="hero-stagger">
          <div class="inline-flex items-center gap-2 rounded-lg border border-brand-accent/40 bg-brand-accent/20 px-3.5 py-1.5 text-xs font-bold text-brand-accent">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.8 6.1 20.8l1.2-6.6L2.5 9l6.6-.9L12 2Z"/></svg>
            5.0 Rating · 236 Reviews
          </div>
          <h1 class="mt-5 font-heading text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-6xl">
            We come to
            <span class="relative inline-block text-brand-accent">
              you, fast.
              <svg class="absolute -bottom-1 left-0 w-full" viewBox="0 0 200 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M2 5c40-5 60 3 100-1s56-4 96 1" stroke="#FF7A1B" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
            Locally based in Happy Valley, our licensed plumbers cover the whole southern corridor — from the coast to the hills. If you're nearby and unsure, just give us a call.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={PHONE_HREF} class="group inline-flex items-center justify-center gap-2.5 skew-btn rounded-lg bg-brand-accent px-7 py-3.5 text-base font-bold text-white shadow-[0_14px_34px_-12px_rgba(255,122,27,0.6)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-accent/90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z" fill="currentColor"/></svg>
              Call {PHONE}
            </a>
            <a href="/contact" class="skew-border-btn inline-flex items-center justify-center border-2 border-white/25 bg-white/10 px-7 py-3.5 text-base font-bold text-white backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-white/50 hover:bg-white/20">
              <span class="btn-inner">Book Online</span>
            </a>
          </div>

          <div class="mt-10 grid grid-cols-1 gap-3 border-t border-white/15 pt-8 sm:grid-cols-3">
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-accent/20 text-brand-accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">$0 Call Out Fee</p>
                <p class="text-xs text-white/60">Clear. Fair. Simple.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="stat-icon stat-icon-clock grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-primary/30 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path class="stat-icon-hand" d="M12 7v5l3.5 2"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Same-Day Service</p>
                <p class="text-xs text-white/60">Fast. Reliable. Today.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center rounded-lg bg-green-400/20 text-green-400">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l7 4v6c0 5-3.5 8.7-7 10C8.5 20.7 5 17 5 12V6l7-4z"/><path d="M9 12l2 2 4-4"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Labour Warranty</p>
                <p class="text-xs text-white/60">T&amp;C may apply.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="hero-img relative">
          <div class="skew-img overflow-hidden shadow-[0_30px_70px_-25px_rgba(0,0,0,0.5)]">
            <img src="/images/Aptec-Hero-Section.webp" alt="Aptec Plumbing team servicing southern Adelaide" class="aspect-[4/5] w-full object-cover sm:aspect-[5/5]" width="640" height="800" />
          </div>
          <div class="absolute -left-3 bottom-6 flex items-center gap-3 rounded-xl bg-brand-bg p-3.5 pr-5 shadow-[0_20px_45px_-18px_rgba(0,0,0,0.5)] ring-1 ring-white/10 sm:-left-6">
            <span class="grid size-11 place-items-center skew-btn rounded-lg bg-brand-accent text-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s-7-4.5-7-11a7 7 0 1 1 14 0c0 6.5-7 11-7 11Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="2"/></svg>
            </span>
            <div>
              <p class="font-heading text-sm font-extrabold leading-tight text-brand-secondary">15+ Suburbs Covered</p>
              <p class="text-xs text-brand-muted">Southern Adelaide locals</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CouponStrip />

    <!-- ============ SUBURB DIRECTORY ============ -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-5 py-16 md:px-6 md:py-20">
        <div class="reveal mx-auto mb-12 max-w-2xl text-center">
          <Drip label="Suburb Directory" align="center" />
          <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight text-brand-secondary sm:text-4xl">Find your suburb</h2>
          <p class="mt-3 text-brand-muted">We cover the entire southern Adelaide corridor — here's a full list of the areas we service.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {regions.map((r) => (
            <div class="reveal overflow-hidden rounded-2xl border border-brand-secondary/10 bg-brand-bg shadow-[0_8px_30px_-12px_rgba(11,40,71,0.15)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_-12px_rgba(11,40,71,0.22)]">
              <div class="border-b border-brand-secondary/8 bg-brand-secondary px-5 py-4">
                <h3 class="font-heading text-sm font-extrabold uppercase tracking-wider text-white">{r.name}</h3>
              </div>
              <ul class="divide-y divide-brand-secondary/6 px-5">
                {r.areas.map((a) => (
                  <li class="flex items-center gap-3 py-3 text-sm text-brand-text">
                    <span class="grid size-5 shrink-0 place-items-center rounded-full bg-brand-primary/10 text-brand-primary">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l4 4L19 7"/></svg>
                    </span>
                    {a}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ PROCESS ============ -->
    <ProcessSection />

    <!-- ============ CONTACT CTA WITH FORM ============ -->
    <section class="relative overflow-hidden bg-brand-primary">
      <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.5) 1px, transparent 0); background-size: 26px 26px;"></div>
      <div class="pointer-events-none absolute -left-20 top-10 size-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="relative mx-auto grid max-w-7xl items-center gap-10 px-5 py-16 md:px-6 md:py-20 lg:grid-cols-2">
        <div class="reveal text-white">
          <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-brand-accent">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor" aria-hidden="true"><path d="M6 0C6 0 1 6.2 1 10a5 5 0 0 0 10 0C11 6.2 6 0 6 0Z"/></svg>
            Don't See Your Suburb?
          </span>
          <h2 class="mt-3 font-heading text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl">Need an expert plumber near you?</h2>
          <p class="mt-4 leading-relaxed text-white/80">We're often able to cover suburbs just outside our core area — send us your details and we'll let you know straight away.</p>
          <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold text-white/90">
            {['$0 call-out (standard hours)', 'Upfront fixed pricing', 'Same-day service'].map((b) => (
              <span class="flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-accent"><path d="M5 12l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</span>
            ))}
          </div>
        </div>
        <form class="reveal rounded-2xl bg-brand-bg p-6 shadow-2xl md:p-8">
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label class="text-sm font-semibold text-brand-secondary" for="area-name">Name</label>
              <input id="area-name" name="name" type="text" required class="mt-1.5 w-full rounded-lg border border-brand-secondary/15 bg-brand-bg px-4 py-2.5 text-sm text-brand-text focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20" />
            </div>
            <div>
              <label class="text-sm font-semibold text-brand-secondary" for="area-phone">Phone</label>
              <input id="area-phone" name="phone" type="tel" required class="mt-1.5 w-full rounded-lg border border-brand-secondary/15 bg-brand-bg px-4 py-2.5 text-sm text-brand-text focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20" />
            </div>
            <div>
              <label class="text-sm font-semibold text-brand-secondary" for="area-suburb">Suburb</label>
              <input id="area-suburb" name="suburb" type="text" required class="mt-1.5 w-full rounded-lg border border-brand-secondary/15 bg-brand-bg px-4 py-2.5 text-sm text-brand-text focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20" />
            </div>
            <div class="sm:col-span-2">
              <label class="text-sm font-semibold text-brand-secondary" for="area-message">What do you need help with?</label>
              <textarea id="area-message" name="message" rows="3" class="mt-1.5 w-full rounded-lg border border-brand-secondary/15 bg-brand-bg px-4 py-2.5 text-sm text-brand-text focus:border-brand-primary focus:outline-none focus:ring-2 focus:ring-brand-primary/20"></textarea>
            </div>
          </div>
          <button type="submit" class="mt-5 w-full skew-btn rounded-lg bg-brand-accent px-7 py-3.5 text-base font-bold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5">
            Check My Suburb
          </button>
        </form>
      </div>
    </section>

  </div>
</Direction1Layout>

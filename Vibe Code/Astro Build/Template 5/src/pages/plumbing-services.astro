---
import Direction1Layout from '../layouts/Direction1Layout.astro';
import Drip from '../components/direction-1/Drip.astro';
import CouponStrip from '../components/direction-1/CouponStrip.astro';
import ProcessSection from '../components/direction-1/ProcessSection.astro';
import ServiceAreaSection from '../components/direction-1/ServiceAreaSection.astro';
import { PHONE, PHONE_HREF } from '../data/site';

const categories = [
  {
    name: 'Drains & Pipes',
    services: [
      { title: 'Blocked Drains', img: '/images/Blocked-Drains.webp', desc: 'Kitchen, bathroom and sewer drains cleared fast.', href: '/blocked-drains' },
      { title: 'Drain Camera Inspection', img: '/images/Drain-Camera-Inspection.webp', desc: 'CCTV pipe inspection to find the exact problem.', href: '/blocked-drains' },
      { title: 'Pipe Relining', img: '/images/Pipe-Relining.webp', desc: 'No-dig pipe repair that lasts decades.', href: '/blocked-drains' },
      { title: 'Water Jetting', img: '/images/Water-Jetting-Aptec-Plumbing.webp', desc: 'High-pressure jetting for stubborn blockages.', href: '/blocked-drains' },
      { title: 'Tree Root Removal', img: '/images/Tree-Root-Removal.webp', desc: 'Root intrusion cleared and pipes restored.', href: '/blocked-drains' },
      { title: 'Stormwater Pits', img: '/images/Stormwater-Pits.webp', desc: 'Stormwater pit clearing, repair and installation.', href: '/blocked-drains' },
      { title: 'Pit Covers', img: '/images/Pit-Covers-1.webp', desc: 'Damaged or sunken pit covers replaced.', href: '/blocked-drains' },
      { title: 'Leak Detection', img: '/images/Pipe-Inspection.webp', desc: 'Find hidden leaks without tearing up floors.', href: '/plumbing-services' },
    ],
  },
  {
    name: 'Taps & Toilets',
    services: [
      { title: 'Leaking Tap Repair', img: '/images/Leaking-Tap-Repair.webp', desc: 'Stop the drip and the wasted water bill.', href: '/plumbing-services' },
      { title: 'Kitchen Mixer Taps', img: '/images/Kitchen-Mixer-Tap.webp', desc: 'Supply and install of kitchen mixer taps.', href: '/plumbing-services' },
      { title: 'Toilet Cistern Repair', img: '/images/Toilet-Cistern-Repair-1.webp', desc: 'Internals rebuilt to stop a running cistern.', href: '/plumbing-services' },
      { title: 'Constantly Running Cistern', img: '/images/Constantly-Running-Cistern.webp', desc: 'Worn valves and seals replaced fast.', href: '/plumbing-services' },
      { title: 'Cistern Replacement', img: '/images/Cistern-Replacement.webp', desc: 'New cistern or full suite fitted same day.', href: '/plumbing-services' },
      { title: 'Blocked Toilet', img: '/images/Blocked-Toilet-Aptec-Plumbing.webp', desc: 'Fast, no-mess blocked toilet clearing.', href: '/blocked-drains' },
    ],
  },
  {
    name: 'Bathroom',
    services: [
      { title: 'Bathroom Drain', img: '/images/Bathroom-Drain.webp', desc: 'Bathroom floor and shower drains cleared.', href: '/blocked-drains' },
      { title: 'Clogged Shower Drain', img: '/images/Clogged-Shower-Drain-Aptec-Plumbing.webp', desc: 'Hair and soap build-up cleared properly.', href: '/blocked-drains' },
      { title: 'Worn Fill Valves', img: '/images/Worn-Fill.webp', desc: 'Upgraded to reliable modern parts.', href: '/plumbing-services' },
    ],
  },
  {
    name: 'Hot Water & Gas',
    services: [
      { title: 'Hot Water Systems', img: '/images/Hot-Water-Replacement.webp', desc: 'Repairs, swaps and same-day replacements.', href: '/plumbing-services' },
      { title: 'Gas Fitting', img: '/images/Gas-Fitting-Service.webp', desc: 'Licensed, safe gas installs and repairs.', href: '/plumbing-services' },
      { title: 'Burst Pipe Repairs', img: '/images/Burst-Pipe-Repair.webp', desc: 'Fast isolation and lasting pipe repairs.', href: '/plumbing-services' },
      { title: 'Emergency Plumbing', img: '/images/Burst-Pipe-Repair.webp', desc: '24/7 rapid response when things go wrong fast.', href: '/plumbing-services' },
    ],
  },
];
---
<Direction1Layout title="Plumbing Services — Aptec Plumbing" description="Full range of plumbing services for Happy Valley and southern Adelaide — drains, taps, toilets, hot water and gas fitting. $0 call-out, upfront pricing, 24/7.">
  <div id="top">

    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-brand-secondary">
      <div class="pointer-events-none absolute inset-0" style="background: linear-gradient(135deg, #0B2847 0%, #0d3260 40%, #156ECE 100%); opacity: 0.95;"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>

      <div class="relative mx-auto grid max-w-7xl items-center gap-10 px-5 py-14 md:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:py-20">
        <div class="hero-stagger">
          <div class="inline-flex items-center gap-2 rounded-lg border border-brand-accent/40 bg-brand-accent/20 px-3.5 py-1.5 text-xs font-bold text-brand-accent">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.8 6.1 20.8l1.2-6.6L2.5 9l6.6-.9L12 2Z"/></svg>
            5.0 Rating · 236 Reviews
          </div>

          <h1 class="mt-5 font-heading text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-6xl">
            Every plumbing job,
            <span class="relative inline-block text-brand-accent">
              done right.
              <svg class="absolute -bottom-1 left-0 w-full" viewBox="0 0 200 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M2 5c40-5 60 3 100-1s56-4 96 1" stroke="#FF7A1B" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </span>
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
            From a dripping tap to a full hot water replacement — one local, licensed team handles it all. Upfront pricing, same-day service, and a labour warranty on every job.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={PHONE_HREF} class="group inline-flex items-center justify-center gap-2.5 skew-btn rounded-lg bg-brand-accent px-7 py-3.5 text-base font-bold text-white shadow-[0_14px_34px_-12px_rgba(255,122,27,0.6)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-accent/90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z" fill="currentColor"/></svg>
              Call {PHONE}
            </a>
            <a href="/contact" class="skew-border-btn inline-flex items-center justify-center border-2 border-white/25 bg-white/10 px-7 py-3.5 text-base font-bold text-white backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-white/50 hover:bg-white/20">
              <span class="btn-inner">Get a Free Quote</span>
            </a>
          </div>

          <div class="mt-10 grid grid-cols-1 gap-3 border-t border-white/15 pt-8 sm:grid-cols-3">
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-accent/20 text-brand-accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">$0 Call Out Fee</p>
                <p class="text-xs text-white/60">Clear. Fair. Simple.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="stat-icon stat-icon-clock grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-primary/30 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path class="stat-icon-hand" d="M12 7v5l3.5 2"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Same-Day Service</p>
                <p class="text-xs text-white/60">Fast. Reliable. Today.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center rounded-lg bg-green-400/20 text-green-400">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l7 4v6c0 5-3.5 8.7-7 10C8.5 20.7 5 17 5 12V6l7-4z"/><path d="M9 12l2 2 4-4"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Labour Warranty</p>
                <p class="text-xs text-white/60">T&amp;C may apply.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="hero-img relative">
          <div class="skew-img overflow-hidden shadow-[0_30px_70px_-25px_rgba(0,0,0,0.5)]">
            <img src="/images/Aptec-Hero-Section.webp" alt="Aptec plumbing team southern Adelaide" class="aspect-[4/5] w-full object-cover sm:aspect-[5/5]" width="640" height="800" />
          </div>
          <div class="absolute -left-3 bottom-6 flex items-center gap-3 rounded-xl bg-brand-bg p-3.5 pr-5 shadow-[0_20px_45px_-18px_rgba(0,0,0,0.5)] ring-1 ring-white/10 sm:-left-6">
            <span class="grid size-11 place-items-center skew-btn rounded-lg bg-brand-accent text-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <p class="font-heading text-sm font-extrabold leading-tight text-brand-secondary">Labour Warranty</p>
              <p class="text-xs text-brand-muted">On every single job</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CouponStrip />

    <!-- ============ SERVICE CATEGORIES ============ -->
    {categories.map((cat) => (
      <section class="bg-brand-bg">
        <div class="mx-auto max-w-7xl px-5 py-14 md:px-6 md:py-16">
          <div class="reveal mb-8">
            <Drip label={cat.name} />
            <h2 class="mt-3 font-heading text-2xl font-extrabold tracking-tight text-brand-secondary sm:text-3xl">{cat.name}</h2>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {cat.services.map((s) => (
              <a href={s.href} class="reveal group overflow-hidden rounded-2xl bg-brand-surface shadow-[0_12px_35px_-24px_rgba(11,40,71,0.4)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_45px_-22px_rgba(11,40,71,0.45)]">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img src={s.img} alt={s.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                </div>
                <div class="p-5">
                  <h3 class="font-heading text-base font-bold text-brand-secondary">{s.title}</h3>
                  <p class="mt-1.5 text-sm leading-snug text-brand-muted">{s.desc}</p>
                  <span class="mt-3 inline-flex items-center gap-1 text-sm font-bold text-brand-primary">
                    Learn more
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- ============ PROCESS ============ -->
    <ProcessSection />

    <!-- ============ SERVICE AREAS ============ -->
    <ServiceAreaSection heading="Plumbing services across southern Adelaide" />

    <!-- ============ CTA BANNER ============ -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/Aptec-Plumbing-1920.webp" alt="" aria-hidden="true" class="h-full w-full object-cover object-center" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(11,40,71,0.93) 0%, rgba(13,50,96,0.88) 50%, rgba(21,110,206,0.82) 100%);"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="relative mx-auto max-w-7xl px-5 py-20 md:px-6 md:py-24">
        <div class="reveal grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="text-white">
            <p class="inline-flex items-center gap-2 rounded-lg border border-brand-accent/40 bg-brand-accent/20 px-3.5 py-1.5 text-xs font-bold text-brand-accent"><span class="inline-block size-2 animate-pulse rounded-full bg-brand-accent"></span> We're available now</p>
            <h2 class="mt-5 font-heading text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl">Need a plumber?<br />Let's get it sorted.</h2>
            <p class="mt-4 max-w-lg text-base leading-relaxed text-white/75">If it involves pipes, taps or gas, our licensed team has almost certainly handled it before. Same-day available — no call-out fee during standard hours.</p>
            <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold text-white/85">
              {['$0 call-out (standard hours)', 'Upfront fixed pricing', 'Same-day service', 'Fully licensed #333997'].map((b) => (
                <span class="flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-accent"><path d="M5 12l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</span>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2.5 skew-btn rounded-lg bg-brand-accent px-7 py-4 text-lg font-extrabold text-white shadow-[0_14px_34px_-12px_rgba(255,122,27,0.65)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-accent/90">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z"/></svg>
              {PHONE}
            </a>
            <a href="/contact" class="skew-border-btn inline-flex items-center justify-center border-2 border-white/30 bg-white/10 px-7 py-4 text-lg font-bold text-white backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-white/60 hover:bg-white/20">
              <span class="btn-inner">Book Online</span>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>
</Direction1Layout>

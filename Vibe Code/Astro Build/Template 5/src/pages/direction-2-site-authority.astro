---
import Layout from '../layouts/Layout.astro';
import Header from '../components/direction-2/Header.astro';
import Hero from '../components/direction-2/Hero.astro';
import PromoStrip from '../components/direction-2/PromoStrip.astro';
import Testimonials from '../components/direction-2/Testimonials.astro';
import ValueProp from '../components/direction-2/ValueProp.astro';
import Services from '../components/direction-2/Services.astro';
import BlockedDrainsDeepDive from '../components/direction-2/BlockedDrainsDeepDive.astro';
import ToiletDeepDive from '../components/direction-2/ToiletDeepDive.astro';
import PipeReliningDeepDive from '../components/direction-2/PipeReliningDeepDive.astro';
import WhyChoose from '../components/direction-2/WhyChoose.astro';
import Process from '../components/direction-2/Process.astro';
import FAQ from '../components/direction-2/FAQ.astro';
import Areas from '../components/direction-2/Areas.astro';
import Team from '../components/direction-2/Team.astro';
import CTABanner from '../components/direction-2/CTABanner.astro';
import Footer from '../components/direction-2/Footer.astro';
---

<Layout title="Site Authority — Aptec Plumbing">
  <style is:global>
    :root {
      --color-brand-primary:   #0B2847;
      --color-brand-secondary: #1B3C5C;
      --color-brand-accent:    #FF7A1A;
      --color-brand-bg:        #FBFBFA;
      --color-brand-surface:   #EFF2F5;
      --color-brand-text:      #10202E;
      --color-brand-muted:     #5E6B76;
      --font-heading: 'Sora Variable', system-ui, sans-serif;
      --font-body:    'IBM Plex Sans Variable', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--color-brand-text); background: var(--color-brand-bg); }
    h1, h2, h3 { font-family: var(--font-heading); }

    /* ── Industrial corner-bracket motif ───────────────── */
    .bracket-frame { position: relative; }
    .bracket-frame::before,
    .bracket-frame::after {
      content: ''; position: absolute; width: 22px; height: 22px; z-index: 2;
      border-color: var(--color-brand-accent); border-style: solid; border-width: 0;
    }
    .bracket-frame::before { top: -7px; left: -7px; border-top-width: 3px; border-left-width: 3px; }
    .bracket-frame::after  { bottom: -7px; right: -7px; border-bottom-width: 3px; border-right-width: 3px; }
    .bracket-light::before, .bracket-light::after { border-color: var(--color-brand-accent); }

    /* CTA button corner bracket on hover */
    .corner-bracket-btn { position: relative; }
    .corner-bracket-btn::before,
    .corner-bracket-btn::after {
      content: ''; position: absolute; width: 8px; height: 8px;
      border-color: rgba(255,255,255,0.85); border-style: solid; border-width: 0;
      opacity: 0; transition: opacity .25s ease, inset .25s ease;
    }
    .corner-bracket-btn::before { top: 4px; left: 4px; border-top-width: 2px; border-left-width: 2px; }
    .corner-bracket-btn::after  { bottom: 4px; right: 4px; border-bottom-width: 2px; border-right-width: 2px; }
    .corner-bracket-btn:hover::before, .corner-bracket-btn:hover::after { opacity: 1; }

    /* ── Hero staggered entrance ───────────────────────── */
    .hero-stagger { opacity: 0; transform: translateY(16px); animation: heroIn .7s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: var(--d, 0ms); }
    @keyframes heroIn { to { opacity: 1; transform: none; } }

    /* ── Scroll reveal ─────────────────────────────────── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .7s cubic-bezier(0.22,1,0.36,1), transform .7s cubic-bezier(0.22,1,0.36,1); transition-delay: var(--stagger, 0ms); }
    .reveal.is-visible { opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      .hero-stagger, .reveal { animation: none !important; opacity: 1 !important; transform: none !important; transition: none !important; }
      html { scroll-behavior: auto; }
    }

    :focus-visible { outline: 2px solid var(--color-brand-accent); outline-offset: 2px; }
  </style>

  <Header />
  <main>
    <Hero />
    <PromoStrip />
    <Testimonials />
    <ValueProp />
    <Services />
    <BlockedDrainsDeepDive />
    <ToiletDeepDive />
    <PipeReliningDeepDive />
    <WhyChoose />
    <Process />
    <FAQ />
    <Areas />
    <Team />
    <CTABanner />
  </main>
  <Footer />

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</Layout>

---
import Direction1Layout from '../layouts/Direction1Layout.astro';
import Drip from '../components/direction-1/Drip.astro';
import FaqAccordion from '../components/direction-1/FaqAccordion.tsx';
import CouponStrip from '../components/direction-1/CouponStrip.astro';
import ProcessSection from '../components/direction-1/ProcessSection.astro';
import ServiceAreaSection from '../components/direction-1/ServiceAreaSection.astro';
import { PHONE, PHONE_HREF } from '../data/site';

const drainServices = [
  { title: 'Kitchen Sink Drains', img: '/images/Bathroom-Drain.webp', desc: 'Grease and food build-up cleared properly.' },
  { title: 'Shower & Bathroom Drains', img: '/images/Clogged-Shower-Drain-Aptec-Plumbing.webp', desc: 'Hair and soap scum no match for our gear.' },
  { title: 'Blocked Toilets', img: '/images/Blocked-Toilet-Aptec-Plumbing.webp', desc: 'Fast, no-mess clearing — same day where possible.' },
  { title: 'Sewer Line Blockages', img: '/images/Tree-Root-Removal.webp', desc: 'Root intrusion and collapsed pipe sections fixed.' },
  { title: 'Stormwater Pits', img: '/images/Stormwater-Pits.webp', desc: 'Pit clearing, repair and cover replacement.' },
  { title: 'High-Pressure Jetting', img: '/images/Water-Jetting-Aptec-Plumbing.webp', desc: 'Stubborn blockages blasted clear, pipe-safe.' },
  { title: 'CCTV Drain Inspection', img: '/images/Drain-Camera-Inspection.webp', desc: "See exactly what's wrong before we start." },
  { title: 'No-Dig Pipe Relining', img: '/images/Pipe-Relining.webp', desc: 'Structural repair without digging up your yard.' },
];

const warningSigns = [
  { t: 'Slow draining water', d: 'Sinks, showers or tubs taking longer than usual to empty.' },
  { t: 'Gurgling sounds', d: 'Strange noises from drains or toilets after flushing.' },
  { t: 'Bad odours', d: 'Persistent smell from a drain that won’t go away.' },
  { t: 'Water pooling', d: 'Standing water around floor drains or outside pits.' },
  { t: 'Multiple fixtures affected', d: 'More than one drain backing up at the same time.' },
  { t: 'Toilet water level changes', d: 'Bowl filling higher or lower than normal.' },
];

const process = [
  { n: '01', t: 'Assess the blockage', d: 'We talk through the symptoms and inspect the affected drain or pipe.' },
  { n: '02', t: 'Choose the right method', d: 'Jetting, electric eel or CCTV-guided clearing — whatever actually fixes it.' },
  { n: '03', t: 'Clear it properly', d: 'We remove the blockage and clean up, not just push the problem further down the line.' },
  { n: '04', t: 'Confirm it’s sorted', d: 'A camera check on request, so you can see the pipe is genuinely clear.' },
];

const drainFaqs = [
  { q: 'How much does it cost to clear a blocked drain?', a: 'Our standard blocked drain clear starts from $99 for a single, accessible drain — fixed price, quoted upfront before we start. More complex jobs (tree roots, collapsed pipes) are quoted after a quick inspection.' },
  { q: 'How long does it take to clear a blocked drain?', a: 'Most single-drain blockages are cleared in under an hour. Tree root removal or pipe relining jobs can take longer — we’ll always give you a realistic time estimate before starting.' },
  { q: 'Can you tell what’s causing the blockage before you start?', a: 'Yes — we offer a free CCTV drain inspection with any blocked drain clearing, so you can see exactly what’s going on underground before any work begins.' },
  { q: 'Do you offer emergency blocked drain service?', a: 'Yes, we’re available 24/7 for urgent blockages, including overflowing toilets and sewer backups. Call (08) 8000 5050 any time.' },
  { q: 'What causes most blocked drains?', a: 'Grease and food waste in kitchen drains, hair and soap in bathroom drains, and tree root intrusion in sewer lines are the most common causes we see across southern Adelaide.' },
  { q: 'Will jetting damage my old pipes?', a: 'No — our high-pressure jetting equipment is calibrated for safe use on residential pipework, including older clay and PVC pipes. We assess pipe condition first if there’s any doubt.' },
  { q: 'Do you provide a warranty on drain clearing?', a: 'Yes, all blocked drain work is backed by our labour warranty. If the same blockage returns shortly after, we’ll come back and sort it.' },
];
---
<Direction1Layout title="Blocked Drains — Aptec Plumbing" description="Blocked drain plumber for Happy Valley & southern Adelaide. $99 blocked drain special, free CCTV inspection, 24/7 emergency clearing.">
  <div id="top">

    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-brand-secondary">
      <div class="pointer-events-none absolute inset-0" style="background: linear-gradient(135deg, #0B2847 0%, #0d3260 40%, #156ECE 100%); opacity: 0.95;"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>

      <div class="relative mx-auto grid max-w-7xl items-center gap-10 px-5 py-14 md:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:py-20">
        <div class="hero-stagger">
          <div class="inline-flex items-center gap-2 rounded-lg border border-brand-accent/40 bg-brand-accent/20 px-3.5 py-1.5 text-xs font-bold text-brand-accent">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.8 6.1 20.8l1.2-6.6L2.5 9l6.6-.9L12 2Z"/></svg>
            5.0 Rating · From $99 Fixed Price
          </div>
          <h1 class="mt-5 font-heading text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl lg:text-6xl">
            Blocked drain?
            <span class="relative inline-block text-brand-accent">
              Cleared today.
              <svg class="absolute -bottom-1 left-0 w-full" viewBox="0 0 200 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M2 5c40-5 60 3 100-1s56-4 96 1" stroke="#FF7A1B" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
            Slow, gurgling or fully blocked — we clear it properly the first time. Fixed-price drain clearing, free CCTV inspection on request, and 24/7 emergency cover.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={PHONE_HREF} class="group inline-flex items-center justify-center gap-2.5 skew-btn rounded-lg bg-brand-accent px-7 py-3.5 text-base font-bold text-white shadow-[0_14px_34px_-12px_rgba(255,122,27,0.6)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-accent/90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z" fill="currentColor"/></svg>
              Call {PHONE}
            </a>
            <a href="/contact" class="skew-border-btn inline-flex items-center justify-center border-2 border-white/25 bg-white/10 px-7 py-3.5 text-base font-bold text-white backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-white/50 hover:bg-white/20">
              <span class="btn-inner">Book Online</span>
            </a>
          </div>

          <div class="mt-10 grid grid-cols-1 gap-3 border-t border-white/15 pt-8 sm:grid-cols-3">
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-accent/20 text-brand-accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">$0 Call Out Fee</p>
                <p class="text-xs text-white/60">Clear. Fair. Simple.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="stat-icon stat-icon-clock grid size-11 shrink-0 place-items-center skew-btn rounded-lg bg-brand-primary/30 text-white">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path class="stat-icon-hand" d="M12 7v5l3.5 2"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Same-Day Service</p>
                <p class="text-xs text-white/60">Fast. Reliable. Today.</p>
              </div>
            </div>
            <div class="flex items-center gap-3.5 rounded-lg bg-white/8 p-4 backdrop-blur">
              <span class="grid size-11 shrink-0 place-items-center rounded-lg bg-green-400/20 text-green-400">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l7 4v6c0 5-3.5 8.7-7 10C8.5 20.7 5 17 5 12V6l7-4z"/><path d="M9 12l2 2 4-4"/></svg>
              </span>
              <div>
                <p class="font-heading text-sm font-extrabold text-white">Free CCTV</p>
                <p class="text-xs text-white/60">With any drain clearing</p>
              </div>
            </div>
          </div>
        </div>
        <div class="hero-img relative">
          <div class="skew-img overflow-hidden shadow-[0_30px_70px_-25px_rgba(0,0,0,0.5)]">
            <img src="/images/Drain-Camera-Inspection.webp" alt="CCTV drain camera inspection" class="aspect-[4/5] w-full object-cover sm:aspect-[5/5]" width="640" height="800" />
          </div>
          <div class="absolute -left-3 bottom-6 flex items-center gap-3 rounded-xl bg-brand-bg p-3.5 pr-5 shadow-[0_20px_45px_-18px_rgba(0,0,0,0.5)] ring-1 ring-white/10 sm:-left-6">
            <span class="grid size-11 place-items-center skew-btn rounded-lg bg-brand-accent text-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/></svg>
            </span>
            <div>
              <p class="font-heading text-sm font-extrabold leading-tight text-brand-secondary">Free CCTV Inspection</p>
              <p class="text-xs text-brand-muted">With any drain clearing</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CouponStrip />

    <!-- ============ TRUSTED LOCALLY ============ -->
    <section class="bg-brand-bg">
      <div class="mx-auto max-w-7xl px-5 py-16 md:px-6 md:py-20">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="reveal">
            <Drip label="Trusted Locally" />
            <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight text-brand-secondary sm:text-4xl">The blocked drain plumber Happy Valley trusts</h2>
            <p class="mt-5 leading-relaxed text-brand-muted">Blocked drains are usually caused by grease build-up, hair and soap, or tree roots working their way into ageing pipes. Clearing the symptom without finding the cause just means it comes back.</p>
            <p class="mt-3 leading-relaxed text-brand-muted">We diagnose the real problem first — with a CCTV camera if needed — then clear it with the right method, not just whatever's quickest.</p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href={PHONE_HREF} class="inline-flex items-center gap-2 skew-btn rounded-lg bg-brand-primary px-6 py-3 text-base font-bold text-white shadow-[0_10px_28px_-12px_rgba(21,110,206,0.5)] transition-all duration-200 hover:-translate-y-0.5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z"/></svg>
                Call us now
              </a>
              <a href="/contact" class="skew-border-btn inline-flex items-center border-2 border-brand-secondary/15 px-6 py-3 text-base font-bold text-brand-secondary transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-primary/40 hover:text-brand-primary">
                <span class="btn-inner">Get a free quote</span>
              </a>
            </div>
          </div>
          <div class="reveal grid grid-cols-2 gap-4">
            {[
              { n: '15+', label: 'Years local experience', icon: 'M12 2l7 4v6c0 5-3.5 8.7-7 10C8.5 20.7 5 17 5 12V6l7-4z', color: 'bg-brand-primary/10 text-brand-primary' },
              { n: '5.0★', label: 'Google rating · 236 reviews', icon: 'M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.8 6.1 20.8l1.2-6.6L2.5 9l6.6-.9L12 2Z', color: 'bg-brand-accent/10 text-brand-accent' },
              { n: '$0', label: 'Call-out fee (standard hours)', icon: 'M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6', color: 'bg-green-400/10 text-green-600' },
              { n: '24/7', label: 'Emergency drain response', icon: 'M12 3a9 9 0 1 0 0 18A9 9 0 0 0 12 3zM12 7v5l3.5 2', color: 'bg-brand-primary/10 text-brand-primary' },
            ].map((stat) => (
              <div class="rounded-2xl border border-brand-secondary/8 bg-brand-surface p-6 shadow-[0_8px_28px_-12px_rgba(11,40,71,0.15)]">
                <span class={`grid size-11 place-items-center rounded-xl ${stat.color}`}>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={stat.icon}/></svg>
                </span>
                <p class="mt-4 font-heading text-3xl font-extrabold tracking-tight text-brand-secondary">{stat.n}</p>
                <p class="mt-1 text-sm leading-snug text-brand-muted">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DRAIN SERVICES GRID ============ -->
    <section class="bg-brand-surface">
      <div class="mx-auto max-w-7xl px-5 py-14 md:px-6 md:py-16">
        <div class="reveal mx-auto mb-12 max-w-2xl text-center">
          <Drip label="What We Clear" align="center" />
          <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight text-brand-secondary sm:text-4xl">Every type of blocked drain, sorted</h2>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {drainServices.map((s) => (
            <div class="reveal group overflow-hidden rounded-2xl bg-brand-bg shadow-[0_12px_35px_-24px_rgba(11,40,71,0.4)] transition-all duration-300 hover:-translate-y-1.5">
              <div class="relative aspect-[4/3] overflow-hidden bg-brand-surface">
                <img src={s.img} alt={s.title} loading="lazy" class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" />
              </div>
              <div class="p-5 text-center">
                <h3 class="font-heading text-base font-bold text-brand-secondary">{s.title}</h3>
                <p class="mt-1.5 text-sm leading-snug text-brand-muted">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ WARNING SIGNS ============ -->
    <section class="relative overflow-hidden bg-brand-secondary">
      <div class="pointer-events-none absolute -left-20 top-10 size-72 rounded-full bg-brand-primary/20 blur-3xl"></div>
      <div class="relative mx-auto max-w-7xl px-5 py-14 md:px-6 md:py-16">
        <div class="reveal mx-auto mb-12 max-w-2xl text-center text-white">
          <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-brand-accent">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor" aria-hidden="true"><path d="M6 0C6 0 1 6.2 1 10a5 5 0 0 0 10 0C11 6.2 6 0 6 0Z"/></svg>
            Don't Ignore These
          </span>
          <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight sm:text-4xl">Signs your drain needs attention</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {warningSigns.map((w) => (
            <div class="reveal rounded-xl border border-white/10 bg-white/5 p-5">
              <div class="flex items-center gap-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><path d="M12 9v4M12 17h.01"/></svg>
                <p class="font-heading text-base font-bold text-white">{w.t}</p>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-white/65">{w.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ PROCESS ============ -->
    <ProcessSection />

    <!-- ============ FAQ ============ -->
    <section id="faq" class="scroll-mt-24 bg-brand-surface">
      <div class="mx-auto max-w-7xl px-5 py-14 md:px-6 md:py-16">
        <div class="reveal mx-auto mb-12 max-w-2xl text-center">
          <Drip label="Common Questions" align="center" />
          <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight text-brand-secondary sm:text-4xl">Blocked drains — frequently asked questions</h2>
        </div>
        <div class="reveal">
          <FaqAccordion client:visible faqs={drainFaqs} />
        </div>
      </div>
    </section>

    <!-- ============ SERVICE AREAS ============ -->
    <ServiceAreaSection heading="Blocked drain plumbing across southern Adelaide" />

    <!-- ============ FINAL CTA ============ -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/Aptec-Plumbing-1920.webp" alt="" aria-hidden="true" class="h-full w-full object-cover object-center" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(11,40,71,0.93) 0%, rgba(13,50,96,0.88) 50%, rgba(21,110,206,0.82) 100%);"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="relative mx-auto max-w-7xl px-5 py-20 md:px-6 md:py-24">
        <div class="reveal grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="text-white">
            <p class="inline-flex items-center gap-2 rounded-lg border border-brand-accent/40 bg-brand-accent/20 px-3.5 py-1.5 text-xs font-bold text-brand-accent"><span class="inline-block size-2 animate-pulse rounded-full bg-brand-accent"></span> We're available now</p>
            <h2 class="mt-5 font-heading text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl">Need a plumber?<br />Let's get it sorted.</h2>
            <p class="mt-4 max-w-lg text-base leading-relaxed text-white/75">Fast, fixed-price drain clearing across Happy Valley and southern Adelaide. Same-day available — no call-out fee during standard hours.</p>
            <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold text-white/85">
              {['$0 call-out (standard hours)', 'Upfront fixed pricing', 'Same-day service', 'Fully licensed #333997'].map((b) => (
                <span class="flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-accent"><path d="M5 12l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</span>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2.5 skew-btn rounded-lg bg-brand-accent px-7 py-4 text-lg font-extrabold text-white shadow-[0_14px_34px_-12px_rgba(255,122,27,0.65)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-accent/90">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5.5C3 4.1 4.1 3 5.5 3h1.6c.6 0 1.1.4 1.3 1l1 3a1.4 1.4 0 0 1-.4 1.5L8.3 9.6a13 13 0 0 0 6.1 6.1l1.1-1.7c.3-.5.9-.7 1.5-.5l3 1c.6.2 1 .7 1 1.3v1.6c0 1.4-1.1 2.5-2.5 2.5C10.5 21 3 13.5 3 5.5Z"/></svg>
              {PHONE}
            </a>
            <a href="/contact" class="skew-border-btn inline-flex items-center justify-center border-2 border-white/30 bg-white/10 px-7 py-4 text-lg font-bold text-white backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-white/60 hover:bg-white/20">
              <span class="btn-inner">Book Online</span>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>
</Direction1Layout>

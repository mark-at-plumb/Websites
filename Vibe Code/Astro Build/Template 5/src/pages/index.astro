---
import Layout from '../layouts/Layout.astro';

const directions = [
  {
    n: 1,
    name: 'Trade Blue',
    slug: 'direction-1-trade-blue',
    description: 'Classic plumbing-trade blue on white, closest to the reference site. Rounded cards, soft shadows, bold confident headlines, green "$0 Call Out" accent.',
  },
  {
    n: 2,
    name: 'Site Authority',
    slug: 'direction-2-site-authority',
    description: 'Deeper navy and steel tones with a safety-orange accent. Flat elevation, sharp edges, uppercase tracked-out labels — rugged trade authority.',
  },
  {
    n: 3,
    name: 'Bright Service',
    slug: 'direction-3-bright-service',
    description: 'Lighter sky-blue and lime-green palette pulled from the promo badge colors. Pill buttons, dramatic soft shadows, friendlier modern feel.',
  },
];
---
<Layout title="Aptec Plumbing — Homepage Concepts">
  <main style="max-width: 680px; margin: 0 auto; padding: 4rem 1.5rem; font-family: var(--font-body);">
    <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">Aptec Plumbing — Homepage Concepts</h1>
    <p style="color: #666; margin-bottom: 3rem;">Click each direction to preview it. Scroll through fully before deciding.</p>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {directions.map(d => (
        <a href={`/${d.slug}`} style="display: block; padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.15s;">
          <div style="font-size: 0.75rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">Direction {d.n}</div>
          <div style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem;">{d.name}</div>
          <div style="color: #555; font-size: 0.9rem; line-height: 1.5;">{d.description}</div>
        </a>
      ))}
    </div>
  </main>
</Layout>
